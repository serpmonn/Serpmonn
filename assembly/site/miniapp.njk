---
permalink: "/frontend/mini/miniapp.html"
layout: "layouts/vk-mini.njk"
title: "Серпмонн"
---

<script>
  window.__SPN_VK_MINI__ = true;
  window.__SPN_MINI_CFG__ = {{ miniApp | dump | safe }};
</script>

<div class="vk-mini-shell">
  <div class="vk-mini-screens">

    {# —— PROFILE —— #}
    <section class="vk-mini-screen vk-mini-profile-screen" data-screen="profile" aria-label="{{ miniApp.nav.profile }}">
      <div class="vk-mini-profile" id="vk-mini-auth" data-state="guest">
        <div class="vk-mini-profile__avatar-wrap">
          <img id="vk-mini-auth-photo" class="vk-mini-profile__avatar" src="/frontend/images/serpmonn.ico?v=3" alt="" width="72" height="72">
        </div>
        <h2 class="vk-mini-profile__name" id="vk-mini-profile-name">{{ miniApp.profile.guestName }}</h2>
        <p class="vk-mini-profile__text" id="vk-mini-profile-text">{{ miniApp.profile.guestText }}</p>
        <p class="vk-mini-profile__quota" id="vk-mini-auth-hint">{{ miniApp.profile.quotaGuest }}</p>
        <div class="vk-mini-profile__actions">
          <button type="button" class="vk-mini-auth__login" id="vk-mini-auth-login">
            {{ miniApp.auth.login }}
          </button>
          <button type="button" class="vk-mini-auth__logout" id="vk-mini-auth-logout" hidden>
            {{ miniApp.profile.logout }}
          </button>
          <button type="button" class="vk-mini-auth__delete" id="vk-mini-auth-delete" hidden>
            {{ miniApp.profile.deleteAccount }}
          </button>
        </div>

        <div class="vk-mini-legal" id="vk-mini-legal">
          <p class="vk-mini-legal__title">{{ miniApp.legal.linksTitle }}</p>
          <div class="vk-mini-legal__links">
            <button type="button" class="vk-mini-legal__link"
              data-open-url="{{ miniApp.legal.privacyUrl }}"
              data-open-title="{{ miniApp.legal.privacyTitle }}">
              {{ miniApp.legal.privacyTitle }}
            </button>
            <button type="button" class="vk-mini-legal__link"
              data-open-url="{{ miniApp.legal.offerUrl }}"
              data-open-title="{{ miniApp.legal.offerTitle }}">
              {{ miniApp.legal.offerTitle }}
            </button>
          </div>
        </div>

        <div class="vk-mini-auth-serp" id="vk-mini-auth-serp">
          <div class="vk-mini-auth-serp__divider" aria-hidden="true">
            <span>{{ miniApp.auth.orDivider }}</span>
          </div>
          <form class="vk-mini-auth-serp__form" id="vk-mini-serp-login-form" autocomplete="on">
            <label class="vk-mini-auth-serp__label" for="vk-mini-serp-email">{{ miniApp.auth.emailLabel }}</label>
            <input
              class="vk-mini-auth-serp__input"
              type="email"
              id="vk-mini-serp-email"
              name="email"
              inputmode="email"
              autocomplete="username"
              placeholder="{{ miniApp.auth.emailPlaceholder }}"
              required
            >
            <label class="vk-mini-auth-serp__label" for="vk-mini-serp-password">{{ miniApp.auth.passwordLabel }}</label>
            <input
              class="vk-mini-auth-serp__input"
              type="password"
              id="vk-mini-serp-password"
              name="password"
              autocomplete="current-password"
              placeholder="{{ miniApp.auth.passwordPlaceholder }}"
              minlength="6"
              required
            >
            <p class="vk-mini-auth-serp__error" id="vk-mini-serp-login-error" hidden></p>
            <button type="submit" class="vk-mini-auth-serp__submit" id="vk-mini-serp-login-submit">
              {{ miniApp.auth.submitSerpmonn }}
            </button>
          </form>
          <div class="vk-mini-auth-serp__links">
            <button type="button" class="vk-mini-auth-serp__link" id="vk-mini-serp-register"
              data-open-url="/frontend/register/register.html"
              data-open-title="{{ miniApp.auth.registerLink }}">
              {{ miniApp.auth.registerLink }}
            </button>
            <button type="button" class="vk-mini-auth-serp__link" id="vk-mini-serp-forgot"
              data-open-url="/frontend/login/forgot/forgot.html"
              data-open-title="{{ miniApp.auth.forgotLink }}">
              {{ miniApp.auth.forgotLink }}
            </button>
          </div>
        </div>

        <span id="vk-mini-auth-status" hidden></span>
        <span id="vk-mini-auth-label" hidden>{{ miniApp.auth.statusUser }}</span>
      </div>
    </section>

    {# —— SEARCH —— #}
    <section class="vk-mini-screen is-active vk-mini-search" data-screen="search" aria-label="{{ miniApp.nav.search }}">
      <div class="news-block" id="news-block" style="display:none;">
        <div class="news-block-header">
          <div class="news-dot"></div>
          <span class="news-block-title">{{ miniApp.news.feedTitle }}</span>
        </div>

        <div id="news-hero-wrap"></div>

        <div class="feed-wrapper">
          <button class="feed-arrow feed-arrow-left" aria-label="Назад" hidden>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="news-feed" id="news-feed"></div>
          <button class="feed-arrow feed-arrow-right" aria-label="Вперёд">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>

      <div class="search-card-wrapper">
        <div class="main-search-container">
          <img src="/frontend/images/serpmonn.ico?v=3" alt="Серпмонн" class="logo" width="40" height="40">
          <form id="ai-search-form" class="search-form">
            <div class="search-form-body">
              <div class="search-form-row">
                <div class="search-input-wrapper">
                  <button
                    type="button"
                    id="attach-txt-btn"
                    class="attach-btn"
                    aria-label="Прикрепить текстовый файл"
                    title="Прикрепить .txt файл"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                    </svg>
                  </button>
                  <input
                    type="file"
                    id="attach-txt-input"
                    accept=".txt,text/plain"
                    hidden
                  >
                  <input
                    type="search"
                    name="q"
                    placeholder="{{ miniApp.search.placeholder }}"
                    autocomplete="off"
                    required
                    autofocus
                    title="{{ miniApp.search.hint }}"
                  >
                  <button
                    type="button"
                    id="voice-input-btn"
                    class="voice-btn is-hidden"
                    aria-label="Голосовой ввод"
                    title="Голосовой ввод"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                      <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                      <line x1="12" y1="19" x2="12" y2="23"/>
                      <line x1="8" y1="23" x2="16" y2="23"/>
                    </svg>
                  </button>
                </div>
                <button type="submit" aria-label="{{ miniApp.search.submitAria }}" class="search-btn" title="{{ miniApp.search.submitAria }}">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                       stroke="#ff4d4d" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7" />
                    <polyline points="7 7 17 7 17 17" />
                  </svg>
                </button>
              </div>
              <div id="search-attachment-preview" class="search-attachment-preview" hidden></div>
            </div>
          </form>
        </div>

        <div id="ai-result-container" class="ai-result-container" style="display: none;">
          <div id="ai-result-content" class="ai-result-content"></div>
          <div id="ai-image-results" class="ai-image-results" style="display:none;"></div>
          <div id="ai-video-results" class="ai-video-results" style="display:none;"></div>
          <div class="ai-result-footer is-pending">
            <div class="ai-actions">
              <button class="ai-action-btn" data-ai-action="copy" title="{{ miniApp.search.copy }}" aria-label="{{ miniApp.search.copy }}">
                <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="9" y="9" width="10" height="12" rx="2"></rect>
                  <rect x="5" y="3" width="10" height="12" rx="2"></rect>
                </svg>
              </button>
              <button class="ai-action-btn" data-ai-action="share" title="{{ miniApp.search.share }}" aria-label="{{ miniApp.search.share }}">
                <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M7 12v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6"></path>
                  <path d="M12 5l0 12"></path>
                  <path d="M8 9l4-4 4 4"></path>
                </svg>
              </button>
            </div>
            <div class="ai-feedback">
              <button class="feedback-btn like" title="{{ miniApp.search.like }}" aria-label="{{ miniApp.search.like }}">
                <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M7 11v10"></path>
                  <path d="M3 11h4"></path>
                  <path d="M9 21h7.2a2 2 0 0 0 2-1.6l1.2-7A2 2 0 0 0 17.4 10H14l.5-3.5A2 2 0 0 0 12.5 4l-3.2 5.1A2 2 0 0 1 8 10H7"></path>
                </svg>
              </button>
              <button class="feedback-btn dislike" title="{{ miniApp.search.dislike }}" aria-label="{{ miniApp.search.dislike }}">
                <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M7 13V3"></path>
                  <path d="M3 13h4"></path>
                  <path d="M9 3h7.2a2 2 0 0 1 2 1.6l1.2 7A2 2 0 0 1 17.4 14H14l.5 3.5A2 2 0 0 1 12.5 20l-3.2-5.1A2 2 0 0 0 8 14H7"></path>
                </svg>
              </button>
            </div>
            <div class="ai-timestamp" id="ai-timestamp"></div>
          </div>
        </div>
      </div>

      <div id="ai-share-toast" class="ai-share-toast" style="display:none;"></div>
    </section>

    {# —— NEWS —— #}
    <section class="vk-mini-screen" data-screen="news" aria-label="{{ miniApp.nav.news }}">
      <h2 class="vk-mini-section-title">{{ miniApp.news.title }}</h2>
      <p class="vk-mini-section-sub">{{ miniApp.news.subtitle }}</p>
      <div class="vk-mini-card-list">
        {% for article in localesNews.ru.news.articles %}
          {% set link = article.link or '' %}
          {% set risky = ('serpmonn-install-guide' in link)
             or ('donate' in link)
             or ('/promo' in link)
             or ('promocode' in link)
             or ('snippet-limits' in link)
             or ('telegram' in link)
             or ('updates-' in link)
             or ('updates_' in link) %}
          {% if not risky %}
            <button type="button" class="vk-mini-card"
                    data-open-url="{{ article.link }}"
                    data-open-title="{{ article.title | escape }}">
              <strong>{{ article.title }}</strong>
              <span>{{ article.excerpt }}</span>
              <span class="vk-mini-meta">{{ article.categoryLabel }} · {{ article.date }} · {{ article.readTime }}</span>
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </section>

    {# —— TOOLS —— #}
    <section class="vk-mini-screen" data-screen="tools" aria-label="{{ miniApp.nav.tools }}">
      <h2 class="vk-mini-section-title">{{ miniApp.tools.title }}</h2>
      <p class="vk-mini-section-sub">{{ miniApp.tools.subtitle }}</p>
      <div class="vk-mini-card-list">
        {% for tool in miniApp.tools.items %}
          <button type="button" class="vk-mini-card"
                  data-open-url="{{ tool.href }}"
                  data-open-title="{{ tool.title | escape }}">
            <strong>{{ tool.title }}</strong>
            <span>{{ tool.description }}</span>
          </button>
        {% endfor %}
      </div>
    </section>

    {# —— GAMES —— #}
    <section class="vk-mini-screen" data-screen="games" aria-label="{{ miniApp.nav.games }}">
      <h2 class="vk-mini-section-title">{{ miniApp.games.title }}</h2>
      <p class="vk-mini-section-sub">{{ miniApp.games.subtitle }}</p>
      <div class="vk-mini-card-list">
        {% for group in localesGames.ru.games.groups %}
          {% if group.key == 'serpmonn' %}
            {% for platform in group.platforms %}
              {% if platform.key == 'web' %}
                {% for game in platform.games %}
                  <button type="button" class="vk-mini-card"
                          data-open-url="{{ game.link }}"
                          data-open-title="{{ game.name | escape }}">
                    <strong>{{ game.name }}</strong>
                    <span>{{ game.description }}</span>
                  </button>
                {% endfor %}
              {% endif %}
            {% endfor %}
          {% endif %}
        {% endfor %}
      </div>
    </section>
  </div>

  <nav class="vk-mini-nav" aria-label="Навигация мини-приложения">
    <button type="button" data-screen="profile">
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c1.5-4 4.5-6 8-6s6.5 2 8 6"/></svg>
      {{ miniApp.nav.profile }}
    </button>
    <button type="button" data-screen="search" class="is-active">
      <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      {{ miniApp.nav.search }}
    </button>
    <button type="button" data-screen="news">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h12v14H4z"/><path d="M16 8h4v11h-4"/><path d="M7 9h6M7 13h6M7 17h4"/></svg>
      {{ miniApp.nav.news }}
    </button>
    <button type="button" data-screen="tools">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14.7 6.3a4 4 0 0 0-5.4 5.4L4 17l3 3 5.3-5.3a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5z"/></svg>
      {{ miniApp.nav.tools }}
    </button>
    <button type="button" data-screen="games">
      <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="8" width="18" height="10" rx="3"/><path d="M8 13h2M9 12v2"/><circle cx="15" cy="12" r="1"/><circle cx="17.5" cy="14" r="1"/></svg>
      {{ miniApp.nav.games }}
    </button>
  </nav>
</div>

{# Viewer #}
<div class="vk-mini-viewer" id="vk-mini-viewer" aria-hidden="true">
  <div class="vk-mini-viewer__bar">
    <button type="button" class="vk-mini-viewer__back" id="vk-mini-viewer-back">{{ miniApp.viewer.back }}</button>
    <div class="vk-mini-viewer__title" id="vk-mini-viewer-title"></div>
  </div>
  <iframe id="vk-mini-viewer-frame" title="Содержимое"></iframe>
</div>

{# Onboarding #}
<div class="vk-mini-onboarding" id="vk-mini-onboarding" aria-hidden="true">
  <div class="vk-mini-onboarding__panel" role="dialog" aria-modal="true" aria-label="Онбординг">
    <div class="vk-mini-onboarding__dots">
      {% for slide in miniApp.onboarding.slides %}
        <span{% if loop.first %} class="is-active"{% endif %}></span>
      {% endfor %}
    </div>
    {% for slide in miniApp.onboarding.slides %}
      <div class="vk-mini-onboarding__slide"{% if not loop.first %} hidden{% endif %}>
        <h2>{{ slide.title }}</h2>
        <p>{{ slide.text }}</p>
      </div>
    {% endfor %}
    <div class="vk-mini-onboarding__consent" id="vk-mini-onboarding-consent">
      <label class="vk-mini-onboarding__consent-label">
        <input type="checkbox" id="vk-mini-consent-check">
        <span>{{ miniApp.legal.consentLabel }}</span>
      </label>
      <div class="vk-mini-onboarding__consent-links">
        <button type="button" class="vk-mini-legal__link"
          data-open-url="{{ miniApp.legal.privacyUrl }}"
          data-open-title="{{ miniApp.legal.privacyTitle }}">
          {{ miniApp.legal.privacyTitle }}
        </button>
        <button type="button" class="vk-mini-legal__link"
          data-open-url="{{ miniApp.legal.offerUrl }}"
          data-open-title="{{ miniApp.legal.offerTitle }}">
          {{ miniApp.legal.offerTitle }}
        </button>
      </div>
      <p class="vk-mini-onboarding__consent-error" id="vk-mini-consent-error" hidden>
        {{ miniApp.legal.consentRequired }}
      </p>
    </div>
    <div class="vk-mini-onboarding__actions">
      <button type="button" data-onboard-skip>{{ miniApp.onboarding.skip }}</button>
      <button type="button" class="is-primary" data-onboard-next>{{ miniApp.onboarding.next }}</button>
    </div>
  </div>
</div>

{# Limit / auth soft wall #}
<div class="vk-mini-limit" id="vk-mini-limit" aria-hidden="true">
  <div class="vk-mini-limit__panel" role="dialog" aria-modal="true" aria-labelledby="vk-mini-limit-title">
    <h2 id="vk-mini-limit-title"></h2>
    <p id="vk-mini-limit-text"></p>
    <div class="vk-mini-limit__actions" id="vk-mini-limit-actions"></div>
    <button type="button" class="vk-mini-limit__close" id="vk-mini-limit-close">{{ miniApp.limit.close }}</button>
  </div>
</div>

<script src="https://unpkg.com/@vkontakte/vk-bridge@2.6.0/dist/browser.min.js"></script>
<script type="module" src="/frontend/scripts/scripts.js" defer></script>
<script src="/frontend/scripts/mini/miniapp.js?v=19" defer></script>
