---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/logistics/fuel-calculator.html{% else %}/frontend/{{ locale }}/tools/logistics/fuel-calculator.html{% endif %}"
eleventyComputed:
  title: "{{ fuelCalculator[locale].meta.title }}"
  description: "{{ fuelCalculator[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/logistics/fuel-calculator.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/logistics/fuel-calculator.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ fuelCalculator[locale].meta.title }}</title>
    <meta name="description" content="{{ fuelCalculator[locale].meta.description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ fuelCalculator[locale].meta.title }}">
    <meta property="og:description" content="{{ fuelCalculator[locale].meta.description }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ fuelCalculator[locale].meta.title }}">
    <meta name="twitter:description" content="{{ fuelCalculator[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    
    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />
    
    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
      {% if loc == 'ru' %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/logistics/fuel-calculator.html" hreflang="{{ loc }}" />
      {% else %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/logistics/fuel-calculator.html" hreflang="{{ loc }}" />
      {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/logistics/fuel-calculator.html" hreflang="x-default" />      <!-- Structured Data: SoftwareApplication -->     <script type="application/ld+json">     {       "@context": "https://schema.org",       "@type": "SoftwareApplication",       "name": "{{ fuelCalculator[locale].meta.title | replace('"', '&quot;') }}",       "description": "{{ fuelCalculator[locale].meta.description | replace('"', '&quot;') }}",       "url": "{{ canonical }}",       "applicationCategory": "UtilityApplication",       "operatingSystem": "Web",       "inLanguage": "{{ locale }}",       "offers": {         "@type": "Offer",         "price": "0",         "priceCurrency": "RUB"       },       "publisher": {         "@type": "Organization",         "name": "Serpmonn",         "url": "{{ site.baseUrl }}/"       }     }     </script>
    
    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/styles/tools/fuel-calculator.css?v=4">
  </head>
  <body class="fuel-calculator-page" data-currency="₽" data-liter="л">
    <div id="menuContainer"></div>

    <script async src="https://ad.mail.ru/static/ads-async.js"></script>
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag"
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}"
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>

    <h1>{{ fuelCalculator[locale].page.title }}</h1>
    {% if fuelCalculator[locale].page.lead %}
    <p class="tool-lead">{{ fuelCalculator[locale].page.lead }}</p>
    {% endif %}

    <div class="calculator-container">
      <h2>{{ fuelCalculator[locale].page.form.title }}</h2>
      <div id="error-message" class="error-message hidden" role="alert"></div>

      <div class="input-section">
        <div class="input-group">
          <label for="distance">{{ fuelCalculator[locale].page.form.distance }}</label>
          <input type="number" id="distance" placeholder="100" min="1" step="0.1" inputmode="decimal">
        </div>
        <div class="input-group">
          <label for="fuelConsumption">{{ fuelCalculator[locale].page.form.fuelConsumption }}</label>
          <input type="number" id="fuelConsumption" placeholder="8.5" min="1" step="0.1" inputmode="decimal">
        </div>
        <div class="input-group">
          <label for="fuelPrice">{{ fuelCalculator[locale].page.form.fuelPrice }}</label>
          <input type="number" id="fuelPrice" placeholder="55.50" min="1" step="0.01" inputmode="decimal">
        </div>
      </div>

      <div class="action-bar">
        <button type="button" class="calculate-btn" id="btn-calculate">{{ fuelCalculator[locale].page.form.calculate }}</button>
        <details class="more-actions">
          <summary>{{ fuelCalculator[locale].page.actions.more if fuelCalculator[locale].page.actions else 'Ещё' }}</summary>
          <div class="more-actions__list">
            <button type="button" class="reset-btn" id="btn-reset">{{ fuelCalculator[locale].page.actions.reset if fuelCalculator[locale].page.actions else 'Сбросить' }}</button>
            <button type="button" class="share-btn" id="btn-share">{{ fuelCalculator[locale].page.actions.share if fuelCalculator[locale].page.actions else 'Поделиться' }}</button>
            <button type="button" class="export-btn" id="btn-pdf">{{ fuelCalculator[locale].page.actions.pdf if fuelCalculator[locale].page.actions else 'Экспорт PDF' }}</button>
            <button type="button" class="csv-btn" id="btn-csv">{{ fuelCalculator[locale].page.actions.csv if fuelCalculator[locale].page.actions else 'Экспорт CSV' }}</button>
          </div>
        </details>
      </div>

      <details class="optional-fields">
        <summary>{{ fuelCalculator[locale].page.form.optionalSummary if fuelCalculator[locale].page.form.optionalSummary else 'Дополнительно' }}</summary>
        <div class="input-section">
          <div class="input-group">
            <label for="fuelType">{{ fuelCalculator[locale].page.form.fuelType }}</label>
            <select id="fuelType">
              <option value="petrol">{{ fuelCalculator[locale].page.fuelTypes.petrol }}</option>
              <option value="petrol95">{{ fuelCalculator[locale].page.fuelTypes.petrol95 }}</option>
              <option value="petrol98">{{ fuelCalculator[locale].page.fuelTypes.petrol98 }}</option>
              <option value="diesel">{{ fuelCalculator[locale].page.fuelTypes.diesel }}</option>
              <option value="lpg">{{ fuelCalculator[locale].page.fuelTypes.lpg }}</option>
              <option value="cng">{{ fuelCalculator[locale].page.fuelTypes.cng }}</option>
            </select>
          </div>
          <div class="input-group">
            <label for="drivingStyle">{{ fuelCalculator[locale].page.form.drivingStyle }}</label>
            <select id="drivingStyle">
              <option value="economical">{{ fuelCalculator[locale].page.drivingStyles.economical }}</option>
              <option value="normal" selected>{{ fuelCalculator[locale].page.drivingStyles.normal }}</option>
              <option value="sport">{{ fuelCalculator[locale].page.drivingStyles.sport }}</option>
              <option value="aggressive">{{ fuelCalculator[locale].page.drivingStyles.aggressive }}</option>
            </select>
          </div>
          <div class="input-group">
            <label for="roadConditions">{{ fuelCalculator[locale].page.form.roadConditions }}</label>
            <select id="roadConditions">
              <option value="highway">{{ fuelCalculator[locale].page.roadConditions.highway }}</option>
              <option value="city">{{ fuelCalculator[locale].page.roadConditions.city }}</option>
              <option value="mixed" selected>{{ fuelCalculator[locale].page.roadConditions.mixed }}</option>
              <option value="offroad">{{ fuelCalculator[locale].page.roadConditions.offroad }}</option>
            </select>
          </div>
          <div class="input-group">
            <label for="load">{{ fuelCalculator[locale].page.form.load }}</label>
            <select id="load">
              <option value="empty">{{ fuelCalculator[locale].page.loads.empty }}</option>
              <option value="light">{{ fuelCalculator[locale].page.loads.light }}</option>
              <option value="medium">{{ fuelCalculator[locale].page.loads.medium }}</option>
              <option value="heavy">{{ fuelCalculator[locale].page.loads.heavy }}</option>
            </select>
          </div>
          <div class="input-group">
            <label for="climate">{{ fuelCalculator[locale].page.form.climate }}</label>
            <select id="climate">
              <option value="normal">{{ fuelCalculator[locale].page.climates.normal }}</option>
              <option value="hot">{{ fuelCalculator[locale].page.climates.hot }}</option>
              <option value="cold">{{ fuelCalculator[locale].page.climates.cold }}</option>
              <option value="rainy">{{ fuelCalculator[locale].page.climates.rainy }}</option>
            </select>
          </div>
        </div>
      </details>

      <div id="results" class="results hidden">
        <h3>{{ fuelCalculator[locale].page.results.title }}</h3>
        <div class="result-hero">
          <div class="result-value" id="heroCostPerKm">—</div>
          <div class="result-label">{{ fuelCalculator[locale].page.results.costPerKm }}</div>
        </div>
        <p class="result-disclaimer">{{ fuelCalculator[locale].page.disclaimer if fuelCalculator[locale].page.disclaimer else 'Ориентировочный расчёт расхода и стоимости топлива.' }}</p>
        <div class="result-grid">
          <div class="result-item">
            <div class="result-value" id="totalFuel">—</div>
            <div class="result-label">{{ fuelCalculator[locale].page.results.totalFuel }}</div>
          </div>
          <div class="result-item">
            <div class="result-value" id="totalCost">—</div>
            <div class="result-label">{{ fuelCalculator[locale].page.results.totalCost }}</div>
          </div>
          <div class="result-item">
            <div class="result-value" id="costPerKm">—</div>
            <div class="result-label">{{ fuelCalculator[locale].page.results.costPerKm }}</div>
          </div>
          <div class="result-item">
            <div class="result-value" id="adjustedConsumption">—</div>
            <div class="result-label">{{ fuelCalculator[locale].page.results.adjustedConsumption }}</div>
          </div>
        </div>
        <p id="formulaPlain" class="formula-plain"></p>
        <canvas id="fuelChart" style="max-height:280px;margin-top:16px;width:100%;"></canvas>
      </div>
    </div>

    <div id="comparison" class="comparison hidden">
      <h3>{{ fuelCalculator[locale].page.comparison.title }}</h3>
      <table class="comparison-table">
        <thead>
          <tr>
            <th>{{ fuelCalculator[locale].page.comparison.drivingStyle }}</th>
            <th>{{ fuelCalculator[locale].page.comparison.consumption }}</th>
            <th>{{ fuelCalculator[locale].page.comparison.cost }}</th>
            <th>{{ fuelCalculator[locale].page.comparison.savings }}</th>
          </tr>
        </thead>
        <tbody id="comparisonBody"></tbody>
      </table>
    </div>

    <div class="history" id="history">
      <h3>{{ fuelCalculator[locale].page.history.title if fuelCalculator[locale].page.history else 'Недавние расчёты' }}</h3>
      <div id="historyList"></div>
    </div>

    <div class="fuel-efficiency">
      <h3>{{ fuelCalculator[locale].page.fuelEfficiency.title }}</h3>
      {% for tip in fuelCalculator[locale].page.fuelEfficiency.tips %}
      <div class="efficiency-item">{{ tip | safe }}</div>
      {% endfor %}
    </div>

    <div class="tips">
      <h3>{{ fuelCalculator[locale].page.advice.title }}</h3>
      {% for tip in fuelCalculator[locale].page.advice.tips %}
      <div class="tip-item">{{ tip | safe }}</div>
      {% endfor %}
    </div>

    <script>
      window.fuelCalculatorTranslations = {{ fuelCalculator[locale] | dump | safe }};
    </script>
    <script type="module" src="/frontend/scripts/tools/fuel-calculator.js?v=2"></script>
    <script type="module" src="/frontend/scripts/tools/more-actions.js?v=1"></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(fuelCalculator[locale].ads.closeAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
