---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/how-to-calculate-the-eco-footprint-of-products.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/how-to-calculate-the-eco-footprint-of-products.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/how-to-calculate-the-eco-footprint-of-products.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/how-to-calculate-the-eco-footprint-of-products.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% set article = ecoFootprintTranslations[locale] %}

    <title>{{ article.meta.title }}</title>
    <meta name="description" content="{{ article.meta.description }}">
    <meta name="keywords" content="{{ article.meta.keywords }}">

    <meta property="og:title" content="{{ article.meta.og.title }}">
    <meta property="og:description" content="{{ article.meta.og.description }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ article.meta.twitter.title }}">
    <meta name="twitter:description" content="{{ article.meta.twitter.description }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <link rel="canonical" href="{{ canonical }}" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "headline": "{{ article.meta.title | replace('"', '&quot;') }}",
      "description": "{{ article.meta.description | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2025-01-10",
      "dateModified": "2025-06-23",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "author": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>
    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="/frontend/styles/articles/article-chrome.css">
    <link rel="stylesheet" href="/frontend/styles/articles/eco-footprint-guide.css">
  </head>
  <body>
    {% set tocTitle = locale | articleTocTitle %}
    {% set tocItems = [
      { href: '#what-is', label: article.content.whatIs.title },
      { href: '#why-important', label: article.content.whyImportant.title },
      { href: '#how-to-use', label: article.content.howToUse.title },
      { href: '#tips', label: article.content.tips.title },
      { href: '#interpret-results', label: article.content.interpretResults.title },
      { href: '#top-products', label: article.content.topProducts.title },
      { href: '#links', label: article.content.links.title }
    ] %}
    {% include "partials/article-floating-toc.njk" %}

    <nav id="menuContainer" aria-label="{% if locale == 'ru' %}Меню{% elif locale == 'en' %}Menu{% elif locale == 'es' %}Menú{% else %}Menu{% endif %}"></nav>

    <article class="article-container" tabindex="0">
      <header class="article-header">
        <span class="article-category">{{ article.article.category }}</span>
        <div class="ad-top-banner ad-banner loading">
          <ins class="mrg-tag"
              style="display:inline-block;"
              data-ad-client="ad-{{ mailAds.slots.top.id }}"
              data-ad-slot="{{ mailAds.slots.top.id }}">
          </ins>
        </div>
        <h1 class="article-title">{{ article.article.title }}</h1>
        <div class="article-meta">{{ article.article.date }} • {{ article.article.readingTime }}</div>
      </header>

      <div class="article-content">
        <p>{{ article.content.intro }}</p>

        <a href="/frontend/tools/ecology/product-footprint-calculator.html" class="cta-button">{{ article.buttons.calculatorCTA }}</a>

        <h2 id="what-is">{{ article.content.whatIs.title }}</h2>
        <p>{{ article.content.whatIs.description }}</p>
        <ul>
          {% for item in article.content.whatIs.items %}
          <li><strong>{{ item.title }}:</strong> {{ item.description }}</li>
          {% endfor %}
        </ul>

        <h2 id="why-important">{{ article.content.whyImportant.title }}</h2>
        <ul>
          {% for item in article.content.whyImportant.items %}
          <li><strong>{{ item.title }}:</strong> {{ item.description }}</li>
          {% endfor %}
        </ul>

        <div class="highlight-box">
          <h4>{{ article.content.interestingFact.title }}</h4>
          <p>{{ article.content.interestingFact.description }}</p>
        </div>

        <h2 id="how-to-use">{{ article.content.howToUse.title }}</h2>

        <ol class="step-list">
          {% for step in article.content.howToUse.steps %}
          <li>
            <h3>{{ step.title }}</h3>
            <p>{{ step.description }}</p>
          </li>
          {% endfor %}
        </ol>

        <div class="example-box">
          <h4>{{ article.content.example.title }}</h4>
          <p>{{ article.content.example.content | safe }}</p>
        </div>

        <h2 id="tips">{{ article.content.tips.title }}</h2>
        <ul>
          {% for tip in article.content.tips.items %}
          <li><strong>{{ tip.title }}:</strong> {{ tip.description }}</li>
          {% endfor %}
        </ul>

        <div class="warning-box">
          <h4>{{ article.content.limitations.title }}</h4>
          <p>{{ article.content.limitations.description }}</p>
        </div>

        <h2 id="interpret-results">{{ article.content.interpretResults.title }}</h2>
        <ul>
          {% for item in article.content.interpretResults.items %}
          <li><strong>{{ item.range }}:</strong> {{ item.description }}</li>
          {% endfor %}
        </ul>

        <h2 id="top-products">{{ article.content.topProducts.title }}</h2>
        <ol>
          {% for product in article.content.topProducts.items %}
          <li><strong>{{ product.name }}:</strong> {{ product.description }}</li>
          {% endfor %}
        </ol>

        <h2 id="links">{{ article.content.links.title }}</h2>
        <ul>
          {% for link in article.content.links.items %}
          <li><a href="{{ link.url }}">{{ link.text }}</a> — {{ link.description }}</li>
          {% endfor %}
        </ul>

        <div class="highlight-box">
          <h4>{{ article.content.conclusion.title }}</h4>
          <p>{{ article.content.conclusion.description }}</p>
        </div>

        <p>{{ article.content.finalNote }}</p>

        <a href="/frontend/tools/ecology/product-footprint-calculator.html" class="cta-button">{{ article.buttons.finalCTA }}</a>

        {% set relatedTitle = locale | articleRelatedTitle %}
        {% set relatedItems = 'how-to-calculate-the-eco-footprint-of-products' | articleRelated(locale) %}
        {% include "partials/article-related.njk" %}
      </div>

      <div class="social-subscribe">
        <a class="tg-btn" href="https://t.me/serpmonn" target="_blank" rel="noopener">{{ article.buttons.telegram }}</a>
        <a class="vk-btn" href="https://vk.com/serpmonn_site" target="_blank" rel="noopener">{{ article.buttons.vk }}</a>
      </div>
    </article>

    <button type="button" class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="↑">↑</button>

    {% include "partials/article-chrome-scripts.njk" %}
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
    {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
    {{ mobileAnchor(localesNews[locale].news.closeAd) }}
    {% include "partials/ad-pool-init.njk" %}
  </body>
</html>
