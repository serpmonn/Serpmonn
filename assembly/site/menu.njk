---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/menu.html{% else %}/frontend/{{ locale }}/menu.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/menu.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/menu.html{% endif %}"
  menu_home: "{{ menuTranslations[locale].home }}"
  menu_auth: "{{ menuTranslations[locale].auth }}"
  menu_profile: "{{ menuTranslations[locale].profile }}"
  menu_findings_inbox: "{{ menuTranslations[locale].findings_inbox or 'Inbox' }}"
  menu_findings_feed: "{{ menuTranslations[locale].findings_feed or menuTranslations['en'].findings_feed or 'Findings feed' }}"
  menu_findings_activity: "{{ menuTranslations[locale].findings_activity or menuTranslations['en'].findings_activity or 'Activity' }}"
  menu_findings_notifications: "{{ menuTranslations[locale].findings_notifications or menuTranslations['en'].findings_notifications or 'Notifications' }}"
  menu_knowledge_base: "{{ menuTranslations[locale].knowledge_base }}"
  menu_all_knowledge_base: "{{ menuTranslations[locale].all_knowledge_base }}"
  menu_games: "{{ menuTranslations[locale].games }}"
  menu_all_games: "{{ menuTranslations[locale].all_games }}"
  menu_web_games: "{{ menuTranslations[locale].web_games }}"
  menu_mobile_games: "{{ menuTranslations[locale].mobile_games }}"
  menu_pc_games: "{{ menuTranslations[locale].pc_games }}"
  menu_apps: "{{ menuTranslations[locale].apps }}"
  menu_download_app: "{{ menuTranslations[locale].download_app }}"
  menu_mobile_apps: "{{ menuTranslations[locale].mobile_apps }}"
  menu_promo_codes: "{{ menuTranslations[locale].promo_codes }}"
  menu_tools: "{{ menuTranslations[locale].tools }}"
  menu_all_tools: "{{ menuTranslations[locale].all_tools }}"
  menu_marketing: "{{ menuTranslations[locale].marketing }}"
  menu_security: "{{ menuTranslations[locale].security }}"
  menu_development: "{{ menuTranslations[locale].development }}"
  menu_design: "{{ menuTranslations[locale].design }}"
  tool_ai_avatar: "{{ menuTranslations[locale].tool_ai_avatar }}"
  menu_engineering: "{{ menuTranslations[locale].engineering }}"
  menu_logistics: "{{ menuTranslations[locale].logistics }}"
  menu_ecology: "{{ menuTranslations[locale].ecology }}"
  menu_partners: "{{ menuTranslations[locale].partners }}"
  menu_privacy_policy: "{{ menuTranslations[locale].privacy_policy }}"
  menu_ad_info: "{{ menuTranslations[locale].ad_info }}"
  menu_about_project: "{{ menuTranslations[locale].about_project }}"
  menu_what_to_improve: "{{ menuTranslations[locale].what_to_improve }}"
  menu_support_project: "{{ menuTranslations[locale].support_project }}"
  menu_settings: "{{ menuTranslations[locale].settings }}"
  menu_accessibility: "{{ menuTranslations[locale].accessibility }}"
  menu_large_font: "{{ menuTranslations[locale].large_font }}"
  menu_high_contrast: "{{ menuTranslations[locale].high_contrast }}"
  menu_underline_links: "{{ menuTranslations[locale].underline_links }}"
  menu_reduce_animation: "{{ menuTranslations[locale].reduce_animation }}"
  menu_language: "{{ menuTranslations[locale].language }}"
  menu_soon: "{{ menuTranslations[locale].soon }}"
  menu_pwa_install: "{{ menuTranslations[locale].pwa_install }}"
  menu_pwa_instructions: "{{ menuTranslations[locale].pwa_instructions }}"
  menu_pwa_step1: "{{ menuTranslations[locale].pwa_step1 }}"
  menu_pwa_step2: "{{ menuTranslations[locale].pwa_step2 }}"
  menu_pwa_step3: "{{ menuTranslations[locale].pwa_step3 }}"
  menu_pwa_install_btn: "{{ menuTranslations[locale].pwa_install_btn }}"
  menu_pwa_close_btn: "{{ menuTranslations[locale].pwa_close_btn }}"
---

<!-- Стили (общие для всех локалей) -->
<link rel="stylesheet" href="/frontend/styles/accessibility.css">
<link rel="stylesheet" href="/frontend/styles/menu.css">
<link rel="stylesheet" href="/frontend/styles/pwa.css">

<!-- Кнопки меню и активности -->
<div class="menu-corner" id="menuCorner">
  <button type="button" class="menu-activity-bell" id="activityBellBtn" hidden
          aria-label="{{ menu_findings_activity or 'Activity' }}">
    <svg class="menu-activity-bell__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span class="menu-activity-bell__badge" id="activityBellBadge" hidden aria-hidden="true"></span>
  </button>
  <button class="menu-button" id="menuButton" 
        aria-controls="menuContainer"
        aria-haspopup="menu"
        aria-expanded="false">
    <span class="s">S</span><span class="n">n</span>
  </button>
</div>

<!-- Основной контейнер меню -->
<div class="menu-container" id="menuContainer">
    {% from "partials/tool-icons.njk" import toolIcon, webGameIcon %}

    <!-- ========== СЕЛЕКТОР ЯЗЫКА ========== -->
    <div class="menu-item lang-selector-item lang-selector-container" id="languageSelectorContainer">
        {{ toolIcon('lang', 'cat') }}
        <select class="lang-selector" id="langSelect"></select>
    </div>

    <!-- ========== ГЛАВНАЯ ========== -->
    <a href="{% if locale == 'ru' %}/frontend/main.html{% else %}/frontend/{{ locale }}/index.html{% endif %}"
    class="menu-item"
    data-route="home">
        {{ toolIcon('search', 'cat') }}
        {{ menu_home }}
    </a>

    <!-- Вход (гость) — скрывается после проверки сессии -->
    <a href="{% if locale == 'ru' %}/frontend/auth/auth.html{% else %}/frontend/{{ locale }}/auth/auth.html{% endif %}"
       class="menu-item menu-auth-link"
       id="auth-block"
       data-route="auth">
        {{ toolIcon('login', 'cat') }}
        {{ menu_auth }}
    </a>

    <!-- Профиль пользователя (только для авторизованных) -->
    <a href="{% if locale == 'ru' %}/frontend/profile/profile.html{% else %}/frontend/{{ locale }}/profile/profile.html{% endif %}"
       class="menu-item menu-profile-link"
       id="profile-block"
       data-route="profile"
       hidden>
        {{ toolIcon('user', 'cat') }}
        {{ menu_profile }}
    </a>

    <a href="#"
       class="menu-item menu-feed-link"
       id="findings-feed-block"
       data-route="findings-feed"
       data-finding-open-feed="1">
        {{ toolIcon('feed', 'cat') }}
        {{ menu_findings_feed }}
    </a>

    <!-- ========== РАЗДЕЛ ИГР ========== -->
    <a href="#" class="menu-item" data-submenu="gamesSubmenu">
        {{ toolIcon('games', 'cat') }}
        {{ menu_games }}
    </a>

    <!-- Подменю игр -->
    <div class="submenu-container" id="gamesSubmenu">

        <!-- ====== СТРАНИЦА СО ВСЕМИ ИГРАМИ ====== -->
        <a href="{% if locale == 'ru' %}/frontend/games/games.html{% else %}/frontend/{{ locale }}/games/games.html{% endif %}"
        class="menu-item"
        data-route="games-all">
            {{ toolIcon('games', 'cat') }}
            {{ menu_all_games }}
        </a>

        <!-- Подраздел: Веб-игры -->
        <a href="#" class="menu-item" data-submenu="webGamesSubmenu">
            {{ toolIcon('web', 'cat') }}
            {{ menu_web_games }}
        </a>

        <!-- Подменю веб-игр (localesGames — синхрон с games.html) -->
        <div class="submenu-container" id="webGamesSubmenu">
            {% for category in localesGames[locale].games.categories %}
              {% if category.key == 'web' %}
                {% for game in category.games %}
            <a href="{{ game.link }}">
                {{ webGameIcon(game.link) }}
                {{ game.name }}
            </a>
                {% endfor %}
              {% endif %}
            {% endfor %}
        </div>

<a href="#" class="menu-item" data-submenu="androidGamesSubmenu">
            {{ toolIcon('mobile', 'cat') }}
            {{ menu_mobile_games }}
        </a>

<div class="submenu-container" id="androidGamesSubmenu">
            <a href="#" class="game-placeholder">
                {{ toolIcon('mobile') }} Мобильная стратегия ({{ menu_soon }})
            </a>
            <a href="#" class="game-placeholder">
                {{ toolIcon('trophy') }} Аркадная игра ({{ menu_soon }})
            </a>
        </div>

        <!-- Подраздел: ПК-игры -->
        <a href="#" class="menu-item" data-submenu="pcGamesSubmenu">
            {{ toolIcon('pc', 'cat') }}
            {{ menu_pc_games }}
        </a>

        <!-- Подменю ПК-игр -->
        <div class="submenu-container" id="pcGamesSubmenu">
            <a href="https://rzekl.com/g/ky2n1t1o3k7c9ceea34447ed6832c6937d428ecd/?erid=5jtCeReNwxHpfQTFQqS8mWE" target="_blank">
                <img src="/frontend/images/atomic-heart.jpg" alt="Atomic Heart" class="icon"> Atomic Heart
            </a>
            <a href="https://ficca2021.com/g/xv8wkx2q4t7c9ceea3443cb67d624d0197bfefde/?erid=25H8d7vbP8SRTvJ4WQksxm" target="_blank">
                <img src="/frontend/images/lost-ark.png" alt="Lost Ark" class="icon"> Lost Ark
            </a>
            <a href="https://codeaven.com/g/pw3myei9ht7c9ceea344a4713a8ace3ce163585e/?erid=5jtCeReNwxHpfQTGQVAJcnX" target="_blank">
                <img src="/frontend/images/allods-online.png" alt="Аллоды Онлайн" class="icon"> Аллоды Онлайн
            </a>
            <a href="https://xcdus.com/g/c5e9n6r3ew7c9ceea344c5c964748a/?erid=MvGzQC98w3З1gMq1pRgkzi9d" target="_blank">
                <img src="/frontend/images/malinovka.png" alt="Малиновка" class="icon"> Малиновка
            </a>
            <a href="https://xmknb.com/g/ilvfzhs26x7c9ceea34461e800f2bd/?erid=2bL9aMPo2e49hMef4piV5BfNfR" target="_blank">
                <img src="/frontend/images/evolve-rp.png" alt="Evolve RP" class="icon"> Evolve RP
            </a>
            <a href="https://rzekl.com/g/txwwmat2wx7c9ceea344c065b8a873/?erid=2bL9aMPo2e49hMef4pfym3SuLK" target="_blank">
                <img src="/frontend/images/amazing-online.jpg" alt="AMAZING ONLINE" class="icon"> AMAZING ONLINE
            </a>
            <a href="https://zmgig.com/g/yog728vijm7c9ceea344f0d389d68d/?erid=MvGzQC98w3З1gMq1oSV73txX" target="_blank">
                <img src="/frontend/images/nextrp.png" alt="NEXTRP" class="icon"> NEXTRP
            </a>
            <a href="https://tywhh.com/g/q10rxle26a7c9ceea34443269ad76debd4fd1b95/?erid=2bL9aMPo2e49hMef4piUr6ZhiU" target="_blank">
                <img src="/frontend/images/gta5rp.webp" alt="GTA5RP" class="icon"> GTA5RP
            </a>
            <a href="https://twnfz.com/g/f15f0db8437c9ceea344d8792ef979/?erid=5jtCeReLm1S3Xx3Lf3au61G" target="_blank">
                <img src="/frontend/images/lineage-2.png" alt="Lineage 2" class="icon"> Lineage 2
            </a>
            <a href="https://rzekl.com/g/7lgnbu225t7c9ceea3444cb8738d24/?erid=MvGzQC98w3З1gMq1oSV73uLi" target="_blank">
                <img src="/frontend/images/lineage-2-essence.png" alt="Lineage 2 Essence" class="icon"> Lineage 2 Essence
            </a>
            <a href="https://dhwnh.com/g/4z1liq0shk7c9ceea34426d3115512/?erid=2bL9aMPo2e49hMef4pfzSMbrkc" target="_blank">
                <img src="/frontend/images/lineage-2-legacy.png" alt="Lineage 2 Legacy" class="icon"> Lineage 2 Legacy
            </a>
            <a href="https://rzekl.com/g/fy90i94aoa7c9ceea3443fcec4d4a3/?erid=MvGzQC98w3З1gMq1oS2xNYhq" target="_blank">
                <img src="/frontend/images/black-desert.png" alt="Black Desert" class="icon"> Black Desert
            </a>
            <a href="https://dorinebeaumont.com/g/jmyq21wgw87c9ceea344a78ad6f5e61bedefe48e/?erid=5jtCeReNwxHpfQTEujFRZrz" target="_blank">
                <img src="/frontend/images/warface.png" alt="Warface" class="icon"> Warface
            </a>
        </div>
    </div>

    <!-- ========== РАЗДЕЛ ПРИЛОЖЕНИЙ ========== -->
    <a href="#" class="menu-item" data-submenu="appsSubmenu">
        {{ toolIcon('apps', 'cat') }}
        {{ menu_apps }}
    </a>

    <!-- Подменю приложений -->
    <div class="submenu-container" id="appsSubmenu">
        <!-- Кнопка установки PWA -->
        <a href="#" class="menu-item" id="installAppButton">
            <img src="/frontend/images/serpmonn.ico?v=3" alt="{{ menu_download_app }}" class="icon">
            {{ menu_download_app }}
        </a>

<a href="#" class="menu-item" data-submenu="mobileAppsSubmenu">
            {{ toolIcon('mobile', 'cat') }}
            {{ menu_mobile_apps }}
        </a>
        <div class="submenu-container" id="mobileAppsSubmenu">
            <a href="/frontend/downloads/Serpmonn_beta.apk" download="Serpmonn_beta.apk" class="menu-item">
                <img src="/frontend/images/serpmonn.ico?v=3" alt="Serpmonn Beta" class="icon">
                Serpmonn Beta (TWA)
            </a>
            <a href="https://serpmonn.ru/frontend/messenger.html" class="menu-item">
                <img src="/frontend/images/serpmonn.ico?v=3" alt="Serpmonn Messenger" class="icon">
                Serpmonn Messenger
            </a>
        </div>
    </div>

    <!-- ========== ПРОМОКОДЫ И СКИДКИ ========== -->
    <a href="{% if locale == 'ru' %}/frontend/promo-codes-and-discounts/promokody-skidki.html{% else %}/frontend/{{ locale }}/promo-codes-and-discounts/promokody-skidki.html{% endif %}"
    class="menu-item"
    id="promo-codes-btn"
    data-route="promo">
        {{ toolIcon('promo', 'cat') }}
        {{ menu_promo_codes }}
    </a>

    <!-- ========== РАЗДЕЛ ИНСТРУМЕНТОВ ========== -->
    <a href="#" class="menu-item" data-submenu="toolsSubmenu">
        {{ toolIcon('all', 'cat') }}
        {{ menu_tools }}
    </a>

    <!-- Подменю инструментов -->
    <div class="submenu-container" id="toolsSubmenu">

        <!-- ====== СТРАНИЦА СО ВСЕМИ ИНСТРУМЕНТАМИ ====== -->
        <a href="{% if locale == 'ru' %}/frontend/tools/tools.html{% else %}/frontend/{{ locale }}/tools/tools.html{% endif %}"
        class="menu-item"
        data-route="tools-all">
            {{ toolIcon('all', 'cat') }} {{ menu_all_tools }}
        </a>
        
        <!-- Маркетинг -->
        <a href="#" class="menu-item" data-submenu="marketingToolsSubmenu">
            {{ toolIcon('marketing', 'cat') }} {{ menu_marketing }}
        </a>
        <div class="submenu-container" id="marketingToolsSubmenu">
            <a href="{% if locale == 'ru' %}/frontend/tools/marketing/utm-builder.html{% else %}/frontend/{{ locale }}/tools/marketing/utm-builder.html{% endif %}">
                {{ toolIcon('link') }} Генератор UTM‑меток
            </a>
            <a href="{% if locale == 'ru' %}/frontend/tools/marketing/word-counter.html{% else %}/frontend/{{ locale }}/tools/marketing/word-counter.html{% endif %}">
                {{ toolIcon('text') }} Счётчик слов/символов
            </a>
        </div>
        
        <!-- Безопасность -->
        <a href="#" class="menu-item" data-submenu="securityToolsSubmenu">
            {{ toolIcon('security', 'cat') }} {{ menu_security }}
        </a>
        <div class="submenu-container" id="securityToolsSubmenu">
            <a href="{% if locale == 'ru' %}/frontend/tools/security/password-generator.html{% else %}/frontend/{{ locale }}/tools/security/password-generator.html{% endif %}">
                {{ toolIcon('key') }} Генератор паролей
            </a>
        </div>
        
        <!-- Разработка -->
        <a href="#" class="menu-item" data-submenu="devToolsSubmenu">
            {{ toolIcon('code', 'cat') }} {{ menu_development }}
        </a>
        <div class="submenu-container" id="devToolsSubmenu">
            <a href="{% if locale == 'ru' %}/frontend/tools/development/json-formatter.html{% else %}/frontend/{{ locale }}/tools/development/json-formatter.html{% endif %}">
                {{ toolIcon('json') }} JSON форматтер
            </a>
            <a href="{% if locale == 'ru' %}/frontend/tools/development/base64-converter.html{% else %}/frontend/{{ locale }}/tools/development/base64-converter.html{% endif %}">
                {{ toolIcon('convert') }} Base64 конвертер
            </a>
        </div>
        
        <!-- Дизайн -->
        <a href="#" class="menu-item" data-submenu="designToolsSubmenu">
            {{ toolIcon('design', 'cat') }} {{ menu_design }}
        </a>
        <div class="submenu-container" id="designToolsSubmenu">
            <a href="https://lsuix.com/g/1j6fe2t8jz7c9ceea34457480734a9/?erid=2bL9aMPo2e49hMef4rqxsMZZ36"
               class="tool-link" target="_blank" rel="noopener noreferrer">
                {{ toolIcon('user') }} {{ tool_ai_avatar }}
            </a>
            <a href="{% if locale == 'ru' %}/frontend/tools/design/color-palettes.html{% else %}/frontend/{{ locale }}/tools/design/color-palettes.html{% endif %}">
                {{ toolIcon('palette') }} Цветовые палитры
            </a>
            <a href="{% if locale == 'ru' %}/frontend/tools/design/format-converter.html{% else %}/frontend/{{ locale }}/tools/design/format-converter.html{% endif %}">
                {{ toolIcon('image') }} Конвертер форматов
            </a>
        </div>
        
        <!-- Инженерия -->
        <a href="#" class="menu-item" data-submenu="engineeringToolsSubmenu">
            {{ toolIcon('engineering', 'cat') }} {{ menu_engineering }}
        </a>
        <div class="submenu-container" id="engineeringToolsSubmenu">
            <a href="{% if locale == 'ru' %}/frontend/tools/engineering/unit-converter.html{% else %}/frontend/{{ locale }}/tools/engineering/unit-converter.html{% endif %}">
                {{ toolIcon('ruler') }} Конвертер единиц
            </a>
        </div>
        
        <!-- Логистика -->
        <a href="#" class="menu-item" data-submenu="logisticsToolsSubmenu">
            {{ toolIcon('truck', 'cat') }} {{ menu_logistics }}
        </a>
        <div class="submenu-container" id="logisticsToolsSubmenu">
            <a href="{% if locale == 'ru' %}/frontend/tools/logistics/depreciation-calculator.html{% else %}/frontend/{{ locale }}/tools/logistics/depreciation-calculator.html{% endif %}">
                {{ toolIcon('car') }} Калькулятор амортизации
            </a>
            <a href="{% if locale == 'ru' %}/frontend/tools/logistics/fuel-calculator.html{% else %}/frontend/{{ locale }}/tools/logistics/fuel-calculator.html{% endif %}">
                {{ toolIcon('fuel') }} Калькулятор топлива
            </a>
        </div>
        
        <!-- Экология -->
        <a href="#" class="menu-item" data-submenu="ecologyToolsSubmenu">
            {{ toolIcon('leaf', 'cat') }} {{ menu_ecology }}
        </a>
        <div class="submenu-container" id="ecologyToolsSubmenu">
            <a href="{% if locale == 'ru' %}/frontend/tools/ecology/product-footprint-calculator.html{% else %}/frontend/{{ locale }}/tools/ecology/product-footprint-calculator.html{% endif %}">
                {{ toolIcon('globe') }} Экологический след продуктов
            </a>
        </div>
    </div>

    <!-- ========== БАЗА ЗНАНИЙ ========== -->
    <a href="#" class="menu-item" data-submenu="knowledgeSubmenu">
        {{ toolIcon('books', 'cat') }}
        {{ menu_knowledge_base }}
    </a>

    <div class="submenu-container" id="knowledgeSubmenu">
        <a href="{% if locale == 'ru' %}/frontend/knowledge-base/knowledge-base.html{% else %}/frontend/{{ locale }}/knowledge-base/knowledge-base.html{% endif %}"
           class="menu-item"
           data-route="knowledge">
            {{ toolIcon('books', 'cat') }} {{ menu_all_knowledge_base }}
        </a>

        {%- set kbArticles = localesNews[locale].news.articles -%}
        {%- set kbCategories = localesNews[locale].news.categories -%}

        {%- for cat in kbCategories -%}
          {%- if cat.key == 'articles' -%}
        <a href="#" class="menu-item" data-submenu="kbArticlesSubmenu">
            {{ toolIcon('news', 'cat') }} {{ cat.name }}
        </a>
        <div class="submenu-container" id="kbArticlesSubmenu">
            {%- for article in kbArticles -%}
              {%- if article.category == 'articles' -%}
            <a href="{{ article.link }}">{{ toolIcon('file') }} {{ article.title }}</a>
              {%- endif -%}
            {%- endfor -%}
        </div>
          {%- elif cat.key == 'tutorials' -%}
        <a href="#" class="menu-item" data-submenu="kbTutorialsSubmenu">
            {{ toolIcon('graduation', 'cat') }} {{ cat.name }}
        </a>
        <div class="submenu-container" id="kbTutorialsSubmenu">
            {%- for article in kbArticles -%}
              {%- if article.category == 'tutorials' -%}
            <a href="{{ article.link }}">{{ toolIcon('file') }} {{ article.title }}</a>
              {%- endif -%}
            {%- endfor -%}
        </div>
          {%- elif cat.key == 'engineering' -%}
        <a href="#" class="menu-item" data-submenu="kbEngineeringSubmenu">
            {{ toolIcon('engineering', 'cat') }} {{ cat.name }}
        </a>
        <div class="submenu-container" id="kbEngineeringSubmenu">
            {%- for article in kbArticles -%}
              {%- if article.category == 'engineering' -%}
            <a href="{{ article.link }}">{{ toolIcon('file') }} {{ article.title }}</a>
              {%- endif -%}
            {%- endfor -%}
        </div>
          {%- elif cat.key == 'ecology' -%}
        <a href="#" class="menu-item" data-submenu="kbEcologySubmenu">
            {{ toolIcon('leaf', 'cat') }} {{ cat.name }}
        </a>
        <div class="submenu-container" id="kbEcologySubmenu">
            {%- for article in kbArticles -%}
              {%- if article.category == 'ecology' -%}
            <a href="{{ article.link }}">{{ toolIcon('file') }} {{ article.title }}</a>
              {%- endif -%}
            {%- endfor -%}
        </div>
          {%- elif cat.key == 'updates' -%}
        <a href="#" class="menu-item" data-submenu="kbUpdatesSubmenu">
            {{ toolIcon('rocket', 'cat') }} {{ cat.name }}
        </a>
        <div class="submenu-container" id="kbUpdatesSubmenu">
            {%- for article in kbArticles -%}
              {%- if article.category == 'updates' -%}
            <a href="{{ article.link }}">{{ toolIcon('file') }} {{ article.title }}</a>
              {%- endif -%}
            {%- endfor -%}
        </div>
          {%- elif cat.key == 'logistics' -%}
            {# Категория есть в фильтре KB, статей пока нет — пункт скрыт #}
          {%- endif -%}
        {%- endfor -%}
