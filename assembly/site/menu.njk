<!-- Стили (общие для всех локалей) -->
<link rel="stylesheet" href="/frontend/styles/accessibility.css">
<link rel="stylesheet" href="/frontend/styles/menu.css">
<link rel="stylesheet" href="/frontend/styles/pwa.css">

<!-- Кнопки меню и активности -->
<div class="menu-corner" id="menuCorner">
  <button type="button" class="menu-activity-bell" id="activityBellBtn" hidden
          aria-label="{{ menu_findings_activity or 'Activity' }}">
    <svg class="menu-activity-bell__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span class="menu-activity-bell__badge" id="activityBellBadge" hidden aria-hidden="true"></span>
  </button>
  <button class="menu-button" id="menuButton" 
        aria-controls="menuContainer"
        aria-haspopup="menu"
        aria-expanded="false">
    <span class="s">S</span><span class="n">n</span>
  </button>
</div>

<!-- Основной контейнер меню -->
<div class="menu-container" id="menuContainer">

    <!-- ========== СЕЛЕКТОР ЯЗЫКА ========== -->
