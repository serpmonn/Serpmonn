---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/web-development-guide.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/web-development-guide.html{% endif %}"
eleventyComputed:
  title: "{{ webDevelopmentGuide[locale].meta.title }}"
  description: "{{ webDevelopmentGuide[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/web-development-guide.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/web-development-guide.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ description }}">
    <title>{{ title }}</title>
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ webDevelopmentGuide[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ webDevelopmentGuide[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ webDevelopmentGuide[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ webDevelopmentGuide[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

<!-- Structured Data: Article -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "headline": "{{ webDevelopmentGuide[locale].meta.ogTitle | replace('"', '&quot;') }}",
      "description": "{{ webDevelopmentGuide[locale].meta.ogDescription | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2024-08-18",
      "dateModified": "2025-06-23",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "author": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
    {% if loc == 'ru' %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/web-development-guide.html" hreflang="{{ loc }}" />
    {% else %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/knowledge-base/articles/web-development-guide.html" hreflang="{{ loc }}" />
    {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/web-development-guide.html" hreflang="x-default" />

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css">
    <link rel="stylesheet" href="/frontend/styles/articles/article-chrome.css">
    <link rel="stylesheet" href="/frontend/styles/articles/web-development-guide.css">
</head>
<body>
    {% set tocTitle = webDevelopmentGuide[locale].article.sections.toc.title %}
    {% set tocItems = [] %}
    {% for item in webDevelopmentGuide[locale].article.sections.toc.items %}
    {% set tocItems = (tocItems.push({ href: '#section-' ~ item.anchor, label: item.text }), tocItems) %}
    {% endfor %}
    {% include "partials/article-floating-toc.njk" %}

    <div id="menuContainer"></div>
    {% from "partials/tool-icons.njk" import toolIcon %}
    <article class="article-container" tabindex="0">
        <header class="article-header">
            <span class="article-category">{{ webDevelopmentGuide[locale].article.category }}</span>
            <div class="ad-top-banner ad-banner loading">
                <ins class="mrg-tag" style="display:inline-block;" data-ad-client="ad-{{ mailAds.slots.top.id }}" data-ad-slot="{{ mailAds.slots.top.id }}"></ins>
            </div>
            <h1 class="article-title">{{ webDevelopmentGuide[locale].article.title }}</h1>
            <div class="article-meta">{{ webDevelopmentGuide[locale].article.date }} • {{ webDevelopmentGuide[locale].article.readTime }}</div>
        </header>

        <div class="article-content">
            <p>{{ webDevelopmentGuide[locale].article.intro }}</p>

            <h2 id="section-goals">{{ webDevelopmentGuide[locale].article.sections.goals.title }}</h2>
            <ul>
                {% for item in webDevelopmentGuide[locale].article.sections.goals.items %}
                <li>{{ item }}</li>
                {% endfor %}
            </ul>

            <h2 id="section-tools">{{ webDevelopmentGuide[locale].article.sections.tools.title }}</h2>
            <div class="tech-grid">
                {% for card in webDevelopmentGuide[locale].article.sections.tools.techCards %}
                <div class="tech-card">
                    {{ toolIcon(card.icon, 'cat') }}
                    <h4>{{ card.title }}</h4>
                    <p>{{ card.description }}</p>
                </div>
                {% endfor %}
            </div>

            <h2 id="section-guide">{{ webDevelopmentGuide[locale].article.sections.guide.title }}</h2>
            
            <div class="visual-guide">
                {% for visual in webDevelopmentGuide[locale].article.sections.guide.visuals %}
                <div class="visual-item">
                    {{ toolIcon(visual.icon, 'cat') }}
                    <h3>{{ visual.title }}</h3>
                    <p>{{ visual.description }}</p>
                </div>
                {% endfor %}
            </div>
            
            <ol class="step-list">
                {% for step in webDevelopmentGuide[locale].article.sections.guide.steps %}
                <li>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.description }}</p>
                    
                    {% if step.codeExample %}
                    <div class="code-example">
                        <h4>{{ step.codeExample.title }}</h4>
                        <pre><code class="language-{{ step.codeExample.language }}">{{ step.codeExample.code }}</code></pre>
                    </div>
                    {% endif %}
                    
                    {% if step.interactiveEditor %}
                    <div class="interactive-editor {{ step.interactiveEditor.type }}-editor">
                        <div class="editor-toolbar">
                            <span>{{ step.interactiveEditor.toolbar }}</span>
                            <button class="run-button" onclick="runCode(this)">{{ step.interactiveEditor.runButton }}</button>
                        </div>
                        <div class="editor-content">
                            <div class="code-area">
                                <textarea class="code-textarea">{{ step.interactiveEditor.defaultCode }}</textarea>
                            </div>
                            <div class="preview-area">{{ step.interactiveEditor.previewContent | safe }}</div>
                        </div>
                    </div>
                    {% endif %}
                </li>
                {% endfor %}
            </ol>

            <div class="highlight-box">
                <h4>{{ webDevelopmentGuide[locale].article.sections.tips.title }}</h4>
                <p>{{ webDevelopmentGuide[locale].article.sections.tips.content }}</p>
            </div>

            <h2 id="section-modern-tools">{{ webDevelopmentGuide[locale].article.sections.modernTools.title }}</h2>
            <p>{{ webDevelopmentGuide[locale].article.sections.modernTools.intro }}</p>
            <ul>
                {% for tool in webDevelopmentGuide[locale].article.sections.modernTools.list %}
                <li><strong>{{ tool.name }}:</strong> {{ tool.description }}</li>
                {% endfor %}
            </ul>

            <div class="warning-box">
                <h4>{{ webDevelopmentGuide[locale].article.sections.warning.title }}</h4>
                <p>{{ webDevelopmentGuide[locale].article.sections.warning.content }}</p>
            </div>

            <h2 id="section-faq">{{ webDevelopmentGuide[locale].article.sections.faq.title }}</h2>
            
            {% for faq in webDevelopmentGuide[locale].article.sections.faq.items %}
            <details class="faq-item">
                <summary>{{ faq.question }}</summary>
                <p>{{ faq.answer }}</p>
            </details>
            {% endfor %}

            <h3>{{ webDevelopmentGuide[locale].article.sections.checklist.title }}</h3>
            <ul class="checklist">
                {% for item in webDevelopmentGuide[locale].article.sections.checklist.items %}
                <li>
                    <input type="checkbox" id="check{{ loop.index }}">
                    <label for="check{{ loop.index }}">{{ item }}</label>
                </li>
                {% endfor %}
            </ul>

            <h2 id="section-resources">{{ webDevelopmentGuide[locale].article.sections.resources.title }}</h2>
            <ul>
                {% for resource in webDevelopmentGuide[locale].article.sections.resources.links %}
                <li><a href="{{ resource.url }}" target="_blank" rel="noopener">{{ resource.name }}</a> — {{ resource.description }}</li>
                {% endfor %}
            </ul>

            <p>{{ webDevelopmentGuide[locale].article.sections.conclusion }}</p>

            {% set relatedTitle = locale | articleRelatedTitle %}
            {% set relatedItems = 'web-development-guide' | articleRelated(locale) %}
            {% include "partials/article-related.njk" %}

            <div class="share-buttons">
                <h3>{{ webDevelopmentGuide[locale].article.sections.share.title }}</h3>
                <button type="button" onclick="serpmonnShare('telegram')" aria-label="{{ webDevelopmentGuide[locale].article.sections.share.telegramAria }}">{{ webDevelopmentGuide[locale].article.sections.share.telegram }}</button>
                <button type="button" onclick="serpmonnShare('vk')" aria-label="{{ webDevelopmentGuide[locale].article.sections.share.vkAria }}">{{ webDevelopmentGuide[locale].article.sections.share.vk }}</button>
            </div>
        </div>

        <div class="social-subscribe">
            <a class="tg-btn" href="{{ webDevelopmentGuide[locale].article.social.telegram.url }}" target="_blank" rel="noopener" aria-label="{{ webDevelopmentGuide[locale].article.social.telegram.aria }}">{{ webDevelopmentGuide[locale].article.social.telegram.text }}</a>
            <a class="vk-btn" href="{{ webDevelopmentGuide[locale].article.social.vk.url }}" target="_blank" rel="noopener" aria-label="{{ webDevelopmentGuide[locale].article.social.vk.aria }}">{{ webDevelopmentGuide[locale].article.social.vk.text }}</a>
        </div>
    </article>

    <button class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="{{ webDevelopmentGuide[locale].article.buttons.scrollTopAria }}">{{ webDevelopmentGuide[locale].article.buttons.scrollTop }}</button>

    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    {% include "partials/article-chrome-scripts.njk" %}
    <script>
        const localeTexts = {
            error: "Error"
        };

        function runCode(button) {
            const editor = button.closest('.interactive-editor');
            const codeArea = editor.querySelector('.code-textarea');
            const previewArea = editor.querySelector('.preview-area');

            try {
                if (editor.classList.contains('html-editor')) {
                    previewArea.replaceChildren();
                    const frame = document.createElement('iframe');
                    frame.setAttribute('sandbox', '');
                    frame.style.width = '100%';
                    frame.style.minHeight = '200px';
                    frame.style.border = '0';
                    frame.srcdoc = codeArea.value;
                    previewArea.appendChild(frame);
                } else if (editor.classList.contains('css-editor')) {
                    const styleTag = document.createElement('style');
                    styleTag.textContent = codeArea.value;
                    previewArea.replaceChildren();
                    const sample = document.createElement('div');
                    sample.innerHTML = '<h1>Пример заголовка</h1><p>Пример текста для стилизации с помощью CSS</p>';
                    previewArea.appendChild(sample);
                    previewArea.appendChild(styleTag);
                }
            } catch (error) {
                previewArea.textContent = `${localeTexts.error}: ${error.message}`;
            }
        }
    </script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(webDevelopmentGuide[locale].article.buttons.closeAdAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
