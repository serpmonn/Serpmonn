---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/games/flappy/flappy.html{% else %}/frontend/{{ locale }}/games/flappy/flappy.html{% endif %}"
eleventyComputed:
  title: "{{ gameFlappyTranslations[locale].gameFlappy.pageTitle }}"
  description: "{{ gameFlappyTranslations[locale].gameFlappy.metaDescription }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/games/flappy/flappy.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/games/flappy/flappy.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Language" content="{{ locale }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:title" content="{{ gameFlappyTranslations[locale].gameFlappy.ogTitle }}">
  <meta property="og:description" content="{{ gameFlappyTranslations[locale].gameFlappy.ogDescription }}">
  <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/flappy.png">

  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ canonical }}">
  <meta property="twitter:title" content="{{ gameFlappyTranslations[locale].gameFlappy.ogTitle }}">
  <meta property="twitter:description" content="{{ gameFlappyTranslations[locale].gameFlappy.twitterDescription }}">
  <meta property="twitter:image" content="{{ site.baseUrl }}/frontend/images/flappy.png">

  <link rel="canonical" href="{{ canonical }}">
  <link rel="icon" href="/frontend/images/flappy.png" type="image/x-icon">

  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/base.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/menu.css">
  <link rel="stylesheet" href="/frontend/games/flappy/flappy.css">

  <script async src="https://ad.mail.ru/static/ads-async.js"></script>
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
  <div id="menuContainer"></div>

  <script>
    window.i18n = {
      welcomeTitle: {{ gameFlappyTranslations[locale].gameFlappy.welcomeTitle | dump | safe }},
      welcomeLine1: {{ gameFlappyTranslations[locale].gameFlappy.welcomeLine1 | dump | safe }},
      welcomeLine2: {{ gameFlappyTranslations[locale].gameFlappy.welcomeLine2 | dump | safe }},
      welcomeLine3: {{ gameFlappyTranslations[locale].gameFlappy.welcomeLine3 | dump | safe }},
      yourBest: {{ gameFlappyTranslations[locale].gameFlappy.yourBest | dump | safe }},
      gameOver: {{ gameFlappyTranslations[locale].gameFlappy.gameOver | dump | safe }},
      yourScore: {{ gameFlappyTranslations[locale].gameFlappy.yourScore | dump | safe }},
      newRecord: {{ gameFlappyTranslations[locale].gameFlappy.newRecord | dump | safe }},
      restartLine1: {{ gameFlappyTranslations[locale].gameFlappy.restartLine1 | dump | safe }},
      restartLine2: {{ gameFlappyTranslations[locale].gameFlappy.restartLine2 | dump | safe }},
      restartLine3: {{ gameFlappyTranslations[locale].gameFlappy.restartLine3 | dump | safe }},
      howToTitle: {{ gameFlappyTranslations[locale].gameFlappy.howToTitle | dump | safe }},
      instructionsMobileHtml: {{ gameFlappyTranslations[locale].gameFlappy.instructionsMobileHtml | dump | safe }},
      instructionsDesktopHtml: {{ gameFlappyTranslations[locale].gameFlappy.instructionsDesktopHtml | dump | safe }},
      startPlaying: {{ gameFlappyTranslations[locale].gameFlappy.startPlaying | dump | safe }},
      dontShowAgain: {{ gameFlappyTranslations[locale].gameFlappy.dontShowAgain | dump | safe }},
      adTitle: {{ gameFlappyTranslations[locale].gameFlappy.adTitle | dump | safe }},
      continueAd: {{ gameFlappyTranslations[locale].gameFlappy.continueAd | dump | safe }},
      recordNotificationHtml: {{ gameFlappyTranslations[locale].gameFlappy.recordNotificationHtml | dump | safe }},
      motivationalMessages: {{ gameFlappyTranslations[locale].gameFlappy.motivationalMessages | dump | safe }}
    };
  </script>
  <script src="/frontend/games/flappy/flappy-ads.js?v=2" defer></script>

  <script>
  (function(){
    function isMobile(){
      return /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (window.innerWidth < 768);
    }
    function showCenteredInstructions(){
      try{
        if (localStorage.getItem('game_instructions_flappy_shown') === '1') return;

        var overlay = document.createElement('div');
        overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);display:flex;align-items:center;justify-content:center;z-index:10000;font-family:system-ui,-apple-system,sans-serif;';

        var box = document.createElement('div');
        box.style.cssText = 'background:#1a2230;border:2px solid #2ecc71;border-radius:16px;padding:24px;text-align:center;max-width:320px;width:90%;color:#fff;';

        var title = document.createElement('div');
        title.textContent = window.i18n.howToTitle;
        title.style.cssText = 'font-weight:bold;margin-bottom:16px;color:#f1c40f;font-size:18px;';

        var text = document.createElement('div');
        text.style.cssText = 'font-size:14px;line-height:1.6;margin-bottom:20px;text-align:left;';
        text.innerHTML = isMobile() ? window.i18n.instructionsMobileHtml : window.i18n.instructionsDesktopHtml;

        var closeBtn = document.createElement('button');
        closeBtn.textContent = window.i18n.startPlaying;
        closeBtn.style.cssText = 'background:#2ecc71;border:none;color:#fff;padding:10px 20px;border-radius:20px;cursor:pointer;font-size:14px;font-weight:bold;margin-bottom:12px;';

        var checkboxLabel = document.createElement('label');
        checkboxLabel.style.cssText = 'display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;';
        var checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.style.marginRight = '8px';
        checkboxLabel.appendChild(checkbox);
        checkboxLabel.appendChild(document.createTextNode(window.i18n.dontShowAgain));

        closeBtn.onclick = function(){
          if (checkbox.checked) localStorage.setItem('game_instructions_flappy_shown','1');
          overlay.remove();
        };

        box.appendChild(title);
        box.appendChild(text);
        box.appendChild(closeBtn);
        box.appendChild(checkboxLabel);
        overlay.appendChild(box);
        document.body.appendChild(overlay);
      }catch(e){}
    }
    document.addEventListener('DOMContentLoaded', showCenteredInstructions);
  })();
  </script>

  <div class="page">
    <header>
      <img src="/frontend/images/flappy.png" width="28" height="28" alt="{{ gameFlappyTranslations[locale].gameFlappy.gamesAlt }}" style="border-radius:6px;">
      <h1>{{ gameFlappyTranslations[locale].gameFlappy.mainTitle }}</h1>
    </header>

    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag" style="display:inline-block;" data-ad-client="ad-1897960" data-ad-slot="1897960"></ins>
    </div>
    <script>(window.MRGtag = window.MRGtag || []).push({});</script>

    <div class="wrap">
      <div class="panel">
        <canvas id="game" width="480" height="640" aria-label="{{ gameFlappyTranslations[locale].gameFlappy.canvasAria }}"></canvas>
        <div class="hint" style="display:none;">{{ gameFlappyTranslations[locale].gameFlappy.hint }}</div>
      </div>

      <div class="panel">
        <div class="stats">
          <div class="stat">{{ gameFlappyTranslations[locale].gameFlappy.scoreLabel }}<br><b id="score">0</b></div>
          <div class="stat">{{ gameFlappyTranslations[locale].gameFlappy.bestLabel }}<br><b id="best">0</b></div>
        </div>

        <div class="controls">
          <button class="btn primary" id="btnStart">{{ gameFlappyTranslations[locale].gameFlappy.btnStart }}</button>
          <button class="btn" id="btnReset">{{ gameFlappyTranslations[locale].gameFlappy.btnReset }}</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/frontend/games/flappy/flappy.js?v=2" defer></script>
  <script src="/frontend/games/flappy/flappy-notifications.js?v=2" defer></script>
  <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
