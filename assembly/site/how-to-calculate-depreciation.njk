---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/how-to-calculate-depreciation.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/how-to-calculate-depreciation.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/how-to-calculate-depreciation.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/how-to-calculate-depreciation.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% set article = howToCalculateDepreciation[locale] or howToCalculateDepreciation['ru'] %}

    <title>{{ article.pageTitle }}</title>
    <meta name="description" content="{{ article.metaDescription }}">

    <meta property="og:title" content="{{ article.ogTitle }}">
    <meta property="og:description" content="{{ article.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ article.twitterTitle }}">
    <meta name="twitter:description" content="{{ article.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <link rel="canonical" href="{{ canonical }}" />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "headline": "{{ article.pageTitle | replace('"', '&quot;') }}",
      "description": "{{ article.metaDescription | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2025-01-10",
      "dateModified": "2026-07-16",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "author": {
        "@type": "Organization",
        "name": "Serpmonn"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Serpmonn",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>
    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="/frontend/styles/articles/article-chrome.css">
    <link rel="stylesheet" href="/frontend/styles/articles/depreciation-guide.css">
  </head>
  <body>
    {% set tocTitle = locale | articleTocTitle %}
    {% set tocItems = [
      { href: '#what-is', label: article.whatIsTitle },
      { href: '#factors', label: article.factorsTitle },
      { href: '#calculator', label: article.calculatorTitle }
    ] %}
    {% if article.formulaTitle %}{% set _ = tocItems.push({ href: '#formula', label: article.formulaTitle }) %}{% endif %}
    {% if article.kmExample %}{% set _ = tocItems.push({ href: '#km-example', label: article.kmExampleTitle }) %}{% endif %}
    {% set _ = tocItems.push({ href: '#tips', label: article.tipsTitle }) %}
    {% set _ = tocItems.push({ href: '#accuracy', label: article.accuracyTitle }) %}
    {% set _ = tocItems.push({ href: '#recalc', label: article.recalcTitle }) %}
    {% if article.faq %}{% set _ = tocItems.push({ href: '#faq', label: article.faqTitle }) %}{% endif %}
    {% set _ = tocItems.push({ href: '#links', label: article.linksTitle }) %}
    {% include "partials/article-floating-toc.njk" %}

    <nav id="menuContainer" aria-label="{% if locale == 'ru' %}Меню{% elif locale == 'en' %}Menu{% elif locale == 'ar' or locale == 'he' or locale == 'ug' or locale == 'fa' %}القائمة{% else %}Menu{% endif %}"></nav>

    <article class="article-container" tabindex="0">
      <header class="article-header">
        <span class="article-category">{{ article.articleCategory }}</span>
        <div class="ad-top-banner ad-banner loading">
          <ins class="mrg-tag"
              style="display:inline-block;"
              data-ad-client="ad-{{ mailAds.slots.top.id }}"
              data-ad-slot="{{ mailAds.slots.top.id }}">
          </ins>
        </div>
        <h1 class="article-title">{{ article.articleTitle }}</h1>
        <div class="article-meta">{{ article.articleMeta }}</div>
      </header>

      <div class="article-content">
        <p>{{ article.intro }}</p>

        <h2 id="what-is">{{ article.whatIsTitle }}</h2>
        <p>{{ article.whatIsText }}</p>

        <h2 id="factors">{{ article.factorsTitle }}</h2>
        <ul>
          {% for factor in article.factors %}
          <li><strong>{{ factor.split(':')[0] }}:</strong> {{ factor.split(':')[1] if ':' in factor else factor }}</li>
          {% endfor %}
        </ul>

        <h2 id="calculator">{{ article.calculatorTitle }}</h2>

        <ol class="step-list">
          {% for step in article.steps %}
          <li>
            <h3>{{ step.title }}</h3>
            <p>{{ step.text }}</p>
          </li>
          {% endfor %}
        </ol>

        <div class="example-box">
          <h4>{{ article.exampleTitle }}</h4>
          <p>
            <strong>{% if locale == 'ru' %}Автомобиль{% elif locale == 'en' %}Car{% elif locale == 'es' %}Automóvil{% elif locale == 'ug' %}ماشىna{% else %}Car{% endif %}:</strong> {{ article.example.car }}<br>
            <strong>{% if locale == 'ru' %}Пробег{% elif locale == 'en' %}Mileage{% elif locale == 'es' %}Kilometraje{% elif locale == 'ug' %}يۈرگەن ماسىفا{% else %}Mileage{% endif %}:</strong> {{ article.example.mileage }}<br>
            <strong>{% if locale == 'ru' %}Условия{% elif locale == 'en' %}Conditions{% elif locale == 'es' %}Condiciones{% elif locale == 'ug' %}ئىشلەش شارائىتى{% else %}Conditions{% endif %}:</strong> {{ article.example.conditions }}<br>
            <strong>{% if locale == 'ru' %}Обслуживание{% elif locale == 'en' %}Maintenance{% elif locale == 'es' %}Mantenimiento{% elif locale == 'ug' %}ساقلىش{% else %}Maintenance{% endif %}:</strong> {{ article.example.maintenance }}<br>
            <strong>{% if locale == 'ru' %}Результат{% elif locale == 'en' %}Result{% elif locale == 'es' %}Resultado{% elif locale == 'ug' %}نەتىجە{% else %}Result{% endif %}:</strong> {{ article.example.result }}
          </p>
        </div>

        {% if article.formulaTitle %}
        <h2 id="formula">{{ article.formulaTitle }}</h2>
        <p>{{ article.formulaText }}</p>
        {% endif %}

        {% if article.kmExample %}
        <h2 id="km-example">{{ article.kmExampleTitle }}</h2>
        <p>{{ article.kmExampleIntro }}</p>
        <div class="example-box">
          <p>
            <strong>{{ article.kmExample.purchase }}</strong><br>
            <strong>{{ article.kmExample.years }}</strong><br>
            <strong>{{ article.kmExample.mileage }}</strong><br>
            <strong>{{ article.kmExample.residual }}</strong><br>
            {{ article.kmExample.total }}<br>
            <strong>{{ article.kmExample.perKm }}</strong><br>
            <em>{{ article.kmExample.note }}</em>
          </p>
          <p><a href="/frontend/tools/logistics/depreciation-calculator.html">{% if locale == 'ru' %}Открыть калькулятор амортизации онлайн{% else %}Open depreciation calculator{% endif %}</a></p>
        </div>
        {% endif %}

        <h2 id="tips">{{ article.tipsTitle }}</h2>
        <ul>
          {% for tip in article.tips %}
          <li><strong>{{ tip.split(':')[0] }}:</strong> {{ tip.split(':')[1] if ':' in tip else tip }}</li>
          {% endfor %}
        </ul>

        <div class="highlight-box">
          <h4>{{ article.highlightTitle }}</h4>
          <p>{{ article.highlightText }}</p>
        </div>

        <h2 id="accuracy">{{ article.accuracyTitle }}</h2>
        <ul>
          {% for item in article.accuracy %}
          <li><strong>{{ item.split(':')[0] }}:</strong> {{ item.split(':')[1] if ':' in item else item }}</li>
          {% endfor %}
        </ul>

        <div class="warning-box">
          <h4>{{ article.warningTitle }}</h4>
          <p>{{ article.warningText }}</p>
        </div>

        <h2 id="recalc">{{ article.recalcTitle }}</h2>
        <ul>
          {% for item in article.recalc %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>

        {% if article.faq %}
        <h2 id="faq">{{ article.faqTitle }}</h2>
        <div class="faq-list">
          {% for item in article.faq %}
          <details class="faq-item">
            <summary>{{ item.q }}</summary>
            <p>{{ item.a }}</p>
          </details>
          {% endfor %}
        </div>
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          "mainEntity": [
            {% for item in article.faq %}
            {
              "@type": "Question",
              "name": {{ item.q | dump | safe }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ item.a | dump | safe }}
              }
            }{% if not loop.last %},{% endif %}
            {% endfor %}
          ]
        }
        </script>
        {% endif %}

        <h2 id="links">{{ article.linksTitle }}</h2>
        <ul>
          {% for link in article.links %}
          <li><a href="{{ link.href }}">{{ link.text }}</a> — {% if locale == 'ru' %}наш инструмент для расчётов{% elif locale == 'en' %}our tool for calculations{% elif locale == 'es' %}nuestra herramienta para cálculos{% elif locale == 'ug' %}ھېسابلاش قورالىمىز{% else %}our tool for calculations{% endif %}</li>
          {% endfor %}
        </ul>

        <p>{{ article.conclusion }}</p>

        {% set relatedTitle = locale | articleRelatedTitle %}
        {% set relatedItems = 'how-to-calculate-depreciation' | articleRelated(locale) %}
        {% include "partials/article-related.njk" %}
      </div>

      <div class="social-subscribe">
        <a class="tg-btn" href="https://t.me/serpmonn" target="_blank" rel="noopener">{{ article.telegramBtn }}</a>
        <a class="vk-btn" href="https://vk.com/serpmonn_site" target="_blank" rel="noopener">{{ article.vkBtn }}</a>
      </div>
    </article>

    <button type="button" class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="↑">↑</button>

    {% include "partials/article-chrome-scripts.njk" %}
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
    {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
    {{ mobileAnchor(article.closeAd) }}
    {% include "partials/ad-pool-init.njk" %}
  </body>
</html>
