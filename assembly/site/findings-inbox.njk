---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/findings/inbox.html{% else %}/frontend/{{ locale }}/findings/inbox.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  title: "{{ findingPageI18n[locale].inboxTitle }} — Serpmonn"
  inboxTitle: "{{ findingPageI18n[locale].inboxTitle }}"
  profilePath: "{% if locale == 'ru' %}/frontend/profile/profile.html{% else %}/frontend/{{ locale }}/profile/profile.html{% endif %}"
  searchPath: "{% if locale == 'ru' %}/frontend/main.html{% else %}/frontend/{{ locale }}/index.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{{ title }}</title>
  <link rel="icon" href="/frontend/images/serpmonn.ico" type="image/x-icon">
  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/profile/profile_styles.css">
  <link rel="stylesheet" href="/frontend/find/find-view.css">
  <script type="module" src="/frontend/findings/findings-inbox.js" defer></script>
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
<div class="page-wrapper">
  <main class="container" role="main">
    <section class="card finding-inbox-card" aria-labelledby="findings-inbox-title">
      <h1 id="findings-inbox-title">{{ inboxTitle }}</h1>
      <p id="findings-inbox-hint" class="finding-inbox-subtitle"></p>
      <div id="findings-inbox-list" class="findings-inbox-list findings-inbox-list--loading" aria-live="polite" aria-busy="true">
        <div class="finding-inbox-skeleton" aria-hidden="true"></div>
        <div class="finding-inbox-skeleton" aria-hidden="true"></div>
        <div class="finding-inbox-skeleton" aria-hidden="true"></div>
      </div>
    </section>
  </main>
</div>
<script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
