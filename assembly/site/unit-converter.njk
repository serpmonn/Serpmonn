---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/engineering/unit-converter.html{% else %}/frontend/{{ locale }}/tools/engineering/unit-converter.html{% endif %}"
eleventyComputed:
  title: "{{ unitConverter[locale].meta.title }}"
  description: "{{ unitConverter[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/engineering/unit-converter.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/engineering/unit-converter.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ unitConverter[locale].meta.title }}">
    <meta property="og:description" content="{{ unitConverter[locale].meta.description }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ unitConverter[locale].meta.title }}">
    <meta name="twitter:description" content="{{ unitConverter[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    
    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />
    
    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
      {% if loc == 'ru' %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/engineering/unit-converter.html" hreflang="{{ loc }}" />
      {% else %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/engineering/unit-converter.html" hreflang="{{ loc }}" />
      {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/engineering/unit-converter.html" hreflang="x-default" />      <!-- Structured Data: SoftwareApplication -->     <script type="application/ld+json">     {       "@context": "https://schema.org",       "@type": "SoftwareApplication",       "name": "{{ unitConverter[locale].meta.title | replace('"', '&quot;') }}",       "description": "{{ unitConverter[locale].meta.description | replace('"', '&quot;') }}",       "url": "{{ canonical }}",       "applicationCategory": "UtilityApplication",       "operatingSystem": "Web",       "inLanguage": "{{ locale }}",       "offers": {         "@type": "Offer",         "price": "0",         "priceCurrency": "RUB"       },       "publisher": {         "@type": "Organization",         "name": "Serpmonn",         "url": "{{ site.baseUrl }}/"       }     }     </script>
    
    <link rel="icon" href="/frontend/images/serpmonn.ico" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/styles/tools/unit-converter.css">
  </head>
  <body>
    <!-- Меню -->
    <div id="menuContainer"></div>

    <!-- Хлебные крошки -->
    <div class="breadcrumb">
      <a href="{{ site.baseUrl }}/{% if locale == 'ru' %}frontend/tools/index.html{% else %}frontend/{{ locale }}/tools/index.html{% endif %}">🧰 {{ unitConverter[locale].breadcrumb.tools }}</a> → 
      <span>🔄 {{ unitConverter[locale].breadcrumb.unitConverter }}</span>
    </div>

    <script async src="https://ad.mail.ru/static/ads-async.js"></script>
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag" 
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}" 
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>
    <script>
      (MRGtag = window.MRGtag || []).push({});
    </script>
    
    <h1>{{ unitConverter[locale].page.title }}</h1>

    <div class="converter-container">
      <!-- Выбор категории -->
      <div class="category-selector">
        <button class="category-btn active" data-category="length">{{ unitConverter[locale].page.categories.length }}</button>
        <button class="category-btn" data-category="area">{{ unitConverter[locale].page.categories.area }}</button>
        <button class="category-btn" data-category="volume">{{ unitConverter[locale].page.categories.volume }}</button>
        <button class="category-btn" data-category="temperature">{{ unitConverter[locale].page.categories.temperature }}</button>
        <button class="category-btn" data-category="power">{{ unitConverter[locale].page.categories.power }}</button>
        <button class="category-btn" data-category="pressure">{{ unitConverter[locale].page.categories.pressure }}</button>
        <button class="category-btn" data-category="mass">{{ unitConverter[locale].page.categories.mass }}</button>
        <button class="category-btn" data-category="speed">{{ unitConverter[locale].page.categories.speed }}</button>
      </div>

      <!-- Форма конвертера -->
      <div class="converter-form">
        <div class="input-group">
          <label for="fromValue">{{ unitConverter[locale].page.labels.value }}</label>
          <input type="number" id="fromValue" placeholder="{{ unitConverter[locale].page.labels.enterValuePlaceholder }}" step="any">
        </div>

        <button class="swap-btn" id="swapBtn" title="{{ unitConverter[locale].page.labels.swap }}">⇄</button>

        <div class="input-group">
          <label for="toValue">{{ unitConverter[locale].page.labels.result }}</label>
          <input type="number" id="toValue" placeholder="{{ unitConverter[locale].page.labels.resultPlaceholder }}" readonly>
        </div>
      </div>

      <!-- Выбор единиц -->
      <div class="converter-form">
        <div class="input-group">
          <label for="fromUnit">{{ unitConverter[locale].page.labels.fromUnit }}</label>
          <select id="fromUnit"></select>
        </div>

        <div></div>

        <div class="input-group">
          <label for="toUnit">{{ unitConverter[locale].page.labels.toUnit }}</label>
          <select id="toUnit"></select>
        </div>
      </div>

      <!-- Результат -->
      <div class="result" id="result">
        {{ unitConverter[locale].page.labels.enterValue }}
      </div>
    </div>

    <!-- История конвертаций -->
    <div class="conversion-history">
      <h3>{{ unitConverter[locale].page.labels.conversionHistory }}</h3>
      <div id="historyList"></div>
      <button class="clear-history" id="clearHistory">{{ unitConverter[locale].page.labels.clearHistory }}</button>
    </div>

    <!-- Вставляем переводы как JavaScript объект -->
    <script>
      // Глобальная переменная с переводами
      window.unitConverterTranslationsData = {
        locale: '{{ locale }}',
        translations: {{ unitConverter[locale] | dump | safe }}
      };
    </script>

    <script>
      // Конвертер единиц измерения
      class UnitConverter {
        constructor(translations, locale) {
          this.translations = translations;
          this.locale = locale;
          this.categories = {
            length: {
              name: translations.page.categories.length,
              units: {
                'mm': { name: translations.page.units.length.mm, factor: 0.001 },
                'cm': { name: translations.page.units.length.cm, factor: 0.01 },
                'm': { name: translations.page.units.length.m, factor: 1 },
                'km': { name: translations.page.units.length.km, factor: 1000 },
                'in': { name: translations.page.units.length.in, factor: 0.0254 },
                'ft': { name: translations.page.units.length.ft, factor: 0.3048 },
                'yd': { name: translations.page.units.length.yd, factor: 0.9144 },
                'mi': { name: translations.page.units.length.mi, factor: 1609.344 }
              }
            },
            area: {
              name: translations.page.categories.area,
              units: {
                'mm2': { name: translations.page.units.area.mm2, factor: 0.000001 },
                'cm2': { name: translations.page.units.area.cm2, factor: 0.0001 },
                'm2': { name: translations.page.units.area.m2, factor: 1 },
                'km2': { name: translations.page.units.area.km2, factor: 1000000 },
                'in2': { name: translations.page.units.area.in2, factor: 0.00064516 },
                'ft2': { name: translations.page.units.area.ft2, factor: 0.092903 },
                'yd2': { name: translations.page.units.area.yd2, factor: 0.836127 },
                'ac': { name: translations.page.units.area.ac, factor: 4046.86 }
              }
            },
            volume: {
              name: translations.page.categories.volume,
              units: {
                'ml': { name: translations.page.units.volume.ml, factor: 0.001 },
                'l': { name: translations.page.units.volume.l, factor: 1 },
                'm3': { name: translations.page.units.volume.m3, factor: 1000 },
                'cm3': { name: translations.page.units.volume.cm3, factor: 0.001 },
                'in3': { name: translations.page.units.volume.in3, factor: 0.0163871 },
                'ft3': { name: translations.page.units.volume.ft3, factor: 28.3168 },
                'gal': { name: translations.page.units.volume.gal, factor: 3.78541 }
              }
            },
            temperature: {
              name: translations.page.categories.temperature,
              units: {
                'c': { name: translations.page.units.temperature.c, factor: 1, offset: 0 },
                'f': { name: translations.page.units.temperature.f, factor: 1.8, offset: 32 },
                'k': { name: translations.page.units.temperature.k, factor: 1, offset: 273.15 },
                'r': { name: translations.page.units.temperature.r, factor: 1.8, offset: 491.67 }
              }
            },
            power: {
              name: translations.page.categories.power,
              units: {
                'w': { name: translations.page.units.power.w, factor: 1 },
                'kw': { name: translations.page.units.power.kw, factor: 1000 },
                'mw': { name: translations.page.units.power.mw, factor: 1000000 },
                'hp': { name: translations.page.units.power.hp, factor: 745.7 },
                'btu': { name: translations.page.units.power.btu, factor: 0.293071 }
              }
            },
            pressure: {
              name: translations.page.categories.pressure,
              units: {
                'pa': { name: translations.page.units.pressure.pa, factor: 1 },
                'kpa': { name: translations.page.units.pressure.kpa, factor: 1000 },
                'mpa': { name: translations.page.units.pressure.mpa, factor: 1000000 },
                'bar': { name: translations.page.units.pressure.bar, factor: 100000 },
                'atm': { name: translations.page.units.pressure.atm, factor: 101325 },
                'psi': { name: translations.page.units.pressure.psi, factor: 6894.76 }
              }
            },
            mass: {
              name: translations.page.categories.mass,
              units: {
                'mg': { name: translations.page.units.mass.mg, factor: 0.001 },
                'g': { name: translations.page.units.mass.g, factor: 1 },
                'kg': { name: translations.page.units.mass.kg, factor: 1000 },
                't': { name: translations.page.units.mass.t, factor: 1000000 },
                'lb': { name: translations.page.units.mass.lb, factor: 453.592 },
                'oz': { name: translations.page.units.mass.oz, factor: 28.3495 }
              }
            },
            speed: {
              name: translations.page.categories.speed,
              units: {
                'mps': { name: translations.page.units.speed.mps, factor: 1 },
                'kmh': { name: translations.page.units.speed.kmh, factor: 0.277778 },
                'mph': { name: translations.page.units.speed.mph, factor: 0.44704 },
                'knot': { name: translations.page.units.speed.knot, factor: 0.514444 },
                'fps': { name: translations.page.units.speed.fps, factor: 0.3048 }
              }
            }
          };

          this.currentCategory = 'length';
          this.history = JSON.parse(localStorage.getItem('conversionHistory') || '[]');
          
          this.init();
        }

        init() {
          this.setupEventListeners();
          this.populateUnits();
          this.updateHistory();
        }

        setupEventListeners() {
          // Кнопки категорий
          document.querySelectorAll('.category-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
              this.setCategory(e.target.dataset.category);
            });
          });

          // Поля ввода
          document.getElementById('fromValue').addEventListener('input', () => {
            this.convert();
          });

          // Выбор единиц
          document.getElementById('fromUnit').addEventListener('change', () => {
            this.convert();
          });

          document.getElementById('toUnit').addEventListener('change', () => {
            this.convert();
          });

          // Кнопка смены местами
          document.getElementById('swapBtn').addEventListener('click', () => {
            this.swapUnits();
          });

          // Очистка истории
          document.getElementById('clearHistory').addEventListener('click', () => {
            this.clearHistory();
          });
        }

        setCategory(category) {
          this.currentCategory = category;
          
          // Обновляем активную кнопку
          document.querySelectorAll('.category-btn').forEach(btn => {
            btn.classList.remove('active');
          });
          document.querySelector(`[data-category="${category}"]`).classList.add('active');
          
          this.populateUnits();
          this.convert();
        }

        populateUnits() {
          const fromSelect = document.getElementById('fromUnit');
          const toSelect = document.getElementById('toUnit');
          const units = this.categories[this.currentCategory].units;
          
          // Очищаем селекты
          fromSelect.innerHTML = '';
          toSelect.innerHTML = '';
          
          // Заполняем опциями
          Object.entries(units).forEach(([key, unit]) => {
            const fromOption = document.createElement('option');
            const toOption = document.createElement('option');
            
            fromOption.value = key;
            fromOption.textContent = unit.name;
            toOption.value = key;
            toOption.textContent = unit.name;
            
            fromSelect.appendChild(fromOption);
            toSelect.appendChild(toOption);
          });
          
          // Устанавливаем разные единицы по умолчанию
          const unitKeys = Object.keys(units);
          if (unitKeys.length >= 2) {
            fromSelect.value = unitKeys[0];
            toSelect.value = unitKeys[1];
          }
        }

        convert() {
          const fromValue = parseFloat(document.getElementById('fromValue').value);
          const fromUnit = document.getElementById('fromUnit').value;
          const toUnit = document.getElementById('toUnit').value;
          
          if (isNaN(fromValue)) {
            document.getElementById('result').textContent = this.translations.page.labels.enterValue;
            return;
          }
          
          let result;
          
          if (this.currentCategory === 'temperature') {
            result = this.convertTemperature(fromValue, fromUnit, toUnit);
          } else {
            result = this.convertStandard(fromValue, fromUnit, toUnit);
          }
          
          document.getElementById('toValue').value = result.toFixed(6);
          document.getElementById('result').textContent = 
            `${fromValue} ${this.categories[this.currentCategory].units[fromUnit].name} = ${result.toFixed(6)} ${this.categories[this.currentCategory].units[toUnit].name}`;
          
          // Добавляем в историю
          this.addToHistory(fromValue, fromUnit, toUnit, result);
        }

        convertStandard(value, fromUnit, toUnit) {
          const fromFactor = this.categories[this.currentCategory].units[fromUnit].factor;
          const toFactor = this.categories[this.currentCategory].units[toUnit].factor;
          
          // Сначала конвертируем в базовую единицу, потом в целевую
          const baseValue = value * fromFactor;
          return baseValue / toFactor;
        }

        convertTemperature(value, fromUnit, toUnit) {
          // Сначала конвертируем в Цельсий
          let celsius;
          
          switch (fromUnit) {
            case 'c':
              celsius = value;
              break;
            case 'f':
              celsius = (value - 32) / 1.8;
              break;
            case 'k':
              celsius = value - 273.15;
              break;
            case 'r':
              celsius = (value - 491.67) / 1.8;
              break;
          }
          
          // Теперь конвертируем из Цельсия в целевую единицу
          switch (toUnit) {
            case 'c':
              return celsius;
            case 'f':
              return celsius * 1.8 + 32;
            case 'k':
              return celsius + 273.15;
            case 'r':
              return celsius * 1.8 + 491.67;
          }
        }

        swapUnits() {
          const fromUnit = document.getElementById('fromUnit');
          const toUnit = document.getElementById('toUnit');
          const temp = fromUnit.value;
          
          fromUnit.value = toUnit.value;
          toUnit.value = temp;
          
          this.convert();
        }

        addToHistory(fromValue, fromUnit, toUnit, result) {
          const historyItem = {
            from: `${fromValue} ${this.categories[this.currentCategory].units[fromUnit].name}`,
            to: `${result.toFixed(6)} ${this.categories[this.currentCategory].units[toUnit].name}`,
            category: this.categories[this.currentCategory].name,
            timestamp: new Date().toLocaleString(this.locale === 'ru' ? 'ru-RU' : 'en-US')
          };
          
          this.history.unshift(historyItem);
          
          // Ограничиваем историю 20 элементами
          if (this.history.length > 20) {
            this.history = this.history.slice(0, 20);
          }
          
          localStorage.setItem('conversionHistory', JSON.stringify(this.history));
          this.updateHistory();
        }

        updateHistory() {
          const historyList = document.getElementById('historyList');
          historyList.innerHTML = '';
          
          if (this.history.length === 0) {
            historyList.innerHTML = `<p style="color: #6c757d; text-align: center;">${this.translations.page.labels.emptyHistory}</p>`;
            return;
          }
          
          this.history.forEach(item => {
            const historyItem = document.createElement('div');
            historyItem.className = 'history-item';
            historyItem.innerHTML = `
              <div class="history-text">
                <strong>${item.category}:</strong> ${item.from} → ${item.to}
              </div>
              <div class="history-time">${item.timestamp}</div>
            `;
            historyList.appendChild(historyItem);
          });
        }

        clearHistory() {
          this.history = [];
          localStorage.removeItem('conversionHistory');
          this.updateHistory();
        }
      }

      // Инициализация конвертера
      document.addEventListener('DOMContentLoaded', () => {
        try {
          // Используем глобальные данные переводов
          const translations = window.unitConverterTranslationsData.translations;
          const locale = window.unitConverterTranslationsData.locale || 'ru';
          new UnitConverter(translations, locale);
        } catch (error) {
          console.error('Error initializing unit converter:', error);
        }
      });
    </script>

    <!-- Загрузка меню -->
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
<script>/*GLOBAL_AD_HOOK*/(function(){
      function handleIns(ins){
        if (!ins || ins.__handled) return; ins.__handled = true;
        setTimeout(function(){
          var has = !!ins.querySelector("iframe");
          if (!has) { (window.MRGtag=window.MRGtag||[]).push({}); }
          setTimeout(function(){ if (!ins.querySelector("iframe")) { var p=ins.closest(".ad-top-banner,.ad-leaderboard,.promo-ad-inline,#mobile-anchor-ad"); if(p) p.style.display='none'; } }, 2000);
        }, 2000);
      }
      document.querySelectorAll("ins.mrg-tag").forEach(handleIns);
      var mo = new MutationObserver(function(muts){
        muts.forEach(function(m){ m.addedNodes && m.addedNodes.forEach(function(n){ if(n.querySelectorAll){ n.querySelectorAll("ins.mrg-tag").forEach(handleIns); } }); });
      });
      mo.observe(document.documentElement,{childList:true,subtree:true});
    })();</script>
    
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(unitConverter[locale].page.labels.closeAd) }}
</body>
</html>
