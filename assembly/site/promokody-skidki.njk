---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/promo-codes-and-discounts/promokody-skidki.html{% else %}/frontend/{{ locale }}/promo-codes-and-discounts/promokody-skidki.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/promo-codes-and-discounts/promokody-skidki.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/promo-codes-and-discounts/promokody-skidki.html{% endif %}"
---
{% from "partials/promo-card-ssr.njk" import renderPromoCard %}

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ localesPromocodes[locale].promoCodes.title }}</title>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />

    <!-- Open Graph -->
    <meta property="og:title" content="{{ localesPromocodes[locale].promoCodes.ogTitle }}">
    <meta property="og:description" content="{{ localesPromocodes[locale].promoCodes.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ localesPromocodes[locale].promoCodes.ogTitle }}">
    <meta name="twitter:description" content="{{ localesPromocodes[locale].promoCodes.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/promo-codes-and-discounts/promokody-skidki.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/promo-codes-and-discounts/promokody-skidki.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/promo-codes-and-discounts/promokody-skidki.html" hreflang="x-default" />

    <!-- Мета-описание для SEO -->
    <meta name="description" content="{{ localesPromocodes[locale].promoCodes.metaDescription }}">
    <meta name="keywords" content="{{ localesPromocodes[locale].promoCodes.keywords }}">

    <!-- Favicon -->
    <link rel="icon" href="/frontend/images/serpmonn.ico" type="image/x-icon">

    <!-- Стили -->
    <link rel="preload" href="/frontend/promo-codes-and-discounts/promokody-skidki.css?v=28" as="style" onload="this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="/frontend/promo-codes-and-discounts/promokody-skidki.css?v=28"></noscript>
    <link rel="preload" href="/frontend/styles/accessibility.css" as="style" onload="this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="/frontend/styles/accessibility.css"></noscript>

    <!-- Скрипты -->
    <script>
        (function() {
            const KEY = 'serpmonn_promos_version';
            async function checkVersion() {
                try {
                    const res = await fetch('/api/promocodes/version', { cache: 'no-store' });
                    if (!res.ok) return;
                    const data = await res.json();
                    const current = data?.version || null;
                    const stored = localStorage.getItem(KEY);
                    if (current && stored && stored !== current) {
                        localStorage.setItem(KEY, current);
                        window.location.reload();
                    } else if (current && !stored) {
                        localStorage.setItem(KEY, current);
                    }
                } catch (error) {
                    console.error('Error checking version:', error);
                }
            }
            checkVersion();
            setInterval(checkVersion, 24 * 60 * 60 * 1000);
        })();
    </script>
    
    <!-- Яндекс.Метрика -->
    <script type="text/javascript">
        (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
        m[i].l=1*new Date();
        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
        (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");

        ym(104300276, "init", {
            clickmap:true,
            trackLinks:true,
            accurateTrackBounce:true,
            webvisor:true,
            ecommerce:"dataLayer"
        });
        
        window.addEventListener('load', function() {
            fetch('https://api.ipify.org?format=json')
                .then(response => response.json())
                .then(data => {
                    if (typeof ym !== 'undefined') {
                        ym(104300276, 'params', { 
                            ip_address: data.ip,
                            user_ip: data.ip
                        });
                        ym(104300276, 'hit', window.location.href, {
                            params: { ip_address: data.ip }
                        });
                    }
                })
                .catch(error => {
                    console.error('Error getting IP:', error);
                });
        });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/104300276" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Яндекс.Метрика -->
    
    <!-- Top.Mail.Ru counter -->
    <script type="text/javascript">
        var _tmr = window._tmr || (window._tmr = []);
        _tmr.push({id: "3552905", type: "pageView", start: (new Date()).getTime()});
        
        var userId = '';
        if (window.dataLayer && window.dataLayer.length > 0) {
            for (var i = window.dataLayer.length - 1; i >= 0; i--) {
                if (window.dataLayer[i].userId) {
                    userId = window.dataLayer[i].userId;
                    break;
                }
            }
        }
        
        if (userId) {
            _tmr.push({id: "3552905", type: "pageView", pid: userId});
        }
        
        (function (d, w, id) {
          if (d.getElementById(id)) return;
          var ts = d.createElement("script"); ts.type = "text/javascript"; ts.async = true; ts.id = id;
          ts.src = "https://top-fwz1.mail.ru/js/code.js";
          var f = function () {var s = d.getElementsByTagName("script")[0]; s.parentNode.insertBefore(ts, s);};
          if (w.opera == "[object Opera]") { d.addEventListener("DOMContentLoaded", f, false); } else { f(); }
        })(document, window, "tmr-code");
    </script>
    <noscript><div><img src="https://top-fwz1.mail.ru/counter?id=3552905;js=na" style="position:absolute;left:-9999px;" alt="Top.Mail.Ru" /></div></noscript>
    <!-- /Top.Mail.Ru counter -->
    
    <script type="module" src="/frontend/promo-codes-and-discounts/promokody-skidki.js?v=45" defer></script>
    <script async src="https://ad.mail.ru/static/ads-async.js"></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
    <header>
        <nav id="main-nav" aria-label="{{ localesPromocodes[locale].promoCodes.mainNavLabel }}"></nav>
    </header>
    
    <main class="container">
        <section class="stats-controls" aria-labelledby="overview-title">
            <div class="stats-head">
                <h1 id="overview-title">{{ localesPromocodes[locale].promoCodes.heroTitle }}</h1>
                <div class="stats-summary" aria-live="polite">
                    <span class="stat-chip">
                        <span class="stat-number" id="activePromos">{{ promocodesBuild.stats.active | default(0) }}</span>
                        <span class="stat-label">{{ localesPromocodes[locale].promoCodes.activePromos }}</span>
                    </span>
                    <span class="stat-chip stat-chip--total" id="totalStatChip">
                        <span class="stat-number" id="totalPromos">{{ promocodesBuild.stats.total | default(0) }}</span>
                        <span class="stat-label">{{ localesPromocodes[locale].promoCodes.totalPromos }}</span>
                    </span>
                    <span class="stats-updated">
                        {{ localesPromocodes[locale].promoCodes.lastUpdated }}
                        <span id="lastUpdate">{{ promocodesBuild.stats.lastUpdateFormatted | default('-') }}</span>
                    </span>
                </div>
            </div>
            <div class="controls toolbar-actions">
                <button id="toggleFilters" class="submit-btn toolbar-mobile-only" type="button" aria-expanded="false" aria-controls="filtersContent" aria-label="{{ localesPromocodes[locale].promoCodes.toggleFilters }}">{{ localesPromocodes[locale].promoCodes.toggleFilters }}</button>
                <button id="sortByExpiryBtn" type="button" class="submit-btn toolbar-desktop-only" aria-label="{{ localesPromocodes[locale].promoCodes.sortByExpiry }}">{{ localesPromocodes[locale].promoCodes.sortByExpiry }}</button>
                <button id="resetFiltersBtn" type="button" class="submit-btn toolbar-desktop-only" aria-label="{{ localesPromocodes[locale].promoCodes.resetFilters }}">{{ localesPromocodes[locale].promoCodes.resetFilters }}</button>
            </div>
        </section>

        <section class="filters" aria-label="{{ localesPromocodes[locale].promoCodes.toggleFilters }}">
            <div id="filtersContent" style="display: none;">
                <div class="filter-row">
                    <label for="searchInput">{{ localesPromocodes[locale].promoCodes.searchPlaceholder }}</label>
                    <input type="text" id="searchInput" aria-label="{{ localesPromocodes[locale].promoCodes.searchPlaceholder }}" aria-describedby="search-hint">
                </div>
                <p id="search-hint" class="visually-hidden">{{ localesPromocodes[locale].promoCodes.searchHint }}</p>

                <div class="filter-row">
                    <label for="categorySelect">{{ localesPromocodes[locale].promoCodes.allCategories }}</label>
                    <select id="categorySelect" aria-label="{{ localesPromocodes[locale].promoCodes.allCategories }}">
                        <option value="">{{ localesPromocodes[locale].promoCodes.allCategories }}</option>
                        {% for cat in promocodesBuild.categories %}
                        <option value="{{ cat }}">{{ promoI18n[locale]['promo.cat.' ~ cat] | default(cat) }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="filter-row">
                    <label for="statusSelect">{{ localesPromocodes[locale].promoCodes.allStatuses }}</label>
                    <select id="statusSelect" aria-label="{{ localesPromocodes[locale].promoCodes.allStatuses }}">
                        <option value="">{{ localesPromocodes[locale].promoCodes.allStatuses }}</option>
                        <option value="active">{{ localesPromocodes[locale].promoCodes.activeStatus }}</option>
                        <option value="expired">{{ localesPromocodes[locale].promoCodes.expiredStatus }}</option>
                    </select>
                </div>

                <div class="filter-row">
                    <label for="countrySelect">{{ localesPromocodes[locale].promoCodes.allCountries }}</label>
                    <select id="countrySelect" aria-label="{{ localesPromocodes[locale].promoCodes.allCountries }}">
                        <option value="" selected>{{ localesPromocodes[locale].promoCodes.allCountries }}</option>
                        <option value="Россия">{{ localesPromocodes[locale].promoCodes.russia }}</option>
                        <option value="Казахстан">{{ localesPromocodes[locale].promoCodes.kazakhstan }}</option>
                        <option value="Узбекистан">{{ localesPromocodes[locale].promoCodes.uzbekistan }}</option>
                        <option value="Грузия">{{ localesPromocodes[locale].promoCodes.georgia }}</option>
                    </select>
                </div>

                <div class="filter-actions toolbar-mobile-only">
                    <button id="sortByExpiryBtnMobile" type="button" class="submit-btn" aria-label="{{ localesPromocodes[locale].promoCodes.sortByExpiry }}">{{ localesPromocodes[locale].promoCodes.sortByExpiry }}</button>
                    <button id="resetFiltersBtnMobile" type="button" class="submit-btn" aria-label="{{ localesPromocodes[locale].promoCodes.resetFilters }}">{{ localesPromocodes[locale].promoCodes.resetFilters }}</button>
                </div>
            </div>
        </section>

        <div id="loadingSpinner" class="loading" style="display: none;">
            <div class="spinner"></div>
            <p>{{ localesPromocodes[locale].promoCodes.loading }}</p>
        </div>

        <section id="catalog" class="promo-grid" aria-label="{{ localesPromocodes[locale].promoCodes.catalogTitle }}" role="region">
            {% for promo in promocodesBuild.cards %}
            {{ renderPromoCard(promo, locale) }}
            {% endfor %}
        </section>

        <section class="faq" aria-labelledby="faq-title">
            <h2 id="faq-title">{{ localesPromocodes[locale].promoCodes.faqTitle }}</h2>
            <details>
                <summary lang="{{ locale }}">{{ localesPromocodes[locale].promoCodes.faq1Question }}</summary>
                <p>{{ localesPromocodes[locale].promoCodes.faq1Answer | safe }}</p>
            </details>
            <details>
                <summary lang="{{ locale }}">{{ localesPromocodes[locale].promoCodes.faq2Question }}</summary>
                <p>{{ localesPromocodes[locale].promoCodes.faq2Answer | safe }}</p>
            </details>
        </section>

        <section class="bonus" aria-labelledby="bonus-title">
            <h2 id="bonus-title">{{ localesPromocodes[locale].promoCodes.bonusTitle }}</h2>
            <p>{{ localesPromocodes[locale].promoCodes.bonusText }}</p>

            <div class="social-proof" aria-live="polite">
                <span class="social-proof-count" id="subscribersCount" data-count-template="{{ localesPromocodes[locale].promoCodes.socialProofCount }}">
                    {{ localesPromocodes[locale].promoCodes.socialProofCount | replace('{count}', '3 000') }}
                </span>
                <span class="social-proof-note">
                    {{ localesPromocodes[locale].promoCodes.socialProofNote }}
                </span>
            </div>

            <form action="/subscribe" method="post" aria-label="{{ localesPromocodes[locale].promoCodes.bonusTitle }}">
                <input type="email" name="email" placeholder="{{ localesPromocodes[locale].promoCodes.emailPlaceholder }}" required aria-label="{{ localesPromocodes[locale].promoCodes.emailPlaceholder }}">
                <button type="submit" class="submit-btn">{{ localesPromocodes[locale].promoCodes.subscribeButton }}</button>
            </form>
        </section>
    </main>
    
    <footer>
        <p>{{ localesPromocodes[locale].promoCodes.footerText | safe }}</p>
    </footer>

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "{{ localesPromocodes[locale].promoCodes.breadcrumbHome }}",
                "item": "{{ site.baseUrl }}/"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "{{ localesPromocodes[locale].promoCodes.breadcrumbPromoCodes }}",
                "item": "{{ canonical }}"
            }
        ]
    }
    </script>
    
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "{{ localesPromocodes[locale].promoCodes.title }}",
        "description": "{{ localesPromocodes[locale].promoCodes.metaDescription }}",
        "url": "{{ canonical }}"
    }
    </script>

    {% if promocodesBuild.schemaOffers.length %}
    <script type="application/ld+json" id="promo-offers-schema">
    {
        "@context": "https://schema.org",
        "@graph": {{ promocodesBuild.schemaOffers | dump | safe }}
    }
    </script>
    {% endif %}

    <script id="promo-bootstrap" type="application/json">{{ {
        stats: promocodesBuild.stats,
        categories: promocodesBuild.categories,
        data: promocodesBuild.data,
        version: promocodesBuild.version
    } | dump | safe }}</script>

    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>