---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/port-forwarding-guide.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/port-forwarding-guide.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/port-forwarding-guide.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/port-forwarding-guide.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ portForwardingGuide[locale].meta.description }}">
    <title>{{ portForwardingGuide[locale].meta.title }}</title>
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ portForwardingGuide[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ portForwardingGuide[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ portForwardingGuide[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ portForwardingGuide[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <!-- Structured Data: Article -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "{{ portForwardingGuide[locale].meta.ogTitle | replace('"', '&quot;') }}",
      "description": "{{ portForwardingGuide[locale].meta.ogDescription | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2025-10-29",
      "dateModified": "2026-07-22",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "author": {
        "@type": "Organization",
        "name": "Serpmonn",
        "url": "{{ site.baseUrl }}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Serpmonn",
        "url": "{{ site.baseUrl }}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
    {% if loc == 'ru' %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/port-forwarding-guide.html" hreflang="{{ loc }}" />
    {% else %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/knowledge-base/articles/port-forwarding-guide.html" hreflang="{{ loc }}" />
    {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/port-forwarding-guide.html" hreflang="x-default" />

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css">
    <link rel="stylesheet" href="/frontend/styles/articles/port-forwarding.css">
</head>
<body>
    <div class="reading-progress" aria-hidden="true">
        <div class="reading-progress-bar"></div>
    </div>

    <button type="button" class="toc-toggle" id="tocToggle" aria-expanded="false" aria-controls="floatingToc">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><path d="M3 6h.01"/><path d="M3 12h.01"/><path d="M3 18h.01"/>
        </svg>
        <span class="visually-hidden">{{ portForwardingGuide[locale].article.sections.toc.title }}</span>
    </button>

    <nav class="floating-toc" id="floatingToc" aria-label="{{ portForwardingGuide[locale].article.sections.toc.title }}">
        <div class="floating-toc__head">
            <h3>{{ portForwardingGuide[locale].article.sections.toc.title }}</h3>
            <button type="button" class="floating-toc__close" id="tocClose" aria-label="×">
                <span aria-hidden="true">×</span>
            </button>
        </div>
        <ul>
            <li><a href="#section-what-is">{{ portForwardingGuide[locale].article.sections.toc.items[0] }}</a></li>
            <li><a href="#section-why-need">{{ portForwardingGuide[locale].article.sections.toc.items[1] }}</a></li>
            <li><a href="#section-preparation">{{ portForwardingGuide[locale].article.sections.toc.items[2] }}</a></li>
            <li><a href="#section-step-by-step">{{ portForwardingGuide[locale].article.sections.toc.items[3] }}</a></li>
            <li><a href="#section-routers">{{ portForwardingGuide[locale].article.sections.toc.items[4] }}</a></li>
            <li><a href="#section-verification">{{ portForwardingGuide[locale].article.sections.toc.items[5] }}</a></li>
            <li><a href="#section-troubleshooting">{{ portForwardingGuide[locale].article.sections.toc.items[6] }}</a></li>
            <li><a href="#section-security">{{ portForwardingGuide[locale].article.sections.toc.items[7] }}</a></li>
            {% if portForwardingGuide[locale].article.sections.practicalCases %}
            <li><a href="#section-practical">{{ portForwardingGuide[locale].article.sections.practicalCases.title }}</a></li>
            {% endif %}
            {% if portForwardingGuide[locale].article.sections.faq %}
            <li><a href="#section-faq">{{ portForwardingGuide[locale].article.sections.faq.title }}</a></li>
            {% endif %}
        </ul>
    </nav>
    <div class="toc-backdrop" id="tocBackdrop" hidden></div>

    <div id="menuContainer"></div>
    <article class="article-container" tabindex="0">
        <header class="article-header">
            <span class="article-category">{{ portForwardingGuide[locale].article.category }}</span>
            <div class="ad-top-banner ad-banner loading">
                <ins class="mrg-tag" style="display:inline-block;" data-ad-client="ad-{{ mailAds.slots.top.id }}" data-ad-slot="{{ mailAds.slots.top.id }}"></ins>
            </div>
            <h1 class="article-title">{{ portForwardingGuide[locale].article.title }}</h1>
            <div class="article-meta">{{ portForwardingGuide[locale].article.date }} • {{ portForwardingGuide[locale].article.readTime }}</div>
        </header>

        <div class="article-content">
            <p>{{ portForwardingGuide[locale].article.intro }}</p>

            <h2 id="section-what-is">{{ portForwardingGuide[locale].article.sections.whatIs.title }}</h2>
            <p>{{ portForwardingGuide[locale].article.sections.whatIs.content | safe }}</p>
            
            <div class="visual-guide">
                <div class="visual-item">
                    <div class="visual-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>
                    </div>
                    <h3>{{ portForwardingGuide[locale].article.sections.whatIs.visualGuide.internet.title }}</h3>
                    <p>{{ portForwardingGuide[locale].article.sections.whatIs.visualGuide.internet.desc }}</p>
                </div>
                <div class="visual-item">
                    <div class="visual-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16h16v3H4z"/><path d="M7 16V9"/><path d="M12 16V7"/><path d="M17 16V9"/><path d="M8 5c2-2 6-2 8 0"/></svg>
                    </div>
                    <h3>{{ portForwardingGuide[locale].article.sections.whatIs.visualGuide.router.title }}</h3>
                    <p>{{ portForwardingGuide[locale].article.sections.whatIs.visualGuide.router.desc }}</p>
                </div>
                <div class="visual-item">
                    <div class="visual-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M8 20h8"/><path d="M12 16v4"/></svg>
                    </div>
                    <h3>{{ portForwardingGuide[locale].article.sections.whatIs.visualGuide.device.title }}</h3>
                    <p>{{ portForwardingGuide[locale].article.sections.whatIs.visualGuide.device.desc }}</p>
                </div>
            </div>

            <h2 id="section-why-need">{{ portForwardingGuide[locale].article.sections.whyNeed.title }}</h2>
            
            <table class="port-table">
                <thead>
                    <tr>
                        {% for header in portForwardingGuide[locale].article.sections.whyNeed.table.headers %}
                        <th>{{ header }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in portForwardingGuide[locale].article.sections.whyNeed.table.rows %}
                    <tr>
                        <td>{{ row.purpose | safe }}</td>
                        <td>{{ row.ports | safe }}</td>
                        <td>{{ row.usage | safe }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="security-warning">
                <h4>{{ portForwardingGuide[locale].article.sections.securityWarning.title }}</h4>
                <p>{{ portForwardingGuide[locale].article.sections.securityWarning.content }}</p>
            </div>

            <h2 id="section-preparation">{{ portForwardingGuide[locale].article.sections.preparation.title }}</h2>
            
            <ol class="step-list">
                {% for step in portForwardingGuide[locale].article.sections.preparation.steps %}
                <li>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.content | safe }}</p>
                    
                    {% if step.windows %}
                    <div class="code-example">
                        <h4>{{ step.windows.title }}</h4>
                        <pre><code class="language-cmd">{{ step.windows.code }}</code></pre>
                        <p>{{ step.windows.hint | safe }}</p>
                    </div>
                    {% endif %}
                    
                    {% if step.linuxMac %}
                    <div class="code-example">
                        <h4>{{ step.linuxMac.title }}</h4>
                        <pre><code class="language-bash">{{ step.linuxMac.code }}</code></pre>
                        <p>{{ step.linuxMac.hint | safe }}</p>
                    </div>
                    {% endif %}
                    
                    {% if step.router %}
                    <ul>
                        <li>{{ step.router | safe }}</li>
                        <li>{{ step.device | safe }}</li>
                    </ul>
                    {% endif %}
                    
                    {% if step.code %}
                    <div class="code-example">
                        <h4>{{ step.codeTitle }}</h4>
                        <pre><code class="language-bash">{{ step.code }}</code></pre>
                    </div>
                    {% endif %}
                </li>
                {% endfor %}
            </ol>

            <h2 id="section-step-by-step">{{ portForwardingGuide[locale].article.sections.stepByStep.title }}</h2>
            
            <ol class="step-list">
                {% for step in portForwardingGuide[locale].article.sections.stepByStep.steps %}
                <li>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.content | safe }}</p>
                    
                    {% if step.ips %}
                    <ul>
                        {% for ip in step.ips %}
                        <li>{{ ip | safe }}</li>
                        {% endfor %}
                    </ul>
                    <p>{{ step.note | safe }}</p>
                    {% endif %}
                    
                    {% if step.names %}
                    <ul>
                        {% for name in step.names %}
                        <li>{{ name | safe }}</li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                    
                    {% if step.params %}
                    <ul>
                        {% for param in step.params %}
                        <li>{{ param | safe }}</li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                </li>
                {% endfor %}
            </ol>

            <h2 id="section-routers">{{ portForwardingGuide[locale].article.sections.routers.title }}</h2>

            {% for guide in portForwardingGuide[locale].article.sections.routers.guides %}
            <div class="router-guide">
                <h4>{{ guide.brand }}</h4>
                <ol>
                    {% for step in guide.steps %}
                    {% if loop.index == 4 %}
                    <li>{{ step | safe }}
                        <ul>
                            {% for field in guide.fields %}
                            <li>{{ field | safe }}</li>
                            {% endfor %}
                        </ul>
                    </li>
                    {% else %}
                    <li>{{ step | safe }}</li>
                    {% endif %}
                    {% endfor %}
                </ol>
            </div>
            {% endfor %}

            <h2 id="section-verification">{{ portForwardingGuide[locale].article.sections.verification.title }}</h2>

            <ol class="step-list">
                {% for step in portForwardingGuide[locale].article.sections.verification.steps %}
                <li>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.content | safe }}</p>
                    
                    {% if step.links %}
                    <ul>
                        {% for link in step.links %}
                        <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.name }}</a></li>
                        {% endfor %}
                    </ul>
                    {% endif %}
                    
                    {% if step.code %}
                    <div class="code-example">
                        <h4>{{ step.codeTitle }}</h4>
                        <pre><code class="language-bash">{{ step.code }}</code></pre>
                    </div>
                    {% endif %}
                </li>
                {% endfor %}
            </ol>

            <div class="success-tip">
                <h4>{{ portForwardingGuide[locale].article.sections.verification.successTips.title }}</h4>
                <ul>
                    {% for tip in portForwardingGuide[locale].article.sections.verification.successTips.tips %}
                    <li>{{ tip }}</li>
                    {% endfor %}
                </ul>
            </div>

            <h2 id="section-troubleshooting">{{ portForwardingGuide[locale].article.sections.troubleshooting.title }}</h2>

            {% for problem in portForwardingGuide[locale].article.sections.troubleshooting.problems %}
            <div class="router-guide">
                <h4>{{ problem.title }}</h4>
                {% if problem.content %}<p>{{ problem.content | safe }}</p>{% endif %}
                <ul>
                    {% for item in problem.items %}
                    <li>{{ item | safe }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}

            <h2 id="section-security">{{ portForwardingGuide[locale].article.sections.security.title }}</h2>

            <div class="security-warning">
                <h4>{{ portForwardingGuide[locale].article.sections.security.rules.title }}</h4>
                <ol>
                    {% for rule in portForwardingGuide[locale].article.sections.security.rules.items %}
                    <li>{{ rule | safe }}</li>
                    {% endfor %}
                </ol>
            </div>

            <div class="success-tip">
                <h4>{{ portForwardingGuide[locale].article.sections.security.bestPractices.title }}</h4>
                <ul>
                    {% for practice in portForwardingGuide[locale].article.sections.security.bestPractices.items %}
                    <li>{{ practice | safe }}</li>
                    {% endfor %}
                </ul>
            </div>

            <h3>{{ portForwardingGuide[locale].article.sections.security.checklist.title }}</h3>
            <ul class="checklist">
                {% for item in portForwardingGuide[locale].article.sections.security.checklist.items %}
                <li>
                    <input type="checkbox" id="security{{ loop.index }}">
                    <label for="security{{ loop.index }}">{{ item }}</label>
                </li>
                {% endfor %}
            </ul>

            {% if portForwardingGuide[locale].article.sections.practicalCases %}
            <h2 id="section-practical">{{ portForwardingGuide[locale].article.sections.practicalCases.title }}</h2>
            <p>{{ portForwardingGuide[locale].article.sections.practicalCases.intro }}</p>
            {% for case in portForwardingGuide[locale].article.sections.practicalCases.cases %}
            <div class="router-guide">
                <h3>{{ case.title }}</h3>
                <p>{{ case.body | safe }}</p>
            </div>
            {% endfor %}
            {% endif %}

            {% if portForwardingGuide[locale].article.sections.faq %}
            <h2 id="section-faq">{{ portForwardingGuide[locale].article.sections.faq.title }}</h2>
            <div class="faq-list">
                {% for item in portForwardingGuide[locale].article.sections.faq.items %}
                <details class="faq-item">
                    <summary>{{ item.q }}</summary>
                    <p>{{ item.a }}</p>
                </details>
                {% endfor %}
            </div>
            <script type="application/ld+json">
            {
              "@context": "https://schema.org",
              "@type": "FAQPage",
              "mainEntity": [
                {% for item in portForwardingGuide[locale].article.sections.faq.items %}
                {
                  "@type": "Question",
                  "name": {{ item.q | dump | safe }},
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": {{ item.a | dump | safe }}
                  }
                }{% if not loop.last %},{% endif %}
                {% endfor %}
              ]
            }
            </script>
            {% endif %}

            {% if portForwardingGuide[locale].article.sections.related %}
            <div class="related-articles">
                <h3>{{ portForwardingGuide[locale].article.sections.related.title }}</h3>
                <ul class="related-links">
                    {% for article in portForwardingGuide[locale].article.sections.related.articles %}
                    <li><a href="{{ article.url }}">{{ article.title }}</a></li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            <div class="share-buttons">
                <h3>{{ portForwardingGuide[locale].article.sections.share.title }}</h3>
                <button type="button" onclick="share('telegram')" aria-label="{{ portForwardingGuide[locale].article.sections.share.telegramAria }}">{{ portForwardingGuide[locale].article.sections.share.telegram }}</button>
                <button type="button" onclick="share('vk')" aria-label="{{ portForwardingGuide[locale].article.sections.share.vkAria }}">{{ portForwardingGuide[locale].article.sections.share.vk }}</button>
            </div>
        </div>

        <div class="social-subscribe">
            <a class="tg-btn" href="{{ portForwardingGuide[locale].article.social.telegram.url }}" target="_blank" rel="noopener" aria-label="{{ portForwardingGuide[locale].article.social.telegram.aria }}">{{ portForwardingGuide[locale].article.social.telegram.text }}</a>
            <a class="vk-btn" href="{{ portForwardingGuide[locale].article.social.vk.url }}" target="_blank" rel="noopener" aria-label="{{ portForwardingGuide[locale].article.social.vk.aria }}">{{ portForwardingGuide[locale].article.social.vk.text }}</a>
        </div>
    </article>

    <button class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="{{ portForwardingGuide[locale].article.buttons.scrollTop }}">{{ portForwardingGuide[locale].article.buttons.scrollTop }}</button>

    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>

    <script>
        function share(network) {
            const url = encodeURIComponent(window.location.href);
            const title = encodeURIComponent(document.title);
            const shareUrls = {
                telegram: `https://t.me/share/url?url=${url}&text=${title}`,
                vk: `https://vk.com/share.php?url=${url}&title=${title}`
            };
            window.open(shareUrls[network], '_blank', 'noopener');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const toc = document.getElementById('floatingToc');
            const tocToggle = document.getElementById('tocToggle');
            const tocClose = document.getElementById('tocClose');
            const tocBackdrop = document.getElementById('tocBackdrop');
            const tocLinks = Array.from(toc.querySelectorAll('a[href^="#"]'));
            const sections = tocLinks
                .map((link) => document.querySelector(link.getAttribute('href')))
                .filter(Boolean);

            function isDesktop() {
                return window.matchMedia('(min-width: 1100px)').matches;
            }

            function setTocOpen(open) {
                document.body.classList.toggle('toc-open', open);
                tocToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                tocBackdrop.hidden = !open || isDesktop();
            }

            function syncDesktopToc() {
                if (isDesktop()) {
                    setTocOpen(true);
                    tocBackdrop.hidden = true;
                } else {
                    setTocOpen(false);
                }
            }

            tocToggle.addEventListener('click', () => {
                setTocOpen(!document.body.classList.contains('toc-open'));
            });
            tocClose.addEventListener('click', () => setTocOpen(false));
            tocBackdrop.addEventListener('click', () => setTocOpen(false));
            tocLinks.forEach((link) => {
                link.addEventListener('click', () => {
                    if (!isDesktop()) setTocOpen(false);
                });
            });

            const contentObserver = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) entry.target.classList.add('visible');
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('.article-content > *').forEach((el) => contentObserver.observe(el));

            const progressBar = document.querySelector('.reading-progress-bar');
            const scrollTopBtn = document.querySelector('.scroll-to-top');

            function onScroll() {
                const windowHeight = window.innerHeight;
                const documentHeight = document.documentElement.scrollHeight;
                const scrollTop = window.scrollY;
                const denom = Math.max(documentHeight - windowHeight, 1);
                progressBar.style.width = `${(scrollTop / denom) * 100}%`;
                scrollTopBtn.classList.toggle('show', scrollTop > 300);

                let current = sections[0];
                for (const section of sections) {
                    if (section.getBoundingClientRect().top <= 120) current = section;
                }
                tocLinks.forEach((link) => {
                    link.classList.toggle('is-active', current && link.getAttribute('href') === `#${current.id}`);
                });
            }

            window.addEventListener('scroll', onScroll, { passive: true });
            window.addEventListener('resize', syncDesktopToc);
            syncDesktopToc();
            onScroll();
        });
    </script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(portForwardingGuide[locale].article.buttons.closeAd) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>