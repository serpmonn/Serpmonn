---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/ecology/product-footprint-calculator.html{% else %}/frontend/{{ locale }}/tools/ecology/product-footprint-calculator.html{% endif %}"
eleventyComputed:
  title: "{{ productFootprintCalculator[locale].title }}"
  description: "{{ productFootprintCalculator[locale].meta_description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/ecology/product-footprint-calculator.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/ecology/product-footprint-calculator.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <meta name="keywords" content="{{ productFootprintCalculator[locale].meta_keywords }}">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ productFootprintCalculator[locale].og_title }}">
    <meta property="og:description" content="{{ productFootprintCalculator[locale].og_description }}">
    <meta property="og:image" content="{{ productFootprintCalculator[locale].og_image }}">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ productFootprintCalculator[locale].og_title }}">
    <meta name="twitter:description" content="{{ productFootprintCalculator[locale].og_description }}">
    <meta name="twitter:image" content="{{ productFootprintCalculator[locale].og_image }}">

    <!-- VKontakte -->
    <meta property="vk:title" content="{{ productFootprintCalculator[locale].vk_title }}">
    <meta property="vk:description" content="{{ productFootprintCalculator[locale].vk_description }}">
    <meta property="vk:image" content="{{ productFootprintCalculator[locale].vk_image }}">
    
    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    
    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />
    
    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
      {% if loc == 'ru' %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/ecology/product-footprint-calculator.html" hreflang="{{ loc }}" />
      {% else %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/ecology/product-footprint-calculator.html" hreflang="{{ loc }}" />
      {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/ecology/product-footprint-calculator.html" hreflang="x-default" />

    <!-- JSON-LD: WebApplication -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "{{ productFootprintCalculator[locale].header.title }}",
      "description": "{{ productFootprintCalculator[locale].meta_description }}",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Any",
      "url": "{{ canonical }}",
      "author": {
        "@type": "Organization",
        "name": "Serpmonn"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
    </script>

    <!-- JSON-LD: BreadcrumbList -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "{{ productFootprintCalculator[locale].breadcrumbs.home }}",
          "item": "{{ site.baseUrl }}/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ productFootprintCalculator[locale].breadcrumbs.tools }}",
          "item": "{{ site.baseUrl }}/frontend/tools/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ productFootprintCalculator[locale].breadcrumbs.current }}"
        }
      ]
    }
    </script>

    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/styles/tools/product-footprint-calculator.css?v=4">
    
    <!-- Mail.ru Advertising -->
    <script async src="https://ad.mail.ru/static/ads-async.js"></script>
</head>
<body class="product-calculator">
    <div id="menuContainer"></div>

    <div class="container">
        <div class="header">
            <h1>{{ productFootprintCalculator[locale].header.title }}</h1>
            <p>{{ productFootprintCalculator[locale].header.subtitle }}</p>
        </div>

        <div class="calculator-card">
            <h2 class="section-title">
                {{ productFootprintCalculator[locale].calculator.section_title }}
            </h2>

            <div id="error-message" class="error-message hidden" role="alert"></div>
            
            <div id="products-container">
                <!-- Продукты будут загружены JavaScript -->
            </div>
            
            <button type="button" class="add-product-btn" onclick="addProductRow()">
                {{ productFootprintCalculator[locale].buttons.add_product }}
            </button>

            <div class="action-bar">
                <button type="button" class="calculate-btn" id="btn-eco-calculate">
                    {{ productFootprintCalculator[locale].buttons.calculate }}
                </button>
                <details class="more-actions">
                    <summary>{{ productFootprintCalculator[locale].buttons.more if productFootprintCalculator[locale].buttons.more else 'Ещё' }}</summary>
                    <div class="more-actions__list">
                        <button type="button" id="btn-eco-reset">{{ productFootprintCalculator[locale].buttons.reset if productFootprintCalculator[locale].buttons.reset else 'Сбросить' }}</button>
                        <button type="button" id="btn-eco-share">{{ productFootprintCalculator[locale].buttons.share_link if productFootprintCalculator[locale].buttons.share_link else 'Поделиться расчётом' }}</button>
                        <button type="button" id="btn-eco-pdf">{{ productFootprintCalculator[locale].buttons.pdf if productFootprintCalculator[locale].buttons.pdf else 'Экспорт PDF' }}</button>
                        <button type="button" id="btn-eco-csv">{{ productFootprintCalculator[locale].buttons.csv if productFootprintCalculator[locale].buttons.csv else 'Экспорт CSV' }}</button>
                    </div>
                </details>
            </div>

            <details class="optional-fields">
                <summary>{{ productFootprintCalculator[locale].calculator.optional_summary if productFootprintCalculator[locale].calculator.optional_summary else 'Дополнительно' }}</summary>
                <div class="optional-grid">
                    <label for="eco-region">{{ productFootprintCalculator[locale].calculator.region_label if productFootprintCalculator[locale].calculator.region_label else 'Регион происхождения' }}
                        <select id="eco-region">
                            <option value="local">{{ productFootprintCalculator[locale].calculator.region_local if productFootprintCalculator[locale].calculator.region_local else 'Местные' }}</option>
                            <option value="regional">{{ productFootprintCalculator[locale].calculator.region_regional if productFootprintCalculator[locale].calculator.region_regional else 'Региональные' }}</option>
                            <option value="national" selected>{{ productFootprintCalculator[locale].calculator.region_national if productFootprintCalculator[locale].calculator.region_national else 'По стране' }}</option>
                            <option value="international">{{ productFootprintCalculator[locale].calculator.region_international if productFootprintCalculator[locale].calculator.region_international else 'Импорт' }}</option>
                        </select>
                    </label>
                    <label for="eco-season">{{ productFootprintCalculator[locale].calculator.season_label if productFootprintCalculator[locale].calculator.season_label else 'Сезонность' }}
                        <select id="eco-season">
                            <option value="in_season" selected>{{ productFootprintCalculator[locale].calculator.season_in if productFootprintCalculator[locale].calculator.season_in else 'В сезоне' }}</option>
                            <option value="out_of_season">{{ productFootprintCalculator[locale].calculator.season_out if productFootprintCalculator[locale].calculator.season_out else 'Вне сезона' }}</option>
                            <option value="greenhouse">{{ productFootprintCalculator[locale].calculator.season_greenhouse if productFootprintCalculator[locale].calculator.season_greenhouse else 'Теплица' }}</option>
                        </select>
                    </label>
                </div>
            </details>
        </div>

        <div id="results-section" class="results-section">
            <h2 class="section-title">
                {{ productFootprintCalculator[locale].results.title }}
            </h2>
            <div class="result-hero">
                <div class="result-value" id="carbon-footprint-hero">0</div>
                <div class="result-label">{{ productFootprintCalculator[locale].results.carbon_label }}</div>
            </div>
            <p class="result-disclaimer">{{ productFootprintCalculator[locale].results.disclaimer if productFootprintCalculator[locale].results.disclaimer else 'Ориентировочный расчёт экологического следа, не лабораторный анализ.' }}</p>
            
            <div class="results-grid">
                <div class="result-card">
                    <div class="result-value" id="carbon-footprint">0</div>
                    <div class="result-label">{{ productFootprintCalculator[locale].results.carbon_label }}</div>
                </div>
                <div class="result-card">
                    <div class="result-value" id="water-footprint">0</div>
                    <div class="result-label">{{ productFootprintCalculator[locale].results.water_label }}</div>
                </div>
                <div class="result-card">
                    <div class="result-value" id="land-footprint">0</div>
                    <div class="result-label">{{ productFootprintCalculator[locale].results.land_label }}</div>
                </div>
                <div class="result-card">
                    <div class="result-value" id="eco-score">0</div>
                    <div class="result-label">{{ productFootprintCalculator[locale].results.eco_score_label }}</div>
                </div>
            </div>

            <canvas id="ecoChart" style="max-height:280px;margin:16px 0;width:100%;"></canvas>
            
            <!-- Рекламный блок - баннер -->
            <div class="ad-container ad-banner" style="margin: 20px 0; text-align: center;">
                <ins class="mrg-tag" 
                    style="display:inline-block;width:728px;height:90px" 
                    data-ad-client="ad-{{ mailAds.slots.top.id }}" 
                    data-ad-slot="{{ mailAds.slots.top.id }}">
                </ins>
            </div>

            <div class="comparison-section">
                <h3 class="comparison-title">{{ productFootprintCalculator[locale].comparison.title }}</h3>
                <div id="comparison-results"></div>
            </div>

            <div class="recommendations">
                <h3>{{ productFootprintCalculator[locale].recommendations.title }}</h3>
                <div id="recommendations-list"></div>
            </div>
            
            <!-- Рекламный блок - квадрат -->
            <div class="ad-container" style="margin: 20px 0; text-align: center;">
                <ins class="mrg-tag" 
                    style="display:inline-block;width:300px;height:250px" 
                    data-ad-client="ad-{{ mailAds.slots.top.id }}" 
                    data-ad-slot="{{ mailAds.slots.top.id }}">
                </ins>
            </div>

            <div class="share-buttons">
                <a class="share-btn vk" href="https://vk.com/share.php?url={{ canonical | urlencode }}" target="_blank" rel="noopener">
                    {{ productFootprintCalculator[locale].buttons.share_vk }}
                </a>
                <a class="share-btn telegram" href="https://t.me/share/url?url={{ canonical | urlencode }}&text={{ productFootprintCalculator[locale].header.title | urlencode }}" target="_blank" rel="noopener">
                    {{ productFootprintCalculator[locale].buttons.share_telegram }}
                </a>
            </div>
        </div>
    </div>

    <script src="/frontend/tools/ecology/database.js?v=3"></script>
    <script src="/frontend/tools/ecology/calculator.js?v=4"></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    
    <!-- Mail.ru Advertising Script -->
<!-- Инициализация переводов для JS -->
    <script>
        // Экспортируем переводы для использования в JavaScript
        window.i18n = {{ productFootprintCalculator[locale] | dump | safe }};
        
        // Инициализация калькулятора после загрузки переводов
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof initProductCalculator === 'function') {
                initProductCalculator();
            } else if (window.ecoCalculator === undefined && typeof EcoFootprintCalculator !== 'undefined') {
                window.ecoCalculator = new EcoFootprintCalculator();
            }
        });
    </script>
    
    <!-- Скрипты для рекламы -->
<script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(productFootprintCalculator[locale].ads.closeAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>