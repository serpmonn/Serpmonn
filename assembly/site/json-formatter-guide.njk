---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/json-formatter-guide.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/json-formatter-guide.html{% endif %}"
eleventyComputed:
  title: "{{ jsonFormatterGuide[locale].title }}"
  description: "{{ jsonFormatterGuide[locale].description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/json-formatter-guide.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/json-formatter-guide.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <title>{{ title }}</title>
    <meta charset="UTF-8">
    <meta name="description" content="{{ description }}">
    <meta name="viewport" content="width=device-width, height=device-height, minimum-scale=0.5, initial-scale=1, maximum-scale=3, user-scalable=yes">

    <meta property="og:title" content="{{ jsonFormatterGuide[locale].title }}">
    <meta property="og:description" content="{{ jsonFormatterGuide[locale].ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ jsonFormatterGuide[locale].title }}">
    <meta name="twitter:description" content="{{ jsonFormatterGuide[locale].twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "{{ jsonFormatterGuide[locale].title | replace('"', '&quot;') }}",
      "description": "{{ jsonFormatterGuide[locale].description | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2026-07-21",
      "dateModified": "2026-07-21",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "author": { "@type": "Organization", "name": "Serpmonn", "url": "{{ site.baseUrl }}" },
      "publisher": {
        "@type": "Organization",
        "name": "Serpmonn",
        "url": "{{ site.baseUrl }}",
        "logo": { "@type": "ImageObject", "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3" }
      }
    }
    </script>

    <link rel="canonical" href="{{ canonical }}" />
    {% for loc in locales %}
      {% if loc == 'ru' %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/json-formatter-guide.html" hreflang="{{ loc }}" />
      {% else %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/knowledge-base/articles/json-formatter-guide.html" hreflang="{{ loc }}" />
      {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/json-formatter-guide.html" hreflang="x-default" />

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <style>
      body { max-width: 800px; margin: 0 auto; padding: 16px; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; background: #f3f4f6; line-height: 1.7; color: #111827; }
      article { background: #fff; border-radius: 16px; padding: 28px; margin: 16px auto; border: 1px solid #e5e7eb; box-shadow: 0 8px 28px rgba(15,23,42,.06); }
      .article-header { margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #e5e7eb; }
      .article-title { font-size: 1.7rem; margin: 0 0 8px; font-weight: 700; }
      .article-date { color: #6b7280; font-size: 0.95rem; }
      .summary { background: #fef2f2; border: 1px solid #fecaca; border-left: 4px solid #dc3545; border-radius: 12px; padding: 14px; margin: 16px 0; color: #7f1d1d; }
      .toc { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px; margin: 16px 0; }
      .toc a { color: #dc3545; text-decoration: none; font-weight: 600; }
      .toc a:hover { text-decoration: underline; }
      h2 { margin-top: 28px; font-size: 1.2rem; }
      .code, code { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px; padding: 2px 6px; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: .92rem; }
      .note { background: #fffbeb; border: 1px solid #fde68a; border-radius: 12px; padding: 12px; margin: 16px 0; color: #92400e; }
      .faq { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px; }
      .faq h3 { margin: 12px 0 6px; font-size: 1rem; }
      .faq h3:first-child { margin-top: 0; }
      .article-cta {
        display: inline-block;
        padding: 10px 16px;
        background: #dc3545;
        color: #fff !important;
        text-decoration: none !important;
        border-radius: 8px;
        font-weight: 600;
      }
      .article-cta:hover,
      .article-cta:visited {
        color: #fff !important;
        background: #c82333;
      }
    </style>
</head>
<body>
    <div id="menuContainer"></div>

    <article>
        <header class="article-header">
            <div class="ad-top-banner ad-banner loading">
                <ins class="mrg-tag"
                    style="display:inline-block;"
                    data-ad-client="ad-{{ mailAds.slots.top.id }}"
                    data-ad-slot="{{ mailAds.slots.top.id }}">
                </ins>
            </div>
            <h1 class="article-title">{{ jsonFormatterGuide[locale].articleTitle }}</h1>
            <div class="article-date">{{ jsonFormatterGuide[locale].articleDate }}</div>
        </header>

        <div class="summary">
            <strong>{{ jsonFormatterGuide[locale].summaryTitle }}</strong> {{ jsonFormatterGuide[locale].summaryContent }}
        </div>

        <div class="toc">
            <strong>{{ jsonFormatterGuide[locale].tocTitle }}</strong>
            <ol>
              {%- set anchors = ['what', 'why', 'modes', 'mistakes', 'howto', 'faq'] -%}
              {%- for item in jsonFormatterGuide[locale].tocItems -%}
              <li><a href="#{{ anchors[loop.index0] }}">{{ item }}</a></li>
              {%- endfor -%}
            </ol>
        </div>

        <h2 id="what">{{ jsonFormatterGuide[locale].section1Title }}</h2>
        <p>{{ jsonFormatterGuide[locale].section1Content | safe }}</p>

        <h2 id="why">{{ jsonFormatterGuide[locale].section2Title }}</h2>
        <ul>
          {%- for item in jsonFormatterGuide[locale].section2List -%}
          <li>{{ item | safe }}</li>
          {%- endfor -%}
        </ul>

        <h2 id="modes">{{ jsonFormatterGuide[locale].section3Title }}</h2>
        <ul>
          {%- for item in jsonFormatterGuide[locale].section3List -%}
          <li>{{ item | safe }}</li>
          {%- endfor -%}
        </ul>
        <div class="note">{{ jsonFormatterGuide[locale].section3Note | safe }}</div>

        <h2 id="mistakes">{{ jsonFormatterGuide[locale].section4Title }}</h2>
        <ul>
          {%- for item in jsonFormatterGuide[locale].section4List -%}
          <li>{{ item | safe }}</li>
          {%- endfor -%}
        </ul>

        <h2 id="howto">{{ jsonFormatterGuide[locale].section5Title }}</h2>
        <ul>
          {%- for item in jsonFormatterGuide[locale].section5List -%}
          <li>{{ item | safe }}</li>
          {%- endfor -%}
        </ul>
        <p>{{ jsonFormatterGuide[locale].section5CtaText }}</p>
        <p>
          <a class="article-cta" href="{% if locale == 'ru' %}/frontend/tools/development/json-formatter.html{% else %}/frontend/{{ locale }}/tools/development/json-formatter.html{% endif %}">
            {{ jsonFormatterGuide[locale].section5CtaButton }}
          </a>
        </p>

        <h2 id="faq">{{ jsonFormatterGuide[locale].section6Title }}</h2>
        <div class="faq">
          {%- for item in jsonFormatterGuide[locale].faqItems -%}
          <h3>{{ item.question }}</h3>
          <p>{{ item.answer | safe }}</p>
          {%- endfor -%}
        </div>
    </article>

    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(jsonFormatterGuide[locale].ads.closeAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
