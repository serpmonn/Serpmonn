---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/findings/feed.html{% else %}/frontend/{{ locale }}/findings/feed.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  title: "{{ findingPageI18n[locale].feedTitle }} — Serpmonn"
  feedTitle: "{{ findingPageI18n[locale].feedTitle }}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{{ title }}</title>
  <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/profile/profile_styles.css">
  <link rel="stylesheet" href="/frontend/find/find-view.css">
  <script type="module" src="/frontend/findings/findings-feed.js" defer></script>
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
<div class="page-wrapper">
  <main class="container" role="main">
    <section class="card finding-inbox-card" aria-labelledby="findings-feed-title">
      <h1 id="findings-feed-title">{{ feedTitle }}</h1>
      <p id="findings-feed-hint" class="finding-inbox-subtitle"></p>
      <div id="findings-feed-list" class="findings-inbox-list" aria-live="polite">
        <p class="plan-hint">…</p>
      </div>
    </section>
  </main>
</div>
<script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
