---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/updates-august-17.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/updates-august-17.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  title: "{{ updatesAugust17[locale].meta.title }}"
  description: "{{ updatesAugust17[locale].meta.ogDescription }}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/updates-august-17.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/updates-august-17.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    
    <meta property="og:title" content="{{ updatesAugust17[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ updatesAugust17[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">
    
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ updatesAugust17[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ updatesAugust17[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "headline": "{{ updatesAugust17[locale].jsonld.headline | replace('"', '&quot;') }}",
      "description": "{{ updatesAugust17[locale].jsonld.description | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2025-08-17",
      "dateModified": "2025-08-17",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "author": {
        "@type": "Organization",
        "name": "Serpmonn"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Serpmonn",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "{{ updatesAugust17[locale].breadcrumbs.home }}", "item": "{{ site.baseUrl }}/"},
        {"@type": "ListItem", "position": 2, "name": "{{ updatesAugust17[locale].breadcrumbs.news }}", "item": "{{ site.baseUrl }}/frontend/knowledge-base/knowledge-base.html"},
        {"@type": "ListItem", "position": 3, "name": "{{ updatesAugust17[locale].breadcrumbs.current }}"}
      ]
    }
    </script>

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="/frontend/styles/articles/article-chrome.css">
    <link rel="stylesheet" href="/frontend/styles/articles/updates-august-17.css">
</head>
<body class="article-page">
    {% set tocTitle = locale | articleTocTitle %}
    {% set tocItems = [
      { href: '#section-summary', label: updatesAugust17[locale].summary.title },
      { href: '#section-drivers', label: updatesAugust17[locale].sections.drivers.title },
      { href: '#section-engineers', label: updatesAugust17[locale].sections.engineers.title },
      { href: '#section-platform', label: updatesAugust17[locale].sections.platform.title },
      { href: '#section-performance', label: updatesAugust17[locale].sections.performance.title },
      { href: '#section-bugfixes', label: updatesAugust17[locale].sections.bugfixes.title }
    ] %}
    {% include "partials/article-floating-toc.njk" %}

    <div id="menuContainer"></div>

    <article class="article-container" tabindex="0">
      <header class="article-header">
        <div class="ad-top-banner ad-banner loading">
          <ins class="mrg-tag"
              style="display:inline-block;"
              data-ad-client="ad-{{ mailAds.slots.top.id }}"
              data-ad-slot="{{ mailAds.slots.top.id }}">
          </ins>
        </div>
        <h1 class="article-title">{{ updatesAugust17[locale].article.title }}</h1>
        <div class="article-date">{{ updatesAugust17[locale].article.date }}</div>
      </header>

      <div class="article-content">
        <div class="summary" id="section-summary">
          <h3>{{ updatesAugust17[locale].summary.title }}</h3>
          <p>{{ updatesAugust17[locale].summary.text }}</p>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number">3</div>
            <div class="stat-label">{{ updatesAugust17[locale].stats.newTools }}</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">15+</div>
            <div class="stat-label">{{ updatesAugust17[locale].stats.bugFixes }}</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">8</div>
            <div class="stat-label">{{ updatesAugust17[locale].stats.uxImprovements }}</div>
          </div>
        </div>

        <div class="update-section">
          <h3 id="section-drivers">{{ updatesAugust17[locale].sections.drivers.title }}</h3>
          <ul class="feature-list">
            {% for item in updatesAugust17[locale].sections.drivers.items %}
            <li>{{ item | safe }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="update-section">
          <h3 id="section-engineers">{{ updatesAugust17[locale].sections.engineers.title }}</h3>
          <ul class="feature-list">
            {% for item in updatesAugust17[locale].sections.engineers.items %}
            <li>{{ item | safe }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="update-section">
          <h3 id="section-platform">{{ updatesAugust17[locale].sections.platform.title }}</h3>
          <ul class="feature-list">
            {% for item in updatesAugust17[locale].sections.platform.items %}
            <li>{{ item | safe }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="update-section">
          <h3 id="section-performance">{{ updatesAugust17[locale].sections.performance.title }}</h3>
          <ul class="feature-list">
            {% for item in updatesAugust17[locale].sections.performance.items %}
            <li>{{ item | safe }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="bug-fix">
          <h4 id="section-bugfixes">{{ updatesAugust17[locale].sections.bugfixes.title }}</h4>
          <ul class="feature-list">
            {% for item in updatesAugust17[locale].sections.bugfixes.items %}
            <li>{{ item | safe }}</li>
            {% endfor %}
          </ul>
        </div>

        <div class="social-share">
          <a class="share-btn vk" href="https://vk.com/share.php?url={{ site.baseUrl }}{{ page.url | urlencode }}" target="_blank" rel="noopener">{{ updatesAugust17[locale].share.vk }}</a>
          <a class="share-btn telegram" href="https://t.me/share/url?url={{ site.baseUrl }}{{ page.url | urlencode }}&text={{ updatesAugust17[locale].article.title | urlencode }}" target="_blank" rel="noopener">{{ updatesAugust17[locale].share.telegram }}</a>
        </div>

        {% set relatedTitle = locale | articleRelatedTitle %}
        {% set relatedItems = 'updates-august-17' | articleRelated(locale) %}
        {% include "partials/article-related.njk" %}
      </div>
    </article>

    <button class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="↑">↑</button>

    {% include "partials/article-chrome-scripts.njk" %}
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
    {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
    {{ mobileAnchor(updatesAugust17[locale].ads.closeAria) }}
    {% include "partials/ad-pool-init.njk" %}
</body>
</html>
