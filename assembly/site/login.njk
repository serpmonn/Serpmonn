---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/login/login.html{% else %}/frontend/{{ locale }}/login/login.html{% endif %}"
eleventyComputed:
  authUrl: "{% if locale == 'ru' %}/frontend/auth/auth.html{% else %}/frontend/{{ locale }}/auth/auth.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redirecting…</title>
    <link rel="canonical" href="{{ authUrl }}?tab=login">
    <script>
        (function () {
            var params = new URLSearchParams(window.location.search);
            params.set('tab', 'login');
            var target = '{{ authUrl }}?' + params.toString();
            window.location.replace(target);
        })();
    </script>
    <noscript>
        <meta http-equiv="refresh" content="0;url={{ authUrl }}?tab=login">
    </noscript>
</head>
<body>
    <p><a href="{{ authUrl }}?tab=login">Continue to sign in</a></p>
</body>
</html>
