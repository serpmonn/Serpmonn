---
pagination:
  data: locales
  size: 1
  alias: locale  # ИСПРАВЛЕНО: lang → locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/knowledge-base.html{% else %}/frontend/{{ locale }}/knowledge-base/knowledge-base.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/knowledge-base.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/knowledge-base.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <!-- Подключение стилей -->
  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/base.css">
  <link rel="stylesheet" href="/frontend/styles/menu.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/knowledge-base/knowledge-base.css">
  
  <!-- Мета-теги для SEO и социальных сетей -->
  <meta http-equiv="Content-Language" content="{{ locale }}">  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ localesNews[locale].news.title }}</title>  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta name="description" content="{{ localesNews[locale].news.metaDescription }}">  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta name="keywords" content="{{ localesNews[locale].news.keywords }}">  <!-- ИСПРАВЛЕНО: lang → locale -->

  <!-- Yandex.Metrika counter -->
  <script type="text/javascript">
      (function(m,e,t,r,i,k,a){
          m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
          m[i].l=1*new Date();
          for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
          k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=108618472', 'ym');

      ym(108618472, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
  </script>
  <noscript><div><img src="https://mc.yandex.ru/watch/108618472&quot; style="position:absolute; left:-9999px;" alt="" /></div></noscript>
  <!-- /Yandex.Metrika counter -->

  <!-- Open Graph для соцсетей -->
  <meta property="og:title" content="{{ localesNews[locale].news.ogTitle }}">  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta property="og:description" content="{{ localesNews[locale].news.ogDescription }}">  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:type" content="website">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ localesNews[locale].news.twitterTitle }}">  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta name="twitter:description" content="{{ localesNews[locale].news.twitterDescription }}">  <!-- ИСПРАВЛЕНО: lang → locale -->
  <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

  <!-- Каноническая ссылка -->
  <link rel="canonical" href="{{ canonical }}" />

  <!-- Hreflang для всех языков -->
  {% for loc in locales %}
    {% if loc == 'ru' %}
      <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/knowledge-base.html" hreflang="{{ loc }}" />
    {% else %}
      <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/knowledge-base/knowledge-base.html" hreflang="{{ loc }}" />
    {% endif %}
  {% endfor %}
  <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/knowledge-base.html" hreflang="x-default" />

  <!-- Schema.org разметка -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "{{ localesNews[locale].news.heroTitle }}",  <!-- ИСПРАВЛЕНО: lang → locale -->
    "description": "{{ localesNews[locale].news.metaDescription }}",  <!-- ИСПРАВЛЕНО: lang → locale -->
    "inLanguage": "{{ locale }}",  <!-- ИСПРАВЛЕНО: lang → locale -->
    "publisher": {
      "@type": "Organization",
      "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}",
      "logo": {"@type": "ImageObject", "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"}
    },
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": [
        {% for article in localesNews[locale].news.articles %}  <!-- ИСПРАВЛЕНО: lang → locale -->
        {
          "@type": "ListItem",
          "position": {{ loop.index }},
          "item": {
            "@type": "Article",
            "headline": "{{ article.title }}",
            "description": "{{ article.excerpt }}",
            "datePublished": "{{ article.date }}",
            "inLanguage": "{{ locale }}",  <!-- ИСПРАВЛЕНО: lang → locale -->
            "url": "{% if locale == 'ru' %}{{ site.baseUrl }}{{ article.link }}{% else %}{{ site.baseUrl }}/{{ locale }}{{ article.link }}{% endif %}"  <!-- ИСПРАВЛЕНО: lang → locale -->
          }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  }
  </script>

  <!-- RSS лента (если нужен общий для всех языков, оставляем так) -->
  <link rel="alternate" type="application/rss+xml" title="RSS базы знаний Серпмонн" href="/frontend/knowledge-base/rss.xml">
  <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
  <script async src="https://ad.mail.ru/static/ads-async.js"></script>
</head>
<body>
  <!-- Контейнер для меню -->
  <div id="menuContainer"></div>
  
  <!-- Основной контент страницы -->
  <div class="page">
    <div class="ad-top-banner loading">
      <ins class="mrg-tag"
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}"
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>

    <!-- Компактный заголовок -->
    <div class="news-header news-header--compact">
      <h1 class="news-title">{{ localesNews[locale].news.heroTitle }}</h1>
      <p class="news-subtitle">{{ localesNews[locale].news.heroSubtitle }}</p>
      <div class="kb-subscribe" role="group" aria-label="{{ localesNews[locale].news.rssTitle }}">
        <a class="kb-subscribe__link" href="/frontend/knowledge-base/rss.xml" target="_blank" rel="noopener" aria-label="{{ localesNews[locale].news.rssButton }}">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><circle cx="6.2" cy="17.8" r="2.2"/><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>
        </a>
        <a class="kb-subscribe__link" href="https://t.me/serpmonn" target="_blank" rel="noopener" aria-label="{{ localesNews[locale].news.telegramButton }}">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8l-1.68 7.92c-.12.56-.46.7-.93.44l-2.58-1.9-1.24 1.2c-.14.14-.26.26-.52.26l.18-2.6 4.74-4.28c.2-.18-.04-.28-.32-.1L7.92 13.8l-2.52-.79c-.54-.17-.56-.54.12-.8l9.84-3.8c.46-.16.86.11.28.39z"/></svg>
        </a>
        <a class="kb-subscribe__link" href="https://vk.com/serpmonn_site" target="_blank" rel="noopener" aria-label="{{ localesNews[locale].news.vkButton }}">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M13.162 18.994c.609 0 .85-.407.84-1.024-.032-1.82.614-2.737 2.066-1.26 1.64 1.67 1.986 2.284 3.408 2.284h2.742c.814 0 1.143-.27.95-.8-.48-1.327-4.297-5.17-4.056-5.512.222-.317 3.347-4.596 3.604-5.664.13-.54-.1-.8-.72-.8H18.22c-.69 0-.91.38-1.14.96-1.048 2.7-2.86 5.073-3.57 4.633-.69-.424-.52-2.686-.484-4.252.02-.75.013-1.557-.746-1.738-.518-.124-1.26-.108-1.76-.108-1.47 0-2.67.5-2.018 1.36.49.643.637 1.934.44 4.26-.26 3.117-3.148-.95-4.29-4.17-.285-.81-.567-1.25-1.3-1.25H1.616c-.777 0-.932.366-.72.972 1.37 3.956 5.87 12.638 12.266 12.11z"/></svg>
        </a>
      </div>
    </div>

    <!-- Навигация по категориям -->
    <div class="news-categories">
      {% for category in localesNews[locale].news.categories %}  <!-- ИСПРАВЛЕНО: lang → locale -->
      <a class="category-link {% if category.key == 'all' %}active{% endif %}" 
         href="{% if locale == 'ru' %}/frontend/knowledge-base/knowledge-base.html{% else %}/frontend/{{ locale }}/knowledge-base/knowledge-base.html{% endif %}?category={{ category.key }}" 
         data-category="{{ category.key }}">
        {{ category.name }}
      </a>
      {% endfor %}
    </div>

    <!-- Поиск по новостям -->
    <div class="search-box">
      <input type="text" class="search-input" placeholder="{{ localesNews[locale].news.searchPlaceholder }}" id="searchInput">  <!-- ИСПРАВЛЕНО: lang → locale -->
      <div class="search-suggestions" id="searchSuggestions"></div>
    </div>

    <!-- Индикатор загрузки -->
    <div class="loading-indicator" id="loadingIndicator" style="display: none;">
      <p>{{ localesNews[locale].news.loadingText }}</p>  <!-- ИСПРАВЛЕНО: lang → locale -->
    </div>

    <!-- Сетка карточек новостей -->
    <div class="news-grid" id="newsGrid">
      {% for article in localesNews[locale].news.articles %}  <!-- ИСПРАВЛЕНО: lang → locale -->
      <div class="news-card" data-category="{{ article.category }}" data-tags="{{ article.tags }}">
        <div class="news-card-content">
          <span class="news-card-category">{{ article.categoryLabel }}</span>
          <h3 class="news-card-title">{{ article.title }}</h3>
          <p class="news-card-excerpt">{{ article.excerpt }}</p>
          <div class="news-card-meta">
            <span class="news-card-date">{{ article.date }}</span>
            <span class="news-card-read-time">{{ article.readTime }}</span>
          </div>
          <div class="news-card-share">
            <button type="button"
                    class="kb-share-button"
                    data-share-url="{{ site.baseUrl }}{{ article.link }}"
                    data-share-title="{{ article.title | escape }}"
                    aria-label="{{ localesNews[locale].news.shareAria }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="2.5"/><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="19" r="2.5"/><path d="m8.5 13.5 7 4"/><path d="m15.5 6.5-7 4"/></svg>
            </button>
          </div>
        </div>
        <a class="news-card-link" href="{{ article.link }}" aria-label="{{ article.ariaLabel }}"></a>
      </div>
      {% endfor %}
    </div>

    <!-- Кнопка загрузки дополнительных новостей -->
    <div class="load-more" id="loadMore">
      <button class="load-more-btn">{{ localesNews[locale].news.loadMoreButton }}</button>  <!-- ИСПРАВЛЕНО: lang → locale -->
    </div>
  </div>

  <!-- Подключение JavaScript файлов -->
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
  <script type="module" src="/frontend/knowledge-base/knowledge-base.js?v=4" defer></script>
  <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(localesNews[locale].news.closeAd) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>