---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/marketing/utm-builder.html{% else %}/frontend/{{ locale }}/tools/marketing/utm-builder.html{% endif %}"
eleventyComputed:
  title: "{{ utmBuilder[locale].meta.title }}"
  description: "{{ utmBuilder[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/marketing/utm-builder.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/marketing/utm-builder.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ utmBuilder[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ utmBuilder[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ utmBuilder[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ utmBuilder[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        <link rel="alternate" href="{{ canonical | replace('/' + locale + '/', '/' + loc + '/') }}" hreflang="{{ loc }}" />
    {% endfor %}
    <link rel="alternate" href="{{ canonical | replace('/' + locale + '/', '/ru/') }}" hreflang="x-default" />

        <!-- Structured Data: SoftwareApplication -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "{{ utmBuilder[locale].meta.title | replace('"', '&quot;') }}",
      "description": "{{ utmBuilder[locale].meta.description | replace('"', '&quot;') }}",
      "url": "{{ canonical }}",
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Web",
      "inLanguage": "{{ locale }}",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "RUB"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Serpmonn",
        "url": "{{ site.baseUrl }}/"
      }
    }
    </script>
<link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/styles/tools/tools-shell.css?v=3">
  </head>
  <body class="spn-tool utm-builder-page">
    <div id="menuContainer"></div>

    <script async src="https://ad.mail.ru/static/ads-async.js"></script>
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag"
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}"
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>

    <h1>{{ utmBuilder[locale].page.title }}</h1>
    {% if utmBuilder[locale].page.lead %}
    <p class="tool-lead">{{ utmBuilder[locale].page.lead }}</p>
    {% endif %}

    <div class="calculator-container">
      <h2>{{ utmBuilder[locale].page.formTitle if utmBuilder[locale].page.formTitle else 'Параметры UTM' }}</h2>
      <div id="error-message" class="error-message hidden" role="alert"></div>

      <div class="input-section">
        <div class="input-group">
          <label for="base">{{ utmBuilder[locale].page.fields.baseUrl }}</label>
          <input id="base" placeholder="{{ utmBuilder[locale].page.placeholders.baseUrl }}" />
        </div>
        <div class="input-group">
          <label for="source">utm_source</label>
          <input id="source" placeholder="{{ utmBuilder[locale].page.placeholders.source }}" />
        </div>
        <div class="input-group">
          <label for="medium">utm_medium</label>
          <input id="medium" placeholder="{{ utmBuilder[locale].page.placeholders.medium }}" />
        </div>
        <div class="input-group">
          <label for="campaign">utm_campaign</label>
          <input id="campaign" placeholder="{{ utmBuilder[locale].page.placeholders.campaign }}" />
        </div>
      </div>

      <div class="action-bar">
        <button type="button" class="calculate-btn" id="btn-build">{{ utmBuilder[locale].page.buttons.generate }}</button>
        <details class="more-actions">
          <summary>{{ utmBuilder[locale].page.actions.more if utmBuilder[locale].page.actions else 'Ещё' }}</summary>
          <div class="more-actions__list">
            <button type="button" id="btn-copy">{{ utmBuilder[locale].page.buttons.copy }}</button>
            <button type="button" id="btn-reset">{{ utmBuilder[locale].page.actions.reset if utmBuilder[locale].page.actions else 'Сбросить' }}</button>
            <button type="button" id="btn-share">{{ utmBuilder[locale].page.actions.share if utmBuilder[locale].page.actions else 'Поделиться' }}</button>
          </div>
        </details>
      </div>

      <details class="optional-fields">
        <summary>{{ utmBuilder[locale].page.optionalSummary if utmBuilder[locale].page.optionalSummary else 'Дополнительно' }}</summary>
        <div class="input-section">
          <div class="input-group">
            <label for="content">utm_content</label>
            <input id="content" placeholder="{{ utmBuilder[locale].page.placeholders.content }}" />
          </div>
          <div class="input-group">
            <label for="term">utm_term</label>
            <input id="term" placeholder="{{ utmBuilder[locale].page.placeholders.term }}" />
          </div>
        </div>
      </details>

      <div class="results">
        <h3>{{ utmBuilder[locale].page.generatedLink }}</h3>
        <div class="result-hero">
          <div class="output" id="result">—</div>
        </div>
        <p class="result-disclaimer">{{ utmBuilder[locale].page.disclaimer if utmBuilder[locale].page.disclaimer else 'Ссылка собирается локально в браузере.' }}</p>
      </div>
    </div>

    <script>
      window.utmBuilderTranslations = {{ utmBuilder[locale] | dump | safe }};
    </script>
    <script type="module" src="/frontend/scripts/tools/utm-builder.js?v=1"></script>
    <script type="module" src="/frontend/scripts/tools/more-actions.js?v=1"></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(utmBuilder[locale].ads.closeAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
