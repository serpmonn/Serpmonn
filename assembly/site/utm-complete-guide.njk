---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/utm-complete-guide.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/utm-complete-guide.html{% endif %}"
eleventyComputed:
  title: "{{ utmCompleteGuide[locale].title }}"
  description: "{{ utmCompleteGuide[locale].description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/utm-complete-guide.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/utm-complete-guide.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <title>{{ title }}</title>
    <meta charset="UTF-8">
    <meta name="description" content="{{ description }}">
    <meta name="viewport" content="width=device-width, height=device-height, minimum-scale=0.5, initial-scale=1, maximum-scale=3, user-scalable=yes">

    <meta property="og:title" content="{{ utmCompleteGuide[locale].title }}">
    <meta property="og:description" content="{{ utmCompleteGuide[locale].ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ utmCompleteGuide[locale].title }}">
    <meta name="twitter:description" content="{{ utmCompleteGuide[locale].twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "{{ utmCompleteGuide[locale].title | replace('"', '&quot;') }}",
      "description": "{{ utmCompleteGuide[locale].description | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2025-09-15",
      "dateModified": "2025-09-15",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "author": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}",
        "url": "{{ site.baseUrl }}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}",
        "url": "{{ site.baseUrl }}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>

    <link rel="canonical" href="{{ canonical }}" />

    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/utm-complete-guide.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/knowledge-base/articles/utm-complete-guide.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/utm-complete-guide.html" hreflang="x-default" />

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    <link rel="stylesheet" href="/frontend/styles/articles/article-chrome.css">
    <link rel="stylesheet" href="/frontend/styles/articles/utm-complete-guide.css">
</head>
<body>
{% set anchors = ['what', 'params', 'ga4', 'naming', 'platforms', 'examples', 'mistakes', 'faq'] %}
{% set tocTitle = utmCompleteGuide[locale].tocTitle | default(locale | articleTocTitle, true) %}
{% set tocItems = [] %}
{% for item in utmCompleteGuide[locale].tocItems %}
{% set _ = tocItems.push({ href: '#' + anchors[loop.index0], label: item }) %}
{% endfor %}
{% include "partials/article-floating-toc.njk" %}

<div id="menuContainer"></div>

<article class="article-container" tabindex="0">
    <header class="article-header">
        <div class="ad-top-banner ad-banner loading">
            <ins class="mrg-tag"
                style="display:inline-block;"
                data-ad-client="ad-{{ mailAds.slots.top.id }}"
                data-ad-slot="{{ mailAds.slots.top.id }}">
            </ins>
        </div>
        <h1 class="article-title">{{ utmCompleteGuide[locale].articleTitle }}</h1>
        <div class="article-date">{{ utmCompleteGuide[locale].articleDate }}</div>
    </header>

    <div class="article-content">
        <div class="summary">
            <strong>{{ utmCompleteGuide[locale].summaryTitle }}</strong> {{ utmCompleteGuide[locale].summaryContent }}
        </div>

        <h2 id="what">{{ utmCompleteGuide[locale].section1Title }}</h2>
        <p>{{ utmCompleteGuide[locale].section1Content | safe }}</p>

        <h2 id="params">{{ utmCompleteGuide[locale].section2Title }}</h2>
        <ul>
            {%- for item in utmCompleteGuide[locale].section2List -%}
            <li>{{ item | safe }}</li>
            {%- endfor -%}
        </ul>
        <div class="note">{{ utmCompleteGuide[locale].section2Note | safe }}</div>

        <h2 id="ga4">{{ utmCompleteGuide[locale].section3Title }}</h2>
        <p>{{ utmCompleteGuide[locale].section3Content | safe }}</p>
        <ul>
            {%- for item in utmCompleteGuide[locale].section3List -%}
            <li>{{ item | safe }}</li>
            {%- endfor -%}
        </ul>

        <h2 id="naming">{{ utmCompleteGuide[locale].section4Title }}</h2>
        <ul>
            {%- for item in utmCompleteGuide[locale].section4List -%}
            <li>{{ item | safe }}</li>
            {%- endfor -%}
        </ul>

        <h2 id="platforms">{{ utmCompleteGuide[locale].section5Title }}</h2>
        <p>{{ utmCompleteGuide[locale].section5Subtitle }}</p>
        <ul>
            {%- for item in utmCompleteGuide[locale].section5List -%}
            <li>{{ item | safe }}</li>
            {%- endfor -%}
        </ul>

        <h2 id="examples">{{ utmCompleteGuide[locale].section6Title }}</h2>
        <div class="code">{{ utmCompleteGuide[locale].section6Example1 }}</div>
        <div class="code">{{ utmCompleteGuide[locale].section6Example2 }}</div>
        <p>
            {{ utmCompleteGuide[locale].section6BuilderText }}
            <a class="btn" href="{% if locale == 'ru' %}/frontend/tools/marketing/utm-builder.html{% else %}/frontend/{{ locale }}/tools/marketing/utm-builder.html{% endif %}">
                {{ utmCompleteGuide[locale].section6BuilderButton }}
            </a>
        </p>

        <h2 id="mistakes">{{ utmCompleteGuide[locale].section7Title }}</h2>
        <ul>
            {%- for item in utmCompleteGuide[locale].section7List -%}
            <li>{{ item | safe }}</li>
            {%- endfor -%}
        </ul>

        <h2 id="faq">{{ utmCompleteGuide[locale].section8Title }}</h2>
        <div class="faq">
            {%- for faq in utmCompleteGuide[locale].faqItems -%}
            <h3>{{ faq.question }}</h3>
            <p>{{ faq.answer | safe }}</p>
            {%- endfor -%}

            <h3>{{ utmCompleteGuide[locale].checklistTitle }}</h3>
            <ul>
                {%- for item in utmCompleteGuide[locale].checklistItems -%}
                <li>{{ item | safe }}</li>
                {%- endfor -%}
            </ul>
        </div>

        <p class="muted">
            {{ utmCompleteGuide[locale].updated }} 15.09.2025 • {{ utmCompleteGuide[locale].category }}
        </p>

        {% set relatedTitle = locale | articleRelatedTitle %}
        {% set relatedItems = 'utm-complete-guide' | articleRelated(locale) %}
        {% include "partials/article-related.njk" %}
    </div>
</article>

<button type="button" class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="↑">↑</button>

{% include "partials/article-chrome-scripts.njk" %}
<script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(localesNews[locale].news.closeAd) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
