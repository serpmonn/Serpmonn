---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/profile/profile.html{% else %}/frontend/{{ locale }}/profile/profile.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  title: "{{ profile[locale].profile.pageTitle }}"
  description: "{{ profile[locale].profile.metaDescription }}"
  myFindingsTitle: "{{ findingPageI18n[locale].myFindingsTitle }}"
  searchPath: "{% if locale == 'ru' %}/frontend/main.html{% else %}/frontend/{{ locale }}/index.html{% endif %}"
  tabProfile: "{{ profile[locale].profile.tabsSection.profile or 'Profile' }}"
  tabFindings: "{{ profile[locale].profile.tabsSection.findings or 'Findings' }}"
  tabPlan: "{{ profile[locale].profile.tabsSection.plan or 'Plan & points' }}"
  tabTools: "{{ profile[locale].profile.tabsSection.tools or 'Tools' }}"
  findingsSummaryTpl: "{{ profile[locale].profile.findingsSection.summary or '{total} findings · {public} in feed' }}"
  filterAll: "{{ profile[locale].profile.findingsSection.filterAll or 'All' }}"
  filterPrivate: "{{ profile[locale].profile.findingsSection.filterPrivate or 'Private' }}"
  filterPublic: "{{ profile[locale].profile.findingsSection.filterPublic or 'In feed' }}"
  filterFollowers: "{{ profile[locale].profile.findingsSection.filterFollowers or 'Followers' }}"
  goSearch: "{{ profile[locale].profile.findingsSection.goSearch or 'Go to search' }}"
  referralCompactLabel: "{{ profile[locale].profile.planSection.referralCompactLabel or 'Referral link' }}"
  exchangeToggle: "{{ profile[locale].profile.planSection.exchangeToggle or 'Exchange points for Pro' }}"
  onnmailSectionTitle: "{{ profile[locale].profile.extraSection.sectionTitle or '@onnmail email' }}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/profile/profile.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/profile/profile.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta http-equiv="Content-Language" content="{{ locale }}">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">

  <meta property="og:title" content="{{ profile[locale].profile.ogTitle }}">
  <meta property="og:description" content="{{ profile[locale].profile.ogDescription }}">
  <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:type" content="website">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ profile[locale].profile.ogTitle }}">
  <meta name="twitter:description" content="{{ profile[locale].profile.twitterDescription }}">
  <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

  <link rel="canonical" href="{{ canonical }}">

  {% for loc in locales %}
    {% if loc == 'ru' %}
      <link rel="alternate" href="{{ site.baseUrl }}/frontend/profile/profile.html" hreflang="{{ loc }}">
    {% else %}
      <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/profile/profile.html" hreflang="{{ loc }}">
    {% endif %}
  {% endfor %}
  <link rel="alternate" href="{{ site.baseUrl }}/frontend/profile/profile.html" hreflang="x-default">

  <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/profile/profile_styles.css">
  <link rel="stylesheet" href="/frontend/find/find-view.css">

  <script type="module" src="/frontend/profile/profile_scripts.js" defer></script>
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body class="profile-page" data-findings-summary-tpl="{{ findingsSummaryTpl }}" data-search-path="{{ searchPath }}">
<div class="page-wrapper">
  <main class="container profile-shell" role="main">

    <header class="profile-hero" aria-label="{{ tabProfile }}">
      <button type="button" class="profile-avatar" id="avatarButton" aria-haspopup="dialog">
        <img id="avatarImage" class="profile-avatar__img" alt="" hidden>
        <span id="avatarInitials">U</span>
      </button>

      <div class="profile-hero__body">
        <h1 class="profile-hero__title">
          <span id="username" class="profile-username">—</span>
        </h1>
        <p class="profile-identity">
          <span id="email" class="profile-email">—</span>
        </p>
        <div class="profile-status-row">
          <span id="accountStatusBadge" class="status-badge status-badge--unconfirmed">
            {{ profile[locale].profile.infoSection.accountStatusLabel }}
          </span>
          <span id="planBadge" class="status-badge status-badge--free">Free</span>
        </div>
      </div>

      <div class="profile-hero__actions">
        <div class="profile-points-column">
          <div id="pointsBadge" class="profile-points" role="button" tabindex="0">
            <span class="profile-points-label">{{ profile[locale].profile.pointsSection.label }}</span>
            <span id="pointsBalance" class="profile-points-value">—</span>
          </div>
          <div id="pointsHistory" class="points-history" style="display:none;"></div>
        </div>
        <button id="openEditProfile" type="button" class="profile-btn profile-btn--ghost">
          {{ profile[locale].profile.editSection.openEditButton }}
        </button>
      </div>
    </header>

    <div id="editProfileMount"></div>

    <nav class="profile-tabs" role="tablist" aria-label="{{ title }}">
      <button type="button" class="profile-tabs__btn profile-tabs__btn--active" role="tab" id="tab-btn-profile" data-profile-tab="profile" aria-selected="true" aria-controls="tab-profile">{{ tabProfile }}</button>
      <button type="button" class="profile-tabs__btn" role="tab" id="tab-btn-findings" data-profile-tab="findings" aria-selected="false" aria-controls="tab-findings">{{ tabFindings }}</button>
      <button type="button" class="profile-tabs__btn" role="tab" id="tab-btn-plan" data-profile-tab="plan" aria-selected="false" aria-controls="tab-plan">{{ tabPlan }}</button>
      <button type="button" class="profile-tabs__btn" role="tab" id="tab-btn-tools" data-profile-tab="tools" aria-selected="false" aria-controls="tab-tools">{{ tabTools }}</button>
    </nav>

    <!-- Профиль -->
    <section id="tab-profile" class="profile-panel profile-panel--active" role="tabpanel" data-profile-panel="profile" aria-labelledby="tab-btn-profile">
      <div class="profile-panel-block">
        <h2 class="profile-panel__heading">{{ onnmailSectionTitle }}</h2>
        <p class="profile-panel__hint">{{ profile[locale].profile.extraSection.onnmailDescription }}</p>
        <div class="profile-onnmail-actions">
          <button id="createOnnmailButton" type="button" class="profile-btn profile-btn--ghost profile-btn--sm">
            {{ profile[locale].profile.extraSection.createOnnmail }}
          </button>
          <button id="loginOnnmailButton" type="button" class="profile-btn profile-btn--ghost profile-btn--sm">
            {{ profile[locale].profile.extraSection.loginOnnmail }}
          </button>
        </div>
      </div>

      <div class="profile-panel-block" id="messengerLinkBlock">
        <h2 class="profile-panel__heading">Serpmonn Messenger</h2>
        <p class="profile-panel__hint" id="messengerLinkHint" hidden>Привяжите мессенджер, чтобы входить на сайт без пароля и SMS.</p>
        <p class="profile-panel__hint" id="messengerLinkStatus">Проверяем…</p>
        <div class="profile-onnmail-actions">
          <button id="messengerLinkButton" type="button" class="profile-btn profile-btn--ghost profile-btn--sm" hidden>
            Привязать
          </button>
          <button id="messengerUnlinkButton" type="button" class="profile-btn profile-btn--ghost profile-btn--sm" hidden>
            Отвязать
          </button>
        </div>
      </div>

      <div class="profile-panel-block profile-panel-block--logout">
        <button id="logoutButton" type="button" class="profile-btn profile-btn--danger profile-btn--block">
          {{ profile[locale].profile.logoutSection.buttonText }}
        </button>
      </div>
    </section>

    <div id="messengerLinkModal" class="messenger-modal" hidden>
      <div class="messenger-modal__backdrop" data-messenger-link-close></div>
      <div class="messenger-modal__card" role="dialog" aria-modal="true" aria-labelledby="messengerLinkTitle">
        <h3 id="messengerLinkTitle">Привязка Serpmonn Messenger</h3>
        <p class="messenger-modal__hint">Отсканируйте QR в мессенджере</p>
        <canvas id="messengerLinkQrCanvas" width="220" height="220" aria-label="QR для привязки"></canvas>
        <p class="messenger-modal__code">Код: <strong id="messengerLinkShortCode">————</strong></p>
        <p id="messengerLinkModalStatus" class="messenger-modal__status">Ожидаем подтверждение…</p>
        <button type="button" class="profile-btn profile-btn--ghost profile-btn--block" data-messenger-link-close>Отмена</button>
      </div>
    </div>

    <!-- Находки -->
    <section id="tab-findings" class="profile-panel" role="tabpanel" data-profile-panel="findings" aria-labelledby="tab-btn-findings" hidden>
      <div class="profile-findings-toolbar">
        <div>
          <h2 class="profile-panel__heading profile-panel__heading--inline">{{ myFindingsTitle }}</h2>
          <p id="myFindingsSummary" class="profile-findings-summary"></p>
        </div>
        <div class="profile-findings-filters" role="group" aria-label="{{ myFindingsTitle }}">
          <button type="button" class="profile-filter-btn profile-filter-btn--active" data-findings-filter="all">{{ filterAll }}</button>
          <button type="button" class="profile-filter-btn" data-findings-filter="private">{{ filterPrivate }}</button>
          <button type="button" class="profile-filter-btn" data-findings-filter="public">{{ filterPublic }}</button>
          <button type="button" class="profile-filter-btn" data-findings-filter="followers">{{ filterFollowers }}</button>
        </div>
      </div>

      <div id="myFindingsList" class="profile-findings-list" aria-live="polite">
        <div id="myFindingsLoading" class="profile-findings-skeleton" aria-hidden="true">
          <div class="profile-skeleton-card"></div>
          <div class="profile-skeleton-card"></div>
          <div class="profile-skeleton-card"></div>
        </div>
      </div>

      <p id="myFindingsEmpty" class="profile-empty-state" hidden>
        <span>{{ findingPageI18n[locale].noFindings or 'No saved findings yet' }}</span>
        <a href="{{ searchPath }}" class="profile-empty-state__link">{{ goSearch }}</a>
      </p>
    </section>

    <!-- Тариф и баллы -->
    <section id="tab-plan" class="profile-panel" role="tabpanel" data-profile-panel="plan" aria-labelledby="tab-btn-plan" hidden>
      <div id="planCard" class="plan-dashboard">
        <div class="plan-dashboard__head">
          <div>
            <p class="plan-dashboard__label">{{ profile[locale].profile.planSection.currentPlanLabel }}</p>
            <p class="plan-dashboard__plan">
              <span id="planName" class="plan-name">Free</span>
            </p>
            <p id="planStatus" class="plan-status"></p>
          </div>
          <button id="managePlanButton" type="button" class="profile-btn profile-btn--primary profile-btn--sm">
            {{ profile[locale].profile.planSection.manageButton }}
          </button>
        </div>

        <div class="plan-quota plan-quota--dashboard">
          <div class="plan-quota-header">
            <span>{{ profile[locale].profile.planSection.quotaLabel }}</span>
            <span id="planQuotaCounter" class="plan-quota-counter">—</span>
          </div>
          <div class="plan-quota-bar">
            <div id="planQuotaBarFill" class="plan-quota-bar-fill"></div>
          </div>
          <p id="planQuotaHint" class="plan-quota-hint"></p>
        </div>

        <p id="planHint" class="plan-hint plan-hint--compact" hidden></p>

        <div id="aiAccessBlock" class="profile-ai-access" style="display:none;">
          <button id="openAiService" type="button" class="profile-btn profile-btn--primary profile-btn--block">
            {{ profile[locale].profile.planSection.openAiServiceButton }}
          </button>
          <p id="aiAccessHint" class="plan-hint"></p>
        </div>

        <details class="profile-details">
          <summary class="profile-details__summary">{{ exchangeToggle }}</summary>
          <div class="profile-details__body">
            <p class="plan-hint">{{ profile[locale].profile.pointsExchangeSection.description }}</p>
            <div class="profile-inline-form">
              <label for="proExchangeDays" class="referral-label">{{ profile[locale].profile.pointsExchangeSection.daysLabel }}</label>
              <input id="proExchangeDays" type="number" class="profile-input" min="1" value="7">
              <button id="proExchangeSubmit" type="button" class="profile-btn profile-btn--ghost profile-btn--sm">
                {{ profile[locale].profile.pointsExchangeSection.submitButton }}
              </button>
            </div>
            <p id="proExchangeHint" class="plan-hint"></p>
          </div>
        </details>

        <div class="profile-referral-compact">
          <label for="referralLink" class="referral-label">{{ referralCompactLabel }}</label>
          <div class="profile-referral-row">
            <input id="referralLink" type="text" class="profile-input profile-input--readonly" readonly value="">
            <button id="copyReferralLink" type="button" class="profile-btn profile-btn--ghost profile-btn--sm" title="">
              {{ profile[locale].profile.referralSection.copyButton }}
            </button>
          </div>
          <p id="referralCounter" class="plan-quota-hint"></p>
        </div>
      </div>
    </section>

    <!-- Инструменты -->
    <section id="tab-tools" class="profile-panel" role="tabpanel" data-profile-panel="tools" aria-labelledby="tab-btn-tools" hidden>
      <h2 class="profile-panel__heading">{{ profile[locale].profile.toolsSection.title }}</h2>
      <div class="tools-grid" id="favoriteTools"></div>
      <p id="noFavoritesMessage" class="plan-hint" style="display:none;">
        {{ profile[locale].profile.toolsSection.noFavorites1 }}
        {{ profile[locale].profile.toolsSection.noFavorites2 }}
        <a href="{% if locale == 'ru' %}/frontend/tools/tools.html{% else %}/frontend/{{ locale }}/tools/tools.html{% endif %}">
          {{ profile[locale].profile.toolsSection.allToolsLink }}
        </a>,
        {{ profile[locale].profile.toolsSection.noFavorites3 }}
      </p>
      <div id="recentTools" class="recent-tools"></div>
    </section>

  </main>
</div>

<div id="toastContainer" aria-live="polite" aria-atomic="true"></div>

<script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
