---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/games/breakout/breakout.html{% else %}/frontend/{{ locale }}/games/breakout/breakout.html{% endif %}"
eleventyComputed:
  title: "{{ gameBreakoutTranslations[locale].gameBreakout.pageTitle }}"
  description: "{{ gameBreakoutTranslations[locale].gameBreakout.metaDescription }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/games/breakout/breakout.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/games/breakout/breakout.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Language" content="{{ locale }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:title" content="{{ gameBreakoutTranslations[locale].gameBreakout.ogTitle }}">
  <meta property="og:description" content="{{ gameBreakoutTranslations[locale].gameBreakout.ogDescription }}">
  <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/breakout.png">
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ canonical }}">
  <meta property="twitter:title" content="{{ gameBreakoutTranslations[locale].gameBreakout.ogTitle }}">
  <meta property="twitter:description" content="{{ gameBreakoutTranslations[locale].gameBreakout.twitterDescription }}">
  <meta property="twitter:image" content="{{ site.baseUrl }}/frontend/images/breakout.png">
  <link rel="canonical" href="{{ canonical }}">
  <link rel="icon" href="/frontend/images/breakout.png" type="image/x-icon">
  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/base.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/menu.css">
  <link rel="stylesheet" href="/frontend/games/breakout/breakout.css">
  <script async src="https://ad.mail.ru/static/ads-async.js"></script>
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
  <div id="menuContainer"></div>
  <script>
    window.i18n = {
      gameOver: {{ gameBreakoutTranslations[locale].gameBreakout.gameOver | dump | safe }},
      winMessage: {{ gameBreakoutTranslations[locale].gameBreakout.winMessage | dump | safe }},
      pressRToRestart: {{ gameBreakoutTranslations[locale].gameBreakout.pressRToRestart | dump | safe }},
      continueAd: {{ gameBreakoutTranslations[locale].gameBreakout.continueAd | dump | safe }},
      instructionsDesktop: {{ gameBreakoutTranslations[locale].gameBreakout.instructionsDesktop | dump | safe }},
      instructionsMobile: {{ gameBreakoutTranslations[locale].gameBreakout.instructionsMobile | dump | safe }}
    };
  </script>
  <script src="/frontend/games/breakout/breakout-ads.js?v=2" defer></script>
  <script>
  (function(){
    function isMobile(){ return /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (window.innerWidth < 768); }
    function showInstructions(){
      try{
        if (localStorage.getItem('game_instructions_breakout_shown') === '1') return;
        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;z-index:9998;';
        var box = document.createElement('div');
        box.style.cssText = 'max-width:90vw;background:#141821;color:#fff;border:1px solid #1f2632;border-radius:12px;padding:16px;text-align:left;';
        var h = document.createElement('h3');
        h.textContent = '{{ gameBreakoutTranslations[locale].gameBreakout.howToTitle }}';
        h.style.margin = '0 0 8px';
        var p = document.createElement('div');
        p.style.cssText = 'font-size:14px;line-height:1.5;white-space:pre-line';
        p.textContent = isMobile() ? window.i18n.instructionsMobile : window.i18n.instructionsDesktop;
        var btn = document.createElement('button');
        btn.className = 'btn';
        btn.textContent = '{{ gameBreakoutTranslations[locale].gameBreakout.gotIt }}';
        btn.style.marginTop = '10px';
        btn.onclick = function(){ localStorage.setItem('game_instructions_breakout_shown','1'); ov.remove(); };
        box.appendChild(h); box.appendChild(p); box.appendChild(btn); ov.appendChild(box); document.body.appendChild(ov);
      }catch(e){}
    }
    document.addEventListener('DOMContentLoaded', showInstructions);
  })();
  </script>
  <div class="page">
    <header>
      <img src="/frontend/images/breakout.png" width="28" height="28" alt="{{ gameBreakoutTranslations[locale].gameBreakout.gamesAlt }}" style="border-radius:6px;">
      <h1>{{ gameBreakoutTranslations[locale].gameBreakout.mainTitle }}</h1>
    </header>
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag" style="display:inline-block;" data-ad-client="ad-1897960" data-ad-slot="1897960"></ins>
    </div>
    <script>(window.MRGtag = window.MRGtag || []).push({});</script>
    <div class="wrap">
      <div class="panel">
        <canvas id="game" width="480" height="640" aria-label="{{ gameBreakoutTranslations[locale].gameBreakout.canvasAria }}"></canvas>
        <div class="hint" style="display:none;">{{ gameBreakoutTranslations[locale].gameBreakout.hint }}</div>
      </div>
      <div class="panel">
        <div class="stats">
          <div class="stat">{{ gameBreakoutTranslations[locale].gameBreakout.scoreLabel }}<br><b id="score">0</b></div>
          <div class="stat">{{ gameBreakoutTranslations[locale].gameBreakout.livesLabel }}<br><b id="lives">3</b></div>
          <div class="stat">{{ gameBreakoutTranslations[locale].gameBreakout.bestLabel }}<br><b id="best">0</b></div>
        </div>
        <div class="controls">
          <button class="btn primary" id="btnStart">{{ gameBreakoutTranslations[locale].gameBreakout.btnStart }}</button>
          <button class="btn" id="btnReset">{{ gameBreakoutTranslations[locale].gameBreakout.btnReset }}</button>
        </div>
      </div>
    </div>
  </div>
  <script src="/frontend/games/breakout/breakout.js?v=2" defer></script>
  <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
