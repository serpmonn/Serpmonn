---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/knowledge-base/articles/cookies-complete-guide.html{% else %}/frontend/{{ locale }}/knowledge-base/articles/cookies-complete-guide.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  title: "{{ cookiesCompleteGuide[locale].meta.title }}"
  description: "{{ cookiesCompleteGuide[locale].meta.description }}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/knowledge-base/articles/cookies-complete-guide.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/knowledge-base/articles/cookies-complete-guide.html{% endif %}"
---

{% set t = cookiesCompleteGuide[locale] %}

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ t.meta.description }}">
    <title>{{ t.meta.title }}</title>
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ t.meta.og_title }}">
    <meta property="og:description" content="{{ t.meta.og_description }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="article">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ t.meta.twitter_title }}">
    <meta name="twitter:description" content="{{ t.meta.twitter_description }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

<!-- Structured Data: Article -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ canonical }}"
      },
      "headline": "{{ t.meta.title | replace('"', '&quot;') }}",
      "description": "{{ t.meta.description | replace('"', '&quot;') }}",
      "image": "{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png",
      "datePublished": "2024-10-29",
      "dateModified": "2025-06-23",
      "inLanguage": "{{ locale }}",
      "url": "{{ canonical }}",
      "author": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.baseUrl }}/frontend/images/serpmonn.ico?v=3"
        }
      }
    }
    </script>

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />
    
    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/cookies-complete-guide.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/knowledge-base/articles/cookies-complete-guide.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/knowledge-base/articles/cookies-complete-guide.html" hreflang="x-default" />

    <!-- Иконка -->
    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    
    <!-- Основные стили -->
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/ad-top-banner.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css" media="print" onload="this.media='all'">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css">
    <link rel="stylesheet" href="/frontend/styles/articles/article-chrome.css">
    <link rel="stylesheet" href="/frontend/styles/articles/cookies-guide.css">
    
    <!-- Скрипт меню -->
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
    {% set tocTitle = t.toc.title %}
    {% set tocItems = [
      { href: '#section-what-is', label: t.toc.items[0] },
      { href: '#section-how-work', label: t.toc.items[1] },
      { href: '#section-types', label: t.toc.items[2] },
      { href: '#section-why-clean', label: t.toc.items[3] },
      { href: '#section-how-clean', label: t.toc.items[4] },
      { href: '#section-manage', label: t.toc.items[5] },
      { href: '#section-security', label: t.toc.items[6] },
      { href: '#section-faq', label: t.toc.items[7] }
    ] %}
    {% include "partials/article-floating-toc.njk" %}
    {% from "partials/tool-icons.njk" import toolIcon %}

    <div id="menuContainer"></div>
    
    <article class="article-container" tabindex="0">
        <header class="article-header">
            <span class="article-category">{{ t.article.category }}</span>
            <div class="ad-top-banner ad-banner loading">
                <ins class="mrg-tag" style="display:inline-block;" data-ad-client="ad-{{ mailAds.slots.top.id }}" data-ad-slot="{{ mailAds.slots.top.id }}"></ins>
            </div>
            <h1 class="article-title">{{ t.article.title }}</h1>
            <div class="article-meta">{{ t.article.date }} • {{ t.article.reading_time }}</div>
        </header>

        <div class="article-content">
            <p>{{ t.article.intro }}</p>

            <!-- Что такое куки -->
            <h2 id="section-what-is">{{ t.sections.what_is.title }}</h2>
            <p>{{ t.sections.what_is.content | safe }}</p>
            
            <div class="analogy-box">
                <h4>{{ t.sections.what_is.analogy.title }}</h4>
                <p>{{ t.sections.what_is.analogy.content }}</p>
            </div>

            <div class="visual-guide">
                {% for item in t.sections.what_is.visual_items %}
                <div class="visual-item">
                    {{ toolIcon(item.icon, 'cat') }}
                    <h3>{{ item.title }}</h3>
                    <p>{{ item.description }}</p>
                </div>
                {% endfor %}
            </div>

            <!-- Как работают куки -->
            <h2 id="section-how-work">{{ t.sections.how_work.title }}</h2>
            
            <ol class="step-list">
                {% for step in t.sections.how_work.steps %}
                <li>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.content }}</p>
                </li>
                {% endfor %}
            </ol>

            <div class="code-example">
                <h4>{{ t.sections.how_work.code_example.title }}</h4>
                <pre><code class="language-json">{{ t.sections.how_work.code_example.code }}</code></pre>
            </div>

            <!-- Типы куки -->
            <h2 id="section-types">{{ t.sections.types.title }}</h2>
            
            <table class="cookies-table">
                <thead>
                    <tr>
                        {% for header in t.sections.types.table.headers %}
                        <th>{{ header | safe }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in t.sections.types.table.rows %}
                    <tr>
                        {% for cell in row %}
                        <td>{{ cell | safe }}</td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="privacy-warning">
                <h4>{{ t.sections.types.warning.title }}</h4>
                <p>{{ t.sections.types.warning.content }}</p>
            </div>

            <!-- Зачем чистить куки -->
            <h2 id="section-why-clean">{{ t.sections.why_clean.title }}</h2>

            <div class="visual-guide">
                {% for item in t.sections.why_clean.visual_items %}
                <div class="visual-item">
                    {{ toolIcon(item.icon, 'cat') }}
                    <h3>{{ item.title }}</h3>
                    <p>{{ item.description }}</p>
                </div>
                {% endfor %}
            </div>

            <h3>{{ t.sections.why_clean.situations.title }}</h3>
            <ul>
                {% for item in t.sections.why_clean.situations.items %}
                <li>{{ item | safe }}</li>
                {% endfor %}
            </ul>

            <!-- Как очистить куки -->
            <h2 id="section-how-clean">{{ t.sections.how_clean.title }}</h2>

            {% for browser in t.sections.how_clean.browsers %}
            <div class="browser-guide">
                <h4>{{ browser.title }}</h4>
                <ol>
                    {% for step in browser.steps %}
                    <li>{{ step | safe }}</li>
                    {% endfor %}
                </ol>
            </div>
            {% endfor %}

            <div class="security-tip">
                <h4>{{ t.sections.how_clean.tip.title }}</h4>
                <p>{{ t.sections.how_clean.tip.content }}</p>
            </div>

            <h3>{{ t.sections.how_clean.shortcuts.title }}</h3>
            <ul>
                {% for item in t.sections.how_clean.shortcuts.items %}
                <li>{{ item | safe }}</li>
                {% endfor %}
            </ul>

            <!-- Управление куки -->
            <h2 id="section-manage">{{ t.sections.manage.title }}</h2>

            <ol class="step-list">
                {% for step in t.sections.manage.steps %}
                <li>
                    <h3>{{ step.title }}</h3>
                    <p>{{ step.content }}</p>
                </li>
                {% endfor %}
            </ol>

            <div class="security-tip">
                <h4>{{ t.sections.manage.extensions.title }}</h4>
                <ul>
                    {% for item in t.sections.manage.extensions.items %}
                    <li>{{ item | safe }}</li>
                    {% endfor %}
                </ul>
            </div>

            <!-- Безопасность -->
            <h2 id="section-security">{{ t.sections.security.title }}</h2>

            <div class="privacy-warning">
                <h4>{{ t.sections.security.attacks.title }}</h4>
                <ul>
                    {% for item in t.sections.security.attacks.items %}
                    <li>{{ item | safe }}</li>
                    {% endfor %}
                </ul>
            </div>

            <h3>{{ t.sections.security.protection.title }}</h3>
            
            <table class="cookies-table">
                <thead>
                    <tr>
                        {% for header in t.sections.security.protection.table.headers %}
                        <th>{{ header | safe }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for row in t.sections.security.protection.table.rows %}
                    <tr>
                        {% for cell in row %}
                        <td>{{ cell | safe }}</td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>

            <h3>{{ t.sections.security.checklist.title }}</h3>
            <ul class="checklist">
                {% for item in t.sections.security.checklist.items %}
                <li>
                    <input type="checkbox" id="security{{ loop.index }}">
                    <label for="security{{ loop.index }}">{{ item }}</label>
                </li>
                {% endfor %}
            </ul>

            <!-- Частые вопросы -->
            <h2 id="section-faq">{{ t.sections.faq.title }}</h2>

            {% for qa in t.sections.faq.questions %}
            <div class="browser-guide">
                <h4>{{ qa.question }}</h4>
                <p>{{ qa.answer | safe }}</p>
            </div>
            {% endfor %}

            <!-- Выводы -->
            <h3>{{ t.sections.conclusions.title }}</h3>
            <ul>
                {% for item in t.sections.conclusions.items %}
                <li>{{ item }}</li>
                {% endfor %}
            </ul>

            {% set relatedTitle = locale | articleRelatedTitle %}
            {% set relatedItems = 'cookies-complete-guide' | articleRelated(locale) %}
            {% include "partials/article-related.njk" %}

            <div class="share-buttons">
                <h3>{{ t.ui.share.title }}</h3>
                <button type="button" onclick="serpmonnShare('telegram')" aria-label="{{ t.ui.share.telegram }}">{{ t.ui.share.telegram }}</button>
                <button type="button" onclick="serpmonnShare('vk')" aria-label="{{ t.ui.share.vk }}">{{ t.ui.share.vk }}</button>
            </div>
        </div>

        <!-- Социальные кнопки -->
        <div class="social-subscribe">
            <a class="tg-btn" href="https://t.me/serpmonn" target="_blank" rel="noopener" aria-label="{{ t.ui.social.telegram }}">{{ t.ui.social.telegram }}</a>
            <a class="vk-btn" href="https://vk.com/serpmonn_site" target="_blank" rel="noopener" aria-label="{{ t.ui.social.vk }}">{{ t.ui.social.vk }}</a>
        </div>
    </article>

    <!-- Кнопка наверх -->
    <button class="scroll-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})" aria-label="{{ t.ui.scroll_top }}">{{ t.ui.scroll_top }}</button>

    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    {% include "partials/article-chrome-scripts.njk" %}
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(localesNews[locale].news.closeAd) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
