---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/games/coins/coins.html{% else %}/frontend/{{ locale }}/games/coins/coins.html{% endif %}"
eleventyComputed:
  title: "{{ gameCoinsTranslations[locale].gameCoins.pageTitle }}"
  description: "{{ gameCoinsTranslations[locale].gameCoins.metaDescription }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/games/coins/coins.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/games/coins/coins.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Language" content="{{ locale }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:title" content="{{ gameCoinsTranslations[locale].gameCoins.ogTitle }}">
  <meta property="og:description" content="{{ gameCoinsTranslations[locale].gameCoins.ogDescription }}">
  <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/coins.png">
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ canonical }}">
  <meta property="twitter:title" content="{{ gameCoinsTranslations[locale].gameCoins.ogTitle }}">
  <meta property="twitter:description" content="{{ gameCoinsTranslations[locale].gameCoins.twitterDescription }}">
  <meta property="twitter:image" content="{{ site.baseUrl }}/frontend/images/coins.png">
  <link rel="canonical" href="{{ canonical }}">
  <link rel="icon" href="/frontend/images/coins.png" type="image/x-icon">
  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/base.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/menu.css">
  <link rel="stylesheet" href="/frontend/games/coins/coins.css">
  <script async src="https://ad.mail.ru/static/ads-async.js"></script>
  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
  <div id="menuContainer"></div>
  <script>
    window.i18n = {
      gameOver: {{ gameCoinsTranslations[locale].gameCoins.gameOver | dump | safe }},
      pressRToRestart: {{ gameCoinsTranslations[locale].gameCoins.pressRToRestart | dump | safe }},
      continueAd: {{ gameCoinsTranslations[locale].gameCoins.continueAd | dump | safe }},
      instructionsDesktop: {{ gameCoinsTranslations[locale].gameCoins.instructionsDesktop | dump | safe }},
      instructionsMobile: {{ gameCoinsTranslations[locale].gameCoins.instructionsMobile | dump | safe }}
    };
  </script>
  <script type="module" src="/frontend/games/coins/coins-ads.js?v=3" defer></script>
  <script>
  (function(){
    function isMobile(){ return /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (window.innerWidth < 768); }
    function showInstructions(){
      try{
        if (localStorage.getItem('game_instructions_coins_shown') === '1') return;
        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;z-index:9998;';
        var box = document.createElement('div');
        box.style.cssText = 'max-width:90vw;background:#141821;color:#fff;border:1px solid #1f2632;border-radius:12px;padding:16px;text-align:left;';
        var h = document.createElement('h3');
        h.textContent = '{{ gameCoinsTranslations[locale].gameCoins.howToTitle }}';
        h.style.margin = '0 0 8px';
        var p = document.createElement('div');
        p.style.cssText = 'font-size:14px;line-height:1.5;white-space:pre-line';
        p.textContent = isMobile() ? window.i18n.instructionsMobile : window.i18n.instructionsDesktop;
        var btn = document.createElement('button');
        btn.className = 'btn';
        btn.textContent = '{{ gameCoinsTranslations[locale].gameCoins.gotIt }}';
        btn.style.marginTop = '10px';
        btn.onclick = function(){ localStorage.setItem('game_instructions_coins_shown','1'); ov.remove(); };
        box.appendChild(h); box.appendChild(p); box.appendChild(btn); ov.appendChild(box); document.body.appendChild(ov);
      }catch(e){}
    }
    document.addEventListener('DOMContentLoaded', showInstructions);
  })();
  </script>
  <div class="page">
    <header>
      <img src="/frontend/images/coins.png" width="28" height="28" alt="{{ gameCoinsTranslations[locale].gameCoins.gamesAlt }}" style="border-radius:6px;">
      <h1>{{ gameCoinsTranslations[locale].gameCoins.mainTitle }}</h1>
    </header>
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag" style="display:inline-block;" data-ad-client="ad-{{ mailAds.slots.top.id }}" data-ad-slot="{{ mailAds.slots.top.id }}"></ins>
    </div>
<div class="wrap">
      <div class="panel">
        <canvas id="game" width="480" height="480" aria-label="{{ gameCoinsTranslations[locale].gameCoins.canvasAria }}"></canvas>
        <div class="hint" style="display:none;">{{ gameCoinsTranslations[locale].gameCoins.hint }}</div>
      </div>
      <div class="panel">
        <div class="stats">
          <div class="stat">{{ gameCoinsTranslations[locale].gameCoins.coinsLabel }}<br><b id="score">0</b></div>
          <div class="stat">{{ gameCoinsTranslations[locale].gameCoins.timeLabel }}<br><b id="time">60</b>{{ gameCoinsTranslations[locale].gameCoins.timeSuffix }}</div>
          <div class="stat">{{ gameCoinsTranslations[locale].gameCoins.bestLabel }}<br><b id="best">0</b></div>
        </div>
        <div class="controls">
          <button class="btn primary" id="btnStart">{{ gameCoinsTranslations[locale].gameCoins.btnStart }}</button>
          <button class="btn" id="btnReset">{{ gameCoinsTranslations[locale].gameCoins.btnReset }}</button>
        </div>
      </div>
    </div>
  </div>
  <script src="/frontend/games/coins/coins.js?v=2" defer></script>
  <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
