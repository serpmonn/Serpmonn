---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/games/games.html{% else %}/frontend/{{ locale }}/games/games.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/games/games.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/games/games.html{% endif %}"
---
<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ localesGames[locale].games.pageTitle }}</title>  <!-- ← меняем на locale -->
    <meta name="description" content="{{ localesGames[locale].games.metaDescription }}">
   
    <!-- Яндекс.Метрика -->
    <script type="text/javascript">
        (function(m,e,t,r,i,k,a){
            m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
        })(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
        ym(104905836, "init", {
            clickmap:true,
            trackLinks:true,
            accurateTrackBounce:true,
            webvisor:true,
            ecommerce:"dataLayer"
        });
       
        window.addEventListener('load', function() {
            fetch('https://api.ipify.org?format=json')
                .then(response => response.json())
                .then(data => {
                    if (typeof ym !== 'undefined') {
                        ym(104905836, 'params', {
                            ip_address: data.ip,
                            user_ip: data.ip
                        });
                        ym(104905836, 'hit', window.location.href, {
                            params: { ip_address: data.ip }
                        });
                    }
                })
                .catch(error => {
                    console.error('Error getting IP:', error);
                });
        });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/104905836" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Яндекс.Метрика -->
   
    <!-- Open Graph -->
    <meta property="og:title" content="{{ localesGames[locale].games.ogTitle }}">
    <meta property="og:description" content="{{ localesGames[locale].games.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />
        <!-- Structured Data: список игр -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "{{ localesGames[locale].games.schemaName | escape }}",
      "numberOfItems": {{ localesGames[locale].games.totalGames | safe }},
      "url": "{{ canonical }}"
    }
    </script>
    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/games/games.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/games/games.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/games/games.html" hreflang="x-default" />
    <!-- Подключение стилей -->
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/games/games.css">
</head>
<body>
    {% from "partials/tool-icons.njk" import toolIcon, webGameIcon %}
    <nav id="menuContainer" aria-label="{{ localesGames[locale].games.menuLabel }}"></nav>
   
    <main class="page" itemscope itemtype="https://schema.org/ItemList">
        <meta itemprop="name" content="{{ localesGames[locale].games.schemaName }}">
        <meta itemprop="numberOfItems" content="{{ localesGames[locale].games.totalGames }}">
        <meta itemprop="publisher" content="Serpmonn">
       
        <h1>
            <img class="section-logo-inline" src="/frontend/images/Games.ico" alt="Serpmonn" loading="lazy">
            {{ localesGames[locale].games.mainTitle }}
        </h1>
        <!-- ФИЛЬТР: источник + платформа -->
        <div class="filter-buttons" role="tablist" aria-label="{{ localesGames[locale].games.filterLabel }}">
            <button class="filter-btn active" data-filter="all" aria-selected="true" role="tab">
                {{ localesGames[locale].games.filters.all }}
            </button>
            <button class="filter-btn" data-filter="serpmonn" role="tab">
                {{ localesGames[locale].games.filters.serpmonn }}
            </button>
            <button class="filter-btn" data-filter="partners" role="tab">
                {{ localesGames[locale].games.filters.partners }}
            </button>
            <span class="filter-sep" aria-hidden="true"></span>
            <button class="filter-btn" data-filter="web" role="tab">
                {{ localesGames[locale].games.filters.web }}
            </button>
            <button class="filter-btn" data-filter="pc" role="tab">
                {{ localesGames[locale].games.filters.pc }}
            </button>
            <button class="filter-btn" data-filter="mobile" role="tab">
                {{ localesGames[locale].games.filters.mobile }}
            </button>
        </div>
       
        <!-- РЕКЛАМНЫЙ БАННЕР -->
        <script async src="https://ad.mail.ru/static/ads-async.js"></script>
        <div class="ad-leaderboard">
            <ins class="mrg-tag" style="display:inline-block" data-ad-client="ad-{{ mailAds.slots.top.id }}" data-ad-slot="{{ mailAds.slots.top.id }}"></ins>
        </div>

{% for group in localesGames[locale].games.groups %}
        <section class="games-group" data-group="{{ group.key }}" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <meta itemprop="position" content="{{ loop.index }}">
            <h2 class="group-title">
                {% if group.key == 'serpmonn' %}
                <span class="section-logo-inline">{{ toolIcon('games', 'cat') }}</span>
                {% else %}
                <span class="section-logo-inline">{{ toolIcon('partners', 'cat') }}</span>
                {% endif %}
                {{ group.title }}
            </h2>

            {% for platform in group.platforms %}
            <div class="platform-block" data-platform="{{ platform.key }}">
                <h3 class="platform-title">
                    {% if platform.key == 'web' %}{{ toolIcon('web', 'cat') }}
                    {% elif platform.key == 'pc' %}{{ toolIcon('pc', 'cat') }}
                    {% else %}{{ toolIcon('mobile', 'cat') }}{% endif %}
                    {{ platform.title }}
                </h3>
                <div class="grid" role="grid" aria-label="{{ platform.ariaLabel }}">
                    {% if platform.games and platform.games | length %}
                      {% for game in platform.games %}
                    <div class="card" role="row" itemprop="item" itemscope itemtype="https://schema.org/Game">
                        <meta itemprop="position" content="{{ game.position }}">
                        <h2>
                            {% if platform.key == 'web' and not game.external %}
                            <span class="game-logo-inline game-logo-inline--svg">{{ webGameIcon(game.link, 'cat') }}</span>
                            {% elif game.image %}
                            <img class="game-logo-inline" src="{{ game.image }}" alt="{{ game.name }}" loading="lazy" itemprop="image">
                            {% else %}
                            <span class="game-logo-inline game-logo-inline--svg">{{ toolIcon('games', 'cat') }}</span>
                            {% endif %}
                            <span itemprop="name">{{ game.name }}</span>
                        </h2>
                        <p itemprop="description">{{ game.description }}</p>

                        {% if game.external or game.badges %}
                        <div class="platform-badges">
                            {% if game.external %}
                            <span class="badge partner">{{ localesGames[locale].games.partnerBadge | default('Партнёр') }}</span>
                            {% endif %}
                            {% if game.badges %}
                            {% for badge in game.badges %}
                            <span class="badge {{ badge.type }}">{{ badge.name }}</span>
                            {% endfor %}
                            {% endif %}
                        </div>
                        {% endif %}

                        <a class="btn"
                           href="{{ game.link }}"
                           {% if game.external %}target="_blank" rel="noopener"{% endif %}
                           itemprop="url">
                            {{ game.buttonText }}
                        </a>
                    </div>
                      {% endfor %}
                    {% elif platform.placeholders and platform.placeholders | length %}
                      {% for ph in platform.placeholders %}
                    <div class="card card--soon" role="row">
                        <h2>
                            <span class="game-logo-inline game-logo-inline--svg">{{ toolIcon(platform.key, 'cat') }}</span>
                            <span>{{ ph.name }}</span>
                        </h2>
                        <p>{{ ph.description | default(localesGames[locale].games.soonLabel) }}</p>
                    </div>
                      {% endfor %}
                    {% else %}
                    <p class="platform-empty">{{ localesGames[locale].games.emptyPlatform }}</p>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </section>
{% endfor %}
    </main>

    {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
    {{ mobileAnchor(localesNews[locale].news.closeAd) }}

    <!-- ПОДКЛЮЧЕНИЕ СКРИПТОВ -->
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/games/games.js" defer></script>
    <script src="/frontend/scripts/interactive-bg.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
{% include "partials/ad-pool-init.njk" %}
</body>
</html>