---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/marketing/word-counter.html{% else %}/frontend/{{ locale }}/tools/marketing/word-counter.html{% endif %}"
eleventyComputed:
  title: "{{ wordCounter[locale].meta.title }}"
  description: "{{ wordCounter[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/marketing/word-counter.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/marketing/word-counter.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ wordCounter[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ wordCounter[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ wordCounter[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ wordCounter[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/marketing/word-counter.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/marketing/word-counter.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/marketing/word-counter.html" hreflang="x-default" />      <!-- Structured Data: SoftwareApplication -->     <script type="application/ld+json">     {       "@context": "https://schema.org",       "@type": "SoftwareApplication",       "name": "{{ wordCounter[locale].meta.title | replace('"', '&quot;') }}",       "description": "{{ wordCounter[locale].meta.description | replace('"', '&quot;') }}",       "url": "{{ canonical }}",       "applicationCategory": "UtilityApplication",       "operatingSystem": "Web",       "inLanguage": "{{ locale }}",       "offers": {         "@type": "Offer",         "price": "0",         "priceCurrency": "RUB"       },       "publisher": {         "@type": "Organization",         "name": "Serpmonn",         "url": "{{ site.baseUrl }}/"       }     }     </script>

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/styles/tools/tools-shell.css?v=3">
  </head>
  <body class="spn-tool word-counter-page">
    <div id="menuContainer"></div>

    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag"
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}"
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>

    <h1>{{ wordCounter[locale].page.title }}</h1>
    {% if wordCounter[locale].page.lead %}
    <p class="tool-lead">{{ wordCounter[locale].page.lead }}</p>
    {% endif %}

    <div class="calculator-container">
      <h2>{{ wordCounter[locale].page.formTitle if wordCounter[locale].page.formTitle else 'Текст' }}</h2>
      <textarea id="text" class="tool-textarea" placeholder="{{ wordCounter[locale].page.textareaPlaceholder }}"></textarea>

      <div class="action-bar">
        <button type="button" class="calculate-btn" id="btn-copy-stats">{{ wordCounter[locale].page.actions.copyStats if wordCounter[locale].page.actions else 'Копировать статистику' }}</button>
        <details class="more-actions">
          <summary>{{ wordCounter[locale].page.actions.more if wordCounter[locale].page.actions else 'Ещё' }}</summary>
          <div class="more-actions__list">
            <button type="button" id="btn-reset">{{ wordCounter[locale].page.actions.reset if wordCounter[locale].page.actions else 'Сбросить' }}</button>
            <button type="button" id="btn-copy-text">{{ wordCounter[locale].page.actions.copyText if wordCounter[locale].page.actions else 'Копировать текст' }}</button>
            <button type="button" id="btn-share">{{ wordCounter[locale].page.actions.share if wordCounter[locale].page.actions else 'Поделиться' }}</button>
          </div>
        </details>
      </div>

      <div class="results">
        <h3>{{ wordCounter[locale].page.resultsTitle if wordCounter[locale].page.resultsTitle else 'Результаты' }}</h3>
        <div class="result-hero">
          <div class="result-value" id="words">0</div>
          <div class="result-label">{{ wordCounter[locale].page.stats.words }}</div>
        </div>
        <p class="result-disclaimer">{{ wordCounter[locale].page.disclaimer if wordCounter[locale].page.disclaimer else 'Подсчёт в браузере, без отправки текста на сервер.' }}</p>
        <div class="stats">
          <div class="card">
            <div class="num" id="chars">0</div>
            <div class="label">{{ wordCounter[locale].page.stats.chars }}</div>
          </div>
          <div class="card">
            <div class="num" id="lines">0</div>
            <div class="label">{{ wordCounter[locale].page.stats.lines }}</div>
          </div>
          <div class="card">
            <div class="num" id="spaces">0</div>
            <div class="label">{{ wordCounter[locale].page.stats.spaces }}</div>
          </div>
        </div>
      </div>
    </div>

    <script>
      window.wordCounterTranslations = {{ wordCounter[locale] | dump | safe }};
    </script>
    <script type="module" src="/frontend/scripts/tools/word-counter.js?v=1"></script>
    <script type="module" src="/frontend/scripts/tools/more-actions.js?v=1"></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(wordCounter[locale].ads.closeAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
