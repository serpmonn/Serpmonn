---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/marketing/word-counter.html{% else %}/frontend/{{ locale }}/tools/marketing/word-counter.html{% endif %}"
eleventyComputed:
  title: "{{ wordCounter[locale].meta.title }}"
  description: "{{ wordCounter[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/marketing/word-counter.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/marketing/word-counter.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ wordCounter[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ wordCounter[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ wordCounter[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ wordCounter[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/marketing/word-counter.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/marketing/word-counter.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/marketing/word-counter.html" hreflang="x-default" />      <!-- Structured Data: SoftwareApplication -->     <script type="application/ld+json">     {       "@context": "https://schema.org",       "@type": "SoftwareApplication",       "name": "{{ wordCounter[locale].meta.title | replace('"', '&quot;') }}",       "description": "{{ wordCounter[locale].meta.description | replace('"', '&quot;') }}",       "url": "{{ canonical }}",       "applicationCategory": "UtilityApplication",       "operatingSystem": "Web",       "inLanguage": "{{ locale }}",       "offers": {         "@type": "Offer",         "price": "0",         "priceCurrency": "RUB"       },       "publisher": {         "@type": "Organization",         "name": "Serpmonn",         "url": "{{ site.baseUrl }}/"       }     }     </script>

    <link rel="icon" href="/frontend/images/serpmonn.ico" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    
    <style>
      /* ad top adaptive start */
      .ad-top-banner .mrg-tag { width: 970px !important; height: 250px !important; }
      @media (max-width: 1199px) { .ad-top-banner .mrg-tag { width: 728px !important; height: 90px !important; } }
      @media (max-width: 768px) { .ad-top-banner .mrg-tag { width: 320px !important; height: 50px !important; } }
      /* ad top adaptive end */
      
      body { max-width: 960px; margin: 0 auto; padding: 16px; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; }
      h1 { margin: 16px 0; }
      textarea { width: 100%; min-height: 240px; padding: 12px; border: 1px solid #e5e7eb; border-radius: 10px; }
      .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-top: 12px; }
      .card { border: 1px solid #e5e7eb; border-radius: 10px; padding: 12px; background: #fff; }
      .num { font-size: 24px; font-weight: 700; }
      .label { color: #6b7280; }

      /* RTL поддержка */
      {% if dir == 'rtl' %}
      body, textarea, .label { text-align: right; direction: rtl; }
      {% endif %}

      /* Адаптивность для мобильных устройств */
      @media (max-width: 768px) {
        body { padding: 12px; }
        .stats { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </head>
  <body>
    <!-- Меню -->
    <div id="menuContainer"></div>
    
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag" 
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}" 
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>
    
    <h1>{{ wordCounter[locale].page.title }}</h1>
    <textarea id="text" placeholder="{{ wordCounter[locale].page.textareaPlaceholder }}"></textarea>
    
    <div class="stats">
      <div class="card">
        <div class="num" id="chars">0</div>
        <div class="label">{{ wordCounter[locale].page.stats.chars }}</div>
      </div>
      <div class="card">
        <div class="num" id="words">0</div>
        <div class="label">{{ wordCounter[locale].page.stats.words }}</div>
      </div>
      <div class="card">
        <div class="num" id="lines">0</div>
        <div class="label">{{ wordCounter[locale].page.stats.lines }}</div>
      </div>
      <div class="card">
        <div class="num" id="spaces">0</div>
        <div class="label">{{ wordCounter[locale].page.stats.spaces }}</div>
      </div>
    </div>

    <script>
      // Вспомогательный селектор
      const qs = (s)=>document.querySelector(s);
      
      // Пересчёт статистики текста
      function recalc() {
        const t = qs('#text').value;
        qs('#chars').textContent = t.length;
        const words = t.trim() ? t.trim().split(/\s+/).length : 0;
        qs('#words').textContent = words;
        const lines = t ? t.split(/\n/).length : 0;
        qs('#lines').textContent = lines;
        const spaces = (t.match(/\s/g) || []).length;
        qs('#spaces').textContent = spaces;
      }
      
      // Обновляем счётчики при вводе
      qs('#text').addEventListener('input', recalc);
      
      // Инициализация при загрузке
      document.addEventListener('DOMContentLoaded', recalc);
    </script>
    
    <!-- Загрузка меню -->
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Инициализация рекламы в шапке
            const adTag = document.querySelector('.mrg-tag');
            const adBanner = document.querySelector('.ad-top-banner');
            
            if (adTag) {
                const script = document.createElement('script');
                import('/frontend/scripts/mail-ads-loader.js').then(m => m.ensureMailAdsScript());
                (window.MRGtag = window.MRGtag || []).push({});

                // Проверка загрузки рекламы
                function checkAdVisibility() {
                    const adContent = adTag;
                    
                    // Проверяем различные условия невидимости рекламы
                    const isAdVisible = adContent && 
                                       adContent.offsetHeight > 0 && 
                                       adContent.innerHTML.trim() !== '' &&
                                       window.getComputedStyle(adContent).display !== 'none' &&
                                       window.getComputedStyle(adContent).visibility !== 'hidden' &&
                                       adContent.getBoundingClientRect().height > 0;
                    
                    if (!isAdVisible) {
                        adBanner.classList.add('hidden');
                    } else {
                        adBanner.classList.remove('hidden');
                    }
                }

                // Проверяем рекламу несколько раз с интервалами
                setTimeout(checkAdVisibility, 2000);
                setTimeout(checkAdVisibility, 5000);
                setTimeout(checkAdVisibility, 10000);

                // Также проверяем при изменении размера окна
                window.addEventListener('resize', function() {
                    setTimeout(checkAdVisibility, 500);
                });

                // Наблюдатель за изменениями в DOM для рекламы
                const mutationObserver = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.type === 'childList' || mutation.type === 'attributes') {
                            setTimeout(checkAdVisibility, 1000);
                        }
                    });
                });

                mutationObserver.observe(adTag, {
                    childList: true,
                    attributes: true,
                    subtree: true
                });
            } else {
                // Если рекламный тег не найден, скрываем баннер сразу
                if (adBanner) {
                    adBanner.classList.add('hidden');
                }
            }

            /*GLOBAL_AD_HOOK*/
            (function(){
                function handleIns(ins){
                    if (!ins || ins.__handled) return; 
                    ins.__handled = true;
                    setTimeout(function(){
                        var has = !!ins.querySelector("iframe");
                        if (!has) { (window.MRGtag=window.MRGtag||[]).push({}); }
                        setTimeout(function(){ 
                            if (!ins.querySelector("iframe")) { 
                                var p=ins.closest(".ad-top-banner,.ad-leaderboard,.promo-ad-inline,#mobile-anchor-ad"); 
                                if(p) p.style.display='none'; 
                            } 
                        }, 2000);
                    });
                }
                document.querySelectorAll("ins.mrg-tag").forEach(handleIns);
                var mo = new MutationObserver(function(muts){
                    muts.forEach(function(m){ 
                        m.addedNodes && m.addedNodes.forEach(function(n){ 
                            if(n.querySelectorAll){ 
                                n.querySelectorAll("ins.mrg-tag").forEach(handleIns); 
                            } 
                        }); 
                    });
                });
                mo.observe(document.documentElement,{childList:true,subtree:true});
            })();
        });
    </script>
    
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(wordCounter[locale].ads.closeAria) }}
</body>
</html>
