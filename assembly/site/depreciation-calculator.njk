---
# Используем глобальный список языков
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/logistics/depreciation-calculator.html{% else %}/frontend/{{ locale }}/tools/logistics/depreciation-calculator.html{% endif %}"
eleventyComputed:
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  title: "{{ depreciationCalculator[locale].meta.title }}"
  description: "{{ depreciationCalculator[locale].meta.description }}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/logistics/depreciation-calculator.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/logistics/depreciation-calculator.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <meta name="i18n-scope" content="tools.depreciation">
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ depreciationCalculator[locale].meta.title }}</title>
    <meta name="description" content="{{ depreciationCalculator[locale].meta.description }}">
    <!-- Open Graph -->
    <meta property="og:title" content="{{ depreciationCalculator[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ depreciationCalculator[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ depreciationCalculator[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ depreciationCalculator[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    
    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />
    
    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/logistics/depreciation-calculator.html" hreflang="{{ loc }}" />
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/logistics/depreciation-calculator.html" hreflang="{{ loc }}" />
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/logistics/depreciation-calculator.html" hreflang="x-default" />      <!-- Structured Data: SoftwareApplication -->     <script type="application/ld+json">     {       "@context": "https://schema.org",       "@type": "SoftwareApplication",       "name": "{{ depreciationCalculator[locale].meta.title | replace('"', '&quot;') }}",       "description": "{{ depreciationCalculator[locale].meta.description | replace('"', '&quot;') }}",       "url": "{{ canonical }}",       "applicationCategory": "UtilityApplication",       "operatingSystem": "Web",       "inLanguage": "{{ locale }}",       "offers": {         "@type": "Offer",         "price": "0",         "priceCurrency": "RUB"       },       "publisher": {         "@type": "Organization",         "name": "Serpmonn",         "url": "{{ site.baseUrl }}/"       }     }     </script>
    
    <link rel="icon" href="/frontend/images/serpmonn.ico" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <!-- Стили для калькулятора амортизации -->
    <link rel="stylesheet" href="/frontend/styles/tools/depreciation-calculator.css">
    
    <!-- Инлайн-стили только для рекламных блоков (необходимы для корректного отображения рекламы) -->
    <style>
      .ad-top-banner .mrg-tag { 
        width: 970px !important; 
        height: 250px !important; 
      }
      @media (max-width: 1199px) { 
        .ad-top-banner .mrg-tag { 
          width: 728px !important; 
          height: 90px !important; 
        } 
      }
      @media (max-width: 768px) { 
        .ad-top-banner .mrg-tag { 
          width: 320px !important; 
          height: 50px !important; 
        } 
      }
    </style>
  </head>
  <body class="depreciation-calculator" data-currency="{{ depreciationCalculator[locale].common.currency }}" data-month="{{ depreciationCalculator[locale].common.month }}">
    <!-- Меню -->
    <div id="menuContainer"></div>

    <!-- Хлебные крошки -->
    <div class="breadcrumb">
      <a href="{% if locale == 'ru' %}/frontend/tools/index.html{% else %}/frontend/{{ locale }}/tools/index.html{% endif %}">{{ depreciationCalculator[locale].breadcrumbs.tools }}</a> → 
      <span>{{ depreciationCalculator[locale].breadcrumbs.current }}</span>
    </div>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "{{ depreciationCalculator[locale].breadcrumbs.tools }}",
          "item": "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/index.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/index.html{% endif %}"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ depreciationCalculator[locale].breadcrumbs.current }}",
          "item": "{{ canonical }}"
        }
      ]
    }
    </script>

    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag" 
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}" 
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>

    <h1>{{ depreciationCalculator[locale].page.title }}</h1>
    <div class="calculator-container">
      <h2>{{ depreciationCalculator[locale].form.sectionTitle }}</h2>
      <div id="error-message" class="error-message hidden" role="alert"></div>
      <div class="input-section">
        <div class="input-group">
          <label for="carBrand">{{ depreciationCalculator[locale].form.labels.carBrand }}</label>
          <input type="text" id="carBrand" list="carBrands" placeholder="{{ depreciationCalculator[locale].form.placeholders.carBrand }}" title="{{ depreciationCalculator[locale].form.titles.carBrand }}">
          <datalist id="carBrands">
            {% for brand in depreciationCalculator[locale].form.brandOptions %}
            <option value="{{ brand }}">
            {% endfor %}
          </datalist>
        </div>
        <div class="input-group">
          <label for="carModel">{{ depreciationCalculator[locale].form.labels.carModel }}</label>
          <input type="text" id="carModel" placeholder="{{ depreciationCalculator[locale].form.placeholders.carModel }}" title="{{ depreciationCalculator[locale].form.titles.carModel }}">
        </div>
        <div class="input-group">
          <label for="carYear">{{ depreciationCalculator[locale].form.labels.carYear }}</label>
          <input type="number" id="carYear" min="1990" max="2025" value="2020" title="{{ depreciationCalculator[locale].form.titles.carYear }}">
        </div>
        <div class="input-group">
          <label for="initialPrice">{{ depreciationCalculator[locale].form.labels.initialPrice }}</label>
          <input type="number" id="initialPrice" placeholder="1500000" min="100000" title="{{ depreciationCalculator[locale].form.titles.initialPrice }}">
        </div>
        <div class="input-group">
          <label for="currentMileage">{{ depreciationCalculator[locale].form.labels.currentMileage }}</label>
          <input type="number" id="currentMileage" placeholder="50000" min="0" title="{{ depreciationCalculator[locale].form.titles.currentMileage }}">
        </div>
        <div class="input-group">
          <label for="usageType">{{ depreciationCalculator[locale].form.labels.usageType }}</label>
          <select id="usageType" title="{{ depreciationCalculator[locale].form.titles.usageType }}">
            {% for option in depreciationCalculator[locale].form.usageTypeOptions %}
            <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="input-group">
          <label for="fuelType">{{ depreciationCalculator[locale].form.labels.fuelType }}</label>
          <select id="fuelType" title="{{ depreciationCalculator[locale].form.titles.fuelType }}">
            {% for option in depreciationCalculator[locale].form.fuelTypeOptions %}
            <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="input-group">
          <label for="maintenanceLevel">{{ depreciationCalculator[locale].form.labels.maintenanceLevel }}</label>
          <select id="maintenanceLevel" title="{{ depreciationCalculator[locale].form.titles.maintenanceLevel }}">
            {% for option in depreciationCalculator[locale].form.maintenanceOptions %}
            <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="input-group">
          <label for="climateZone">{{ depreciationCalculator[locale].form.labels.climateZone }}</label>
          <select id="climateZone" title="{{ depreciationCalculator[locale].form.titles.climateZone }}">
            {% for option in depreciationCalculator[locale].form.climateOptions %}
            <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="input-group">
          <label for="region">{{ depreciationCalculator[locale].form.labels.region }}</label>
          <select id="region" title="{{ depreciationCalculator[locale].form.titles.region }}">
            {% for option in depreciationCalculator[locale].form.regionOptions %}
            <option value="{{ option.value }}">{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="input-group">
          <label for="currentNewPrice">{{ depreciationCalculator[locale].form.labels.currentNewPrice }}</label>
          <input type="number" id="currentNewPrice" placeholder="900000" min="100000" title="{{ depreciationCalculator[locale].form.titles.currentNewPrice }}">
          <small style="color: #6c757d; font-size: 12px;">{{ depreciationCalculator[locale].form.hints.currentNewPrice }}</small>
        </div>
        <div class="input-group">
          <label for="marketGrowth">{{ depreciationCalculator[locale].form.labels.marketGrowth }}</label>
          <input type="number" id="marketGrowth" placeholder="40" min="0" max="200" value="40" title="{{ depreciationCalculator[locale].form.titles.marketGrowth }}">
          <small style="color: #6c757d; font-size: 12px;">{{ depreciationCalculator[locale].form.hints.marketGrowth }}</small>
        </div>
        <div class="input-group">
          <label for="inflationRate">{{ depreciationCalculator[locale].form.labels.inflationRate }}</label>
          <input type="number" id="inflationRate" placeholder="5" min="0" max="50" value="5" title="{{ depreciationCalculator[locale].form.titles.inflationRate }}">
          <small style="color: #6c757d; font-size: 12px;">{{ depreciationCalculator[locale].form.hints.inflationRate }}</small>
        </div>
        <div class="input-group">
          <label for="demandLevel">{{ depreciationCalculator[locale].form.labels.demandLevel }}</label>
          <select id="demandLevel" title="{{ depreciationCalculator[locale].form.titles.demandLevel }}">
            {% for option in depreciationCalculator[locale].form.demandOptions %}
            <option value="{{ option.value }}" {% if option.selected %}selected{% endif %}>{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="input-group">
          <label for="technicalCondition">{{ depreciationCalculator[locale].form.labels.technicalCondition }}</label>
          <select id="technicalCondition" title="{{ depreciationCalculator[locale].form.titles.technicalCondition }}">
            {% for option in depreciationCalculator[locale].form.conditionOptions %}
            <option value="{{ option.value }}" {% if option.selected %}selected{% endif %}>{{ option.label }}</option>
            {% endfor %}
          </select>
          <small style="color: #6c757d; font-size: 12px;">{{ depreciationCalculator[locale].form.hints.technicalCondition }}</small>
        </div>
      </div>
      <div style="text-align: center;">
        <button class="calculate-btn" onclick="calculateDepreciation()" aria-label="{{ depreciationCalculator[locale].aria.calculate }}">{{ depreciationCalculator[locale].buttons.calculate }}</button>
        <button class="reset-btn" onclick="resetForm()" aria-label="{{ depreciationCalculator[locale].aria.reset }}">{{ depreciationCalculator[locale].buttons.reset }}</button>
        <button class="share-btn" onclick="copyShareLink()" aria-label="{{ depreciationCalculator[locale].aria.share }}">{{ depreciationCalculator[locale].buttons.share }}</button>
        <button class="export-btn" onclick="exportToPDF()" aria-label="{{ depreciationCalculator[locale].aria.export_pdf }}">{{ depreciationCalculator[locale].buttons.export_pdf }}</button>
        <button class="csv-btn" onclick="exportToCSV()" aria-label="{{ depreciationCalculator[locale].aria.export_csv }}">{{ depreciationCalculator[locale].buttons.export_csv }}</button>
      </div>
      <div id="results" class="results hidden" aria-live="polite">
        <h3>{{ depreciationCalculator[locale].results.title }}</h3>
        <canvas id="depreciationChart" style="max-height: 300px; margin-top: 20px;"></canvas>
        <div class="result-grid">
          <div class="result-item">
            <div class="result-value" id="currentValue">0 {{ depreciationCalculator[locale].common.currency }}</div>
            <div class="result-label">{{ depreciationCalculator[locale].results.currentValue }}</div>
          </div>
          <div class="result-item">
            <div class="result-value" id="totalDepreciation">0 {{ depreciationCalculator[locale].common.currency }}</div>
            <div class="result-label">{{ depreciationCalculator[locale].results.totalDepreciation }}</div>
          </div>
          <div class="result-item">
            <div class="result-value" id="depreciationPercent">0%</div>
            <div class="result-label">{{ depreciationCalculator[locale].results.depreciationPercent }}</div>
          </div>
          <div class="result-item">
            <div class="result-value" id="monthlyDepreciation">0 {{ depreciationCalculator[locale].common.currency }}/{{ depreciationCalculator[locale].common.month }}</div>
            <div class="result-label">{{ depreciationCalculator[locale].results.monthlyDepreciation }}</div>
          </div>
        </div>
      </div>
    </div>
    <div id="breakdown" class="breakdown hidden" aria-live="polite">
      <h3>{{ depreciationCalculator[locale].breakdown.title }}</h3>
      <div id="breakdownList"></div>
    </div>
    <div id="history" class="history hidden" aria-live="polite">
      <h3>{{ depreciationCalculator[locale].history.title }}</h3>
      <ul id="historyList"></ul>
    </div>
    <div class="info-tips">
      <h3>💡 {{ depreciationCalculator[locale].tips.title }}</h3>
      {% for tip in depreciationCalculator[locale].tips.items %}
      <div class="tip-item">{{ tip | safe }}</div>
      {% endfor %}
    </div>
    {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
    {{ mobileAnchor(depreciationCalculator[locale].aria.closeAd) }}
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script type="module" src="/frontend/scripts/tools/depreciation-calculator.js?v=2" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  {% include "partials/ad-pool-init.njk" %}
</body>
</html>
