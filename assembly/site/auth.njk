---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/auth/auth.html{% else %}/frontend/{{ locale }}/auth/auth.html{% endif %}"
eleventyComputed:
  title: "{{ authTranslations[locale].pageTitle }}"
  description: "{{ authTranslations[locale].ogDescription }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/auth/auth.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/auth/auth.html{% endif %}"
---

{% set auth = authTranslations[locale] %}
<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">

    <meta property="og:title" content="{{ auth.ogTitle }}">
    <meta property="og:description" content="{{ auth.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ auth.ogTitle }}">
    <meta name="twitter:description" content="{{ auth.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">

    <link rel="icon" href="/frontend/images/serpmonn.ico" type="image/x-icon">
    <link rel="canonical" href="{{ canonical }}">

    {% for loc in locales %}
      {% if loc == 'ru' %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/auth/auth.html" hreflang="{{ loc }}" />
      {% else %}
        <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/auth/auth.html" hreflang="{{ loc }}" />
      {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/auth/auth.html" hreflang="x-default" />

    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <link rel="stylesheet" href="auth_styles.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
</head>
<body>
    <div class="container auth-container">
        <h2>{{ auth.mainTitle }}</h2>

        <div id="authFormsView">
            <div id="VkIdSdkOneTap" class="vk-auth-widget" aria-label="{{ auth.vkButton }}"></div>

            <button type="button" id="messengerLoginBtn" class="messenger-login-btn">
                {{ auth.messengerButton }}
            </button>

            <p class="auth-divider"><span>{{ auth.orDivider }}</span></p>

            <div class="auth-tabs" role="tablist">
                <button type="button" class="auth-tab active" data-tab="login" role="tab" aria-selected="true" id="tab-login">{{ auth.tabLogin }}</button>
                <button type="button" class="auth-tab" data-tab="register" role="tab" aria-selected="false" id="tab-register">{{ auth.tabRegister }}</button>
            </div>

            <div id="panel-login" class="auth-panel active" role="tabpanel" aria-labelledby="tab-login">
                <form id="loginForm">
                    <label for="loginEmail">{{ auth.emailLabel }}</label>
                    <input type="email" id="loginEmail" name="email" autocomplete="email" required>

                    <label for="loginPassword">{{ auth.passwordLabel }}</label>
                    <div class="password-container">
                        <input type="password" id="loginPassword" name="password" autocomplete="current-password" required>
                        <button type="button" class="toggle-password" data-target="loginPassword" aria-label="{{ auth.togglePasswordAria }}">👁</button>
                    </div>

                    <button class="submit-btn" type="submit">{{ auth.loginSubmit }}</button>
                </form>
                <p class="auth-forgot">
                    <a href="{% if locale == 'ru' %}/frontend/login/forgot/forgot.html{% else %}/frontend/{{ locale }}/login/forgot/forgot.html{% endif %}">{{ auth.forgotPassword }}</a>
                </p>
            </div>

            <div id="panel-register" class="auth-panel" role="tabpanel" aria-labelledby="tab-register" hidden>
                <form id="registerForm">
                    <label for="registerEmail">{{ auth.emailLabel }}</label>
                    <input type="email" id="registerEmail" name="email" autocomplete="email" required>

                    <label for="registerPassword">{{ auth.passwordLabel }}</label>
                    <div class="password-container">
                        <input type="password" id="registerPassword" name="password" autocomplete="new-password" minlength="6" required>
                        <button type="button" class="toggle-password" data-target="registerPassword" aria-label="{{ auth.togglePasswordAria }}">👁</button>
                    </div>

                    <label class="policy-checkbox">
                        <input type="checkbox" id="policyCheckbox" required>
                        {{ registerTranslations[locale].register.policyText | safe }}
                    </label>

                    <button class="submit-btn" type="submit">{{ auth.registerSubmit }}</button>
                </form>
            </div>

            <p id="message" class="auth-message" role="status"></p>
        </div>

        <div id="registerSuccessView" class="register-success" hidden>
            <h3>{{ auth.registerSuccessTitle }}</h3>
            <p id="registerSuccessText"></p>
            <template id="registerSuccessTemplate">{{ auth.registerSuccessText | safe }}</template>
            <button type="button" class="submit-btn secondary-btn" id="backToLoginBtn">{{ auth.backToLogin }}</button>
        </div>
    </div>

    <div id="messengerLoginModal" class="messenger-modal" hidden>
        <div class="messenger-modal__backdrop" data-messenger-close></div>
        <div class="messenger-modal__card" role="dialog" aria-modal="true" aria-labelledby="messengerLoginTitle">
            <h3 id="messengerLoginTitle">{{ auth.messengerModalTitle }}</h3>
            <p class="messenger-modal__hint">{{ auth.messengerModalHint }}</p>
            <canvas id="messengerQrCanvas" width="220" height="220" aria-label="QR"></canvas>
            <p class="messenger-modal__code">{{ auth.messengerCodeLabel }}: <strong id="messengerShortCode">————</strong></p>
            <p id="messengerLoginStatus" class="messenger-modal__status">{{ auth.messengerWaiting }}</p>
            <button type="button" class="submit-btn secondary-btn" data-messenger-close>{{ auth.messengerCancel }}</button>
        </div>
    </div>

    <script type="module" src="auth_scripts.js" defer></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
