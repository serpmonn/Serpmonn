<div class="news-container" id="news-container">
  <h1>{{ heading }}</h1>
  {% if subheading %}
    <p style="text-align: center;">{{ subheading }}</p>
  {% endif %}

  <div class="news-block" id="news-block" style="display:none;">
    <div class="news-block-header">
      <div class="news-dot"></div>
      <span class="news-block-title">{{ newsLabel }}</span>
    </div>

    <a class="combo-hero" id="news-hero" href="#" target="_blank" rel="noopener noreferrer">
      <span class="news-tag" id="news-hero-tag"></span>
      <p class="combo-hero-headline" id="news-hero-headline"></p>
      <p class="combo-hero-desc" id="news-hero-desc"></p>
      <div class="combo-hero-meta">
        <span class="news-source" id="news-hero-source"></span>
        <span class="news-time" id="news-hero-time"></span>
      </div>
    </a>

    <div class="feed-wrapper">
      <div class="news-feed" id="news-feed"></div>
    </div>
  </div>
</div>

<script>
(function () {
  var locale = document.documentElement.lang || 'ru';

  function timeAgo(dateStr) {
    if (!dateStr) return '';
    var diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 60000);
    if (diff < 1) return '<1 мин';
    if (diff < 60) return diff + ' мин';
    var h = Math.floor(diff / 60);
    if (h < 24) return h + ' ч';
    return Math.floor(h / 24) + ' д';
  }

  function tagClass(category) {
    var map = { ai: 'ai', tech: 'tech', world: 'world', science: 'sci', sport: 'sport' };
    return map[category] || 'ai';
  }

  fetch('/api/news?locale=' + encodeURIComponent(locale))
    .then(function (r) { return r.ok ? r.json() : null; })
    .then(function (data) {
      if (!data || !Array.isArray(data.news) || data.news.length === 0) return;

      var items = data.news;
      var hero = items[0];
      var rest = items.slice(1);

      var block = document.getElementById('news-block');
      var heroEl = document.getElementById('news-hero');
      var heroTag = document.getElementById('news-hero-tag');
      var heroHeadline = document.getElementById('news-hero-headline');
      var heroDesc = document.getElementById('news-hero-desc');
      var heroSource = document.getElementById('news-hero-source');
      var heroTime = document.getElementById('news-hero-time');
      var feed = document.getElementById('news-feed');

      heroEl.href = hero.url || '#';
      heroTag.textContent = hero.category || '';
      heroTag.className = 'news-tag ' + tagClass(hero.category);
      heroHeadline.textContent = hero.title || '';
      heroDesc.textContent = hero.description || '';
      heroSource.textContent = hero.source || '';
      heroTime.textContent = timeAgo(hero.publishedAt);

      feed.innerHTML = rest.map(function (item) {
        return '<a class="card" href="' + (item.url || '#') + '" target="_blank" rel="noopener noreferrer">'
          + '<span class="news-tag ' + tagClass(item.category) + '">' + (item.category || '') + '</span>'
          + '<p class="card-headline">' + (item.title || '') + '</p>'
          + '<div class="card-meta">'
          + '<span class="card-source">' + (item.source || '') + '</span>'
          + '<span class="card-time">' + timeAgo(item.publishedAt) + '</span>'
          + '</div></a>';
      }).join('');

      block.style.display = 'block';
    })
    .catch(function () {});
}());
</script>