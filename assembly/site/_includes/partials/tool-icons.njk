{# Map own web-game URL → stroke icon #}
{% macro webGameIcon(link, tone='item') %}
  {%- if '/2048/' in link -%}{{ toolIcon('g2048', tone) }}
  {%- elif '/flappy/' in link -%}{{ toolIcon('flappy', tone) }}
  {%- elif '/coins/' in link -%}{{ toolIcon('coins', tone) }}
  {%- elif '/breakout/' in link -%}{{ toolIcon('breakout', tone) }}
  {%- elif '/snake/' in link -%}{{ toolIcon('snake', tone) }}
  {%- elif '/minesweeper/' in link -%}{{ toolIcon('mines', tone) }}
  {%- elif '/fifteen/' in link -%}{{ toolIcon('fifteen', tone) }}
  {%- elif '/redsquare2/' in link -%}{{ toolIcon('shapes', tone) }}
  {%- elif '/redsquare/' in link -%}{{ toolIcon('square', tone) }}
  {%- elif '/typing/' in link -%}{{ toolIcon('keyboard', tone) }}
  {%- elif '/rat/' in link -%}{{ toolIcon('rat', tone) }}
  {%- else -%}{{ toolIcon('games', tone) }}
  {%- endif -%}
{% endmacro %}
