---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/main.html{% else %}/frontend/{{ locale }}/index.html{% endif %}"
eleventyComputed:
  layout: "layouts/base.njk"
  adsEnabled: false
  title: "{{ i18n[locale].title }}"
  description: "{{ i18n[locale].description }}"
  keywords: "{{ i18n[locale].keywords }}"
  ogTitle: "{{ i18n[locale].ogTitle }}"
  ogDescription: "{{ i18n[locale].ogDescription }}"
  twitterTitle: "{{ i18n[locale].twitterTitle }}"
  twitterDescription: "{{ i18n[locale].twitterDescription }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  heading: "{{ i18n[locale].heading }}"
  cookieNotice: "{{ i18n[locale].cookie.text }}"
  acceptLabel: "{{ i18n[locale].cookie.accept }}"
  declineLabel: "{{ i18n[locale].cookie.decline }}"
  privacyLink: "{{ i18n[locale].cookie.privacyLink }}"
  privacyLinkText: "{{ i18n[locale].cookie.privacyLinkText }}"
  searchPlaceholder: "{{ i18n[locale].searchPlaceholder }}"
  searchInputTitle: "{{ i18n[locale].searchInputTitle }}"
  voiceInputLabel: "{{ i18n[locale].voiceInputLabel }}"
  voiceInputTitle: "{{ i18n[locale].voiceInputTitle }}"
  submitLabel: "{{ i18n[locale].submitLabel }}"
  submitTitle: "{{ i18n[locale].submitTitle }}"
  copyAnswerLabel: "{{ i18n[locale].copyAnswerLabel }}"
  shareAnswerLabel: "{{ i18n[locale].shareAnswerLabel }}"
  likeLabel: "{{ i18n[locale].likeLabel }}"
  dislikeLabel: "{{ i18n[locale].dislikeLabel }}"
  saveFindingLabel: "{{ findingPageI18n[locale].saveLabel }}"
  shareModalTitle: "{{ i18n[locale].shareModalTitle }}"
  telegramLabel: "{{ i18n[locale].telegramLabel }}"
  vkLabel: "{{ i18n[locale].vkLabel }}"
  newsLabel: "{{ i18n[locale].newsLabel }}"
  newsPrevLabel: "{{ i18n[locale].newsPrevLabel }}"
  newsNextLabel: "{{ i18n[locale].newsNextLabel }}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/{% else %}{{ site.baseUrl }}/{{ locale }}/{% endif %}"
---

<div class="search-card-wrapper">
  <div class="main-search-container">
    <img src="/frontend/images/serpmonn.ico?v=3" alt="{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}" class="logo" title="{% if locale == 'ru' %}Серпмонн{% else %}Serpmonn{% endif %}">

    <form id="ai-search-form" class="search-form">
      <div class="search-form-body">
        <div class="search-form-row">
          <div class="search-input-wrapper">
        <button 
          type="button" 
          id="attach-txt-btn"
          class="attach-btn"
          aria-label="Attach text file"
          title="Attach a .txt file"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
        </button>
        <input
          type="file"
          id="attach-txt-input"
          accept=".txt,text/plain"
          hidden
        >

        <input 
          type="search" 
          name="q" 
          placeholder="{{ searchPlaceholder }}"
          autocomplete="off"
          required
          autofocus
          title="{{ searchInputTitle }}"
        >

        <button 
          type="button" 
          id="voice-input-btn"
          class="voice-btn is-hidden"
          aria-label="{{ voiceInputLabel }}"
          title="{{ voiceInputTitle }}"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
            <line x1="12" y1="19" x2="12" y2="23"/>
            <line x1="8" y1="23" x2="16" y2="23"/>
          </svg>
        </button>
          </div>

          <button 
            type="submit" 
            aria-label="{{ submitLabel }}"
            class="search-btn"
            title="{{ submitTitle }}"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" 
                stroke="#ff4d4d" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7" />
              <polyline points="7 7 17 7 17 17" />
            </svg>
          </button>
        </div>

        <div id="search-attachment-preview" class="search-attachment-preview" hidden></div>
      </div>
    </form>
  </div>

  <div id="ai-result-container" class="ai-result-container" style="display: none;">
    <div id="ai-result-content" class="ai-result-content"></div>

    <div class="ai-result-footer is-pending">
      <div class="ai-actions">
        <button class="ai-action-btn" data-ai-action="copy" title="{{ copyAnswerLabel }}" aria-label="{{ copyAnswerLabel }}" >
          <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="9" y="9" width="10" height="12" rx="2"></rect>
            <rect x="5" y="3" width="10" height="12" rx="2"></rect>
          </svg>
        </button>

        <button class="ai-action-btn" data-ai-action="share" title="{{ shareAnswerLabel }}" aria-label="{{ shareAnswerLabel }}" >
          <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 12v6a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-6"></path>
            <path d="M12 5l0 12"></path>
            <path d="M8 9l4-4 4 4"></path>
          </svg>
        </button>

        <button class="ai-action-btn" data-ai-action="save-finding" title="{{ saveFindingLabel }}" aria-label="{{ saveFindingLabel }}">
          <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
            <polyline points="17 21 17 13 7 13 7 21"></polyline>
            <polyline points="7 3 7 8 15 8"></polyline>
          </svg>
        </button>
      </div>

      <div class="ai-feedback">
        <button class="feedback-btn like" title="{{ likeLabel }}" aria-label="{{ likeLabel }}">
          <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 11v10"></path>
            <path d="M3 11h4"></path>
            <path d="M9 21h7.2a2 2 0 0 0 2-1.6l1.2-7A2 2 0 0 0 17.4 10H14l.5-3.5A2 2 0 0 0 12.5 4l-3.2 5.1A2 2 0 0 1 8 10H7"></path>
          </svg>
        </button>

        <button class="feedback-btn dislike" title="{{ dislikeLabel }}" aria-label="{{ dislikeLabel }}">
          <svg class="ai-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 13V3"></path>
            <path d="M3 13h4"></path>
            <path d="M9 3h7.2a2 2 0 0 1 2 1.6l1.2 7A2 2 0 0 1 17.4 14H14l.5 3.5A2 2 0 0 1 12.5 20l-3.2-5.1A2 2 0 0 0 8 14H7"></path>
          </svg>
        </button>
      </div>

      <div class="ai-timestamp" id="ai-timestamp"></div>
    </div>
  </div>

  <div id="ai-image-results" class="ai-image-results" style="display:none;"></div>
  <div id="ai-video-results" class="ai-video-results" style="display:none;"></div>

  <div id="ai-share-modal" class="ai-share-modal" style="display:none;">
    <div class="ai-share-backdrop"></div>
    <div class="ai-share-dialog" tabindex="-1">
      <div class="ai-share-title">{{ shareModalTitle }}</div>

      <div class="ai-share-quick">
        <a class="ai-share-pill ai-share-telegram" target="_blank" rel="noopener" title="{{ telegramLabel }}" aria-label="{{ telegramLabel }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 240 240" aria-hidden="true">
            <defs>
              <linearGradient id="ai_tg_grad" x1="0" x2="1" y1="1" y2="0">
                <stop offset="0" stop-color="#1d93d2"/>
                <stop offset="1" stop-color="#38b0e3"/>
              </linearGradient>
            </defs>
            <circle cx="120" cy="120" r="120" fill="url(#ai_tg_grad)"/>
            <path fill="#fff" d="M179 72L58 117c-3 1-4 3-4 5 0 3 2 4 5 5l29 9 11 35c1 3 2 4 4 5h1c2 0 3-1 4-2l16-16 29 21c2 1 3 2 5 2 1 0 3 0 4-2 1-1 2-3 2-5l13-94c0-3-1-5-3-6-2-1-4-1-6 0z"/>
          </svg>
        </a>

        <a class="ai-share-pill ai-share-vk" target="_blank" rel="noopener" title="{{ vkLabel }}" aria-label="{{ vkLabel }}">
          <span class="ai-share-pill-icon ai-share-pill-icon--vk" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M13.162 18.994c.609 0 .85-.407.84-1.024-.032-1.82.614-2.737 2.066-1.26 1.64 1.67 1.986 2.284 3.408 2.284h2.742c.814 0 1.143-.27.95-.8-.48-1.327-4.297-5.17-4.056-5.512.222-.317 3.347-4.596 3.604-5.664.13-.54-.1-.8-.72-.8H18.22c-.69 0-.91.38-1.14.96-1.048 2.7-2.86 5.073-3.57 4.633-.69-.424-.52-2.686-.484-4.252.02-.75.013-1.557-.746-1.738-.518-.124-1.26-.108-1.76-.108-1.47 0-2.67.5-2.018 1.36.49.643.637 1.934.44 4.26-.26 3.117-3.148-.95-4.29-4.17-.285-.81-.567-1.25-1.3-1.25H1.616c-.777 0-.932.366-.72.972 1.37 3.956 5.87 12.638 12.266 12.11z"/>
            </svg>
          </span>
        </a>

        <a class="ai-share-pill ai-share-max" target="_blank" rel="noopener" title="MAX" aria-label="MAX">
          <span class="ai-share-pill-icon ai-share-pill-icon--max" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 42 42" fill="currentColor">
              <path fill-rule="evenodd" d="M21.47 41.88c-4.11 0-6.02-.6-9.34-3-2.1 2.7-8.75 4.81-9.04 1.2 0-2.71-.6-5-1.28-7.5C1 29.5.08 26.07.08 21.1.08 9.23 9.82.3 21.36.3c11.55 0 20.6 9.37 20.6 20.91a20.6 20.6 0 0 1-20.49 20.67m.17-31.32c-5.62-.29-10 3.6-10.97 9.7-.8 5.05.62 11.2 1.83 11.52.58.14 2.04-1.04 2.95-1.95a10.4 10.4 0 0 0 5.08 1.81 10.7 10.7 0 0 0 11.19-9.97 10.7 10.7 0 0 0-10.08-11.1Z" clip-rule="evenodd"/>
            </svg>
          </span>
        </a>

        <a class="ai-share-pill ai-share-ok" target="_blank" rel="noopener" title="OK" aria-label="OK">
          <span class="ai-share-pill-icon ai-share-pill-icon--ok" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11 11-4.925 11-11S18.075 1 12 1zm0 4.5a3.5 3.5 0 110 7 3.5 3.5 0 010-7zm3.75 9.25c.47.47.47 1.23 0 1.7l-1.9 1.9c.52.14 1.05.23 1.6.27.66.05 1.16.62 1.11 1.28-.05.66-.62 1.16-1.28 1.11-1.45-.11-2.82-.62-3.98-1.44-1.16.82-2.53 1.33-3.98 1.44-.66.05-1.23-.45-1.28-1.11-.05-.66.45-1.23 1.11-1.28.55-.04 1.08-.13 1.6-.27l-1.9-1.9c-.47-.47-.47-1.23 0-1.7.47-.47 1.23-.47 1.7 0L12 16.54l2.05-2.04c.47-.47 1.23-.47 1.7 0z"/>
            </svg>
          </span>
        </a>

      </div>

      <div class="ai-share-copy-row">
        <input type="text" class="ai-share-url-input" readonly aria-hidden="true" tabindex="-1">
        <button type="button" class="ai-share-copy-btn"></button>
      </div>
    </div>
  </div>
</div>

<div id="ai-share-toast" class="ai-share-toast" style="display:none;"></div>

<div id="finding-save-modal" class="ai-share-modal" style="display:none;" role="dialog" aria-modal="true" aria-labelledby="finding-save-title" data-mode="confirm">
  <div class="ai-share-backdrop"></div>
  <div class="ai-share-dialog finding-save-dialog" tabindex="-1">
    <button type="button" class="ai-share-close finding-save-close" aria-label="Close">&times;</button>
    <div class="ai-share-title" id="finding-save-title">Finding saved</div>

    <div class="finding-save-section finding-save-section--confirm" data-finding-section="confirm">
      <div class="finding-save-actions finding-save-actions--row finding-save-actions--dual">
        <button type="button" class="ai-share-copy-btn" data-finding-action="save-private">Save to profile</button>
        <button type="button" class="finding-share-toggle-btn" data-finding-action="share-open">Share</button>
      </div>
      <button type="button" class="finding-save-cancel-btn finding-save-cancel-btn--full" data-finding-action="cancel">Cancel</button>
    </div>
  </div>
</div>

<script src="https://unpkg.com/@vkontakte/vk-bridge@2.6.0/dist/browser.min.js"></script>
<script>
  if (window.vkBridge) {
    vkBridge.send('VKWebAppInit');
  }
</script>
