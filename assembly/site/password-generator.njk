---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/tools/security/password-generator.html{% else %}/frontend/{{ locale }}/tools/security/password-generator.html{% endif %}"
eleventyComputed:
  title: "{{ passwordGenerator[locale].meta.title }}"
  description: "{{ passwordGenerator[locale].meta.description }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/tools/security/password-generator.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/tools/security/password-generator.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
  <head>
    <link rel="stylesheet" href="/frontend/styles/styles.css">
    <meta http-equiv="Content-Language" content="{{ locale }}">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    
    <!-- Open Graph -->
    <meta property="og:title" content="{{ passwordGenerator[locale].meta.ogTitle }}">
    <meta property="og:description" content="{{ passwordGenerator[locale].meta.ogDescription }}">
    <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">  <!-- ИСПРАВЛЕНО: {{ site.baseUrl }} -->
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:type" content="website">
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ passwordGenerator[locale].meta.twitterTitle }}">
    <meta name="twitter:description" content="{{ passwordGenerator[locale].meta.twitterDescription }}">
    <meta name="twitter:image" content="{{ site.baseUrl }}/frontend/images/Banner_Serpmonn.png">  <!-- ИСПРАВЛЕНО: {{ site.baseUrl }} -->

    <!-- Каноническая ссылка -->
    <link rel="canonical" href="{{ canonical }}" />

    <!-- Hreflang для всех языков -->
    {% for loc in locales %}
        {% if loc == 'ru' %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/security/password-generator.html" hreflang="{{ loc }}" />  <!-- ИСПРАВЛЕНО: добавлен security/ -->
        {% else %}
            <link rel="alternate" href="{{ site.baseUrl }}/frontend/{{ loc }}/tools/security/password-generator.html" hreflang="{{ loc }}" />  <!-- ИСПРАВЛЕНО: добавлен security/ -->
        {% endif %}
    {% endfor %}
    <link rel="alternate" href="{{ site.baseUrl }}/frontend/tools/security/password-generator.html" hreflang="x-default" />      <!-- Structured Data: SoftwareApplication -->     <script type="application/ld+json">     {       "@context": "https://schema.org",       "@type": "SoftwareApplication",       "name": "{{ passwordGenerator[locale].meta.title | replace('"', '&quot;') }}",       "description": "{{ passwordGenerator[locale].meta.description | replace('"', '&quot;') }}",       "url": "{{ canonical }}",       "applicationCategory": "UtilityApplication",       "operatingSystem": "Web",       "inLanguage": "{{ locale }}",       "offers": {         "@type": "Offer",         "price": "0",         "priceCurrency": "RUB"       },       "publisher": {         "@type": "Organization",         "name": "Serpmonn",         "url": "{{ site.baseUrl }}/"       }     }     </script>  <!-- ИСПРАВЛЕНО: добавлен security/ -->

    <link rel="icon" href="/frontend/images/serpmonn.ico?v=3" type="image/x-icon">
    <link rel="stylesheet" href="/frontend/styles/base.css">
    <link rel="stylesheet" href="/frontend/styles/accessibility.css">
    <link rel="stylesheet" href="/frontend/styles/menu.css">
    <link rel="stylesheet" href="/frontend/styles/tools/tools-shell.css?v=3">
  </head>
  <body class="spn-tool password-generator-page">
    <div id="menuContainer"></div>

    <script async src="https://ad.mail.ru/static/ads-async.js"></script>
    <div class="ad-top-banner" style="text-align:center;margin:16px 0;">
      <ins class="mrg-tag"
          style="display:inline-block;"
          data-ad-client="ad-{{ mailAds.slots.top.id }}"
          data-ad-slot="{{ mailAds.slots.top.id }}">
      </ins>
    </div>

    <h1>{{ passwordGenerator[locale].page.title }}</h1>
    {% if passwordGenerator[locale].page.lead %}
    <p class="tool-lead">{{ passwordGenerator[locale].page.lead }}</p>
    {% endif %}

    <div class="calculator-container">
      <h2>{{ passwordGenerator[locale].page.formTitle if passwordGenerator[locale].page.formTitle else 'Параметры' }}</h2>
      <div id="error-message" class="error-message hidden" role="alert"></div>

      <div class="input-section">
        <div class="input-group">
          <label for="len">{{ passwordGenerator[locale].page.length }}</label>
          <input id="len" type="number" min="6" max="128" value="16" inputmode="numeric">
        </div>
      </div>

      <div class="checkbox-row">
        <div class="checkbox-group">
          <input id="lower" type="checkbox" checked>
          <label for="lower">{{ passwordGenerator[locale].page.lowercase }}</label>
        </div>
        <div class="checkbox-group">
          <input id="upper" type="checkbox" checked>
          <label for="upper">{{ passwordGenerator[locale].page.uppercase }}</label>
        </div>
        <div class="checkbox-group">
          <input id="digits" type="checkbox" checked>
          <label for="digits">{{ passwordGenerator[locale].page.digits }}</label>
        </div>
        <div class="checkbox-group">
          <input id="symbols" type="checkbox">
          <label for="symbols">{{ passwordGenerator[locale].page.symbols }}</label>
        </div>
      </div>

      <div class="action-bar">
        <button type="button" class="calculate-btn" id="btn-generate">{{ passwordGenerator[locale].page.buttons.generate }}</button>
        <details class="more-actions">
          <summary>{{ passwordGenerator[locale].page.actions.more if passwordGenerator[locale].page.actions else 'Ещё' }}</summary>
          <div class="more-actions__list">
            <button type="button" id="btn-copy">{{ passwordGenerator[locale].page.buttons.copy }}</button>
            <button type="button" id="btn-reset">{{ passwordGenerator[locale].page.actions.reset if passwordGenerator[locale].page.actions else 'Сбросить' }}</button>
            <button type="button" id="btn-share">{{ passwordGenerator[locale].page.actions.share if passwordGenerator[locale].page.actions else 'Поделиться' }}</button>
          </div>
        </details>
      </div>

      <div class="results">
        <h3>{{ passwordGenerator[locale].page.result }}</h3>
        <div class="result-hero">
          <div class="out" id="out">—</div>
        </div>
        <p class="result-disclaimer">{{ passwordGenerator[locale].page.disclaimer if passwordGenerator[locale].page.disclaimer else 'Пароль создаётся локально в браузере и никуда не отправляется.' }}</p>
      </div>
    </div>

    <script>
      window.passwordGeneratorTranslations = {{ passwordGenerator[locale] | dump | safe }};
    </script>
    <script type="module" src="/frontend/scripts/tools/password-generator.js?v=1"></script>
    <script type="module" src="/frontend/scripts/tools/more-actions.js?v=1"></script>
    <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
    <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
  {% from "partials/mobile-anchor-ad.njk" import mobileAnchor %}
{{ mobileAnchor(passwordGenerator[locale].ads.closeAria) }}
{% include "partials/ad-pool-init.njk" %}
</body>
</html>
