---
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "{% if locale == 'ru' %}/frontend/games/snake/snake.html{% else %}/frontend/{{ locale }}/games/snake/snake.html{% endif %}"
eleventyComputed:
  title: "{{ gameSnakeTranslations[locale].gameSnake.pageTitle }}"
  description: "{{ gameSnakeTranslations[locale].gameSnake.metaDescription }}"
  dir: "{% if rtlLocales.indexOf(locale) != -1 %}rtl{% else %}ltr{% endif %}"
  canonical: "{% if locale == 'ru' %}{{ site.baseUrl }}/frontend/games/snake/snake.html{% else %}{{ site.baseUrl }}/frontend/{{ locale }}/games/snake/snake.html{% endif %}"
---

<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="Content-Language" content="{{ locale }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:title" content="{{ gameSnakeTranslations[locale].gameSnake.ogTitle }}">
  <meta property="og:description" content="{{ gameSnakeTranslations[locale].gameSnake.ogDescription }}">
  <meta property="og:image" content="{{ site.baseUrl }}/frontend/images/snake.png">

  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ canonical }}">
  <meta property="twitter:title" content="{{ gameSnakeTranslations[locale].gameSnake.ogTitle }}">
  <meta property="twitter:description" content="{{ gameSnakeTranslations[locale].gameSnake.twitterDescription }}">
  <meta property="twitter:image" content="{{ site.baseUrl }}/frontend/images/snake.png">

  <link rel="canonical" href="{{ canonical }}">
  <link rel="icon" href="/frontend/images/snake.png" type="image/x-icon">

  <link rel="stylesheet" href="/frontend/styles/styles.css">
  <link rel="stylesheet" href="/frontend/styles/base.css">
  <link rel="stylesheet" href="/frontend/styles/accessibility.css">
  <link rel="stylesheet" href="/frontend/styles/menu.css">
  <link rel="stylesheet" href="/frontend/games/snake/snake.css">

  <script type="module" src="/frontend/scripts/menu-loader.js" defer></script>
</head>
<body>
  <div id="menuContainer"></div>

  <script>
  (function(){
    function isMobile(){
      return /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || (window.innerWidth < 768);
    }
    function showInstructions(){
      try{
        if (localStorage.getItem('game_instructions_snake_shown') === '1') return;

        var ov = document.createElement('div');
        ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;z-index:9998;';

        var box = document.createElement('div');
        box.style.cssText = 'max-width:90vw;background:#141821;color:#fff;border:1px solid #1f2632;border-radius:12px;padding:16px;text-align:left;';

        var h = document.createElement('h3');
        h.textContent = '{{ gameSnakeTranslations[locale].gameSnake.howToTitle }}';
        h.style.margin = '0 0 8px';

        var p = document.createElement('div');
        p.style.cssText = 'font-size:14px;line-height:1.5;white-space:pre-line';
        p.textContent = isMobile() ? window.i18n.instructionsMobile : window.i18n.instructionsDesktop;

        var btn = document.createElement('button');
        btn.className = 'btn';
        btn.textContent = '{{ gameSnakeTranslations[locale].gameSnake.gotIt }}';
        btn.style.marginTop = '10px';
        btn.onclick = function(){
          localStorage.setItem('game_instructions_snake_shown','1');
          ov.remove();
        };

        box.appendChild(h);
        box.appendChild(p);
        box.appendChild(btn);
        ov.appendChild(box);
        document.body.appendChild(ov);
      }catch(e){}
    }
    document.addEventListener('DOMContentLoaded', showInstructions);
  })();
  </script>

  <div class="page">
    <header>
      <img src="/frontend/images/snake.png" width="28" height="28" alt="{{ gameSnakeTranslations[locale].gameSnake.gamesAlt }}" style="border-radius:6px;">
      <h1>{{ gameSnakeTranslations[locale].gameSnake.mainTitle }}</h1>
    </header>

    <div class="wrap">
      <div class="panel">
        <canvas id="game" width="480" height="480" aria-label="{{ gameSnakeTranslations[locale].gameSnake.canvasAria }}"></canvas>
        <div class="hint">{{ gameSnakeTranslations[locale].gameSnake.hint }}</div>
      </div>

      <div class="panel">
        <h2>{{ gameSnakeTranslations[locale].gameSnake.statsTitle }}</h2>

        <div class="stats">
          <div class="stat">{{ gameSnakeTranslations[locale].gameSnake.scoreLabel }}<br><b id="score">0</b></div>
          <div class="stat">{{ gameSnakeTranslations[locale].gameSnake.bestLabel }}<br><b id="best">0</b></div>
        </div>

        <div class="stats">
          <div class="stat">{{ gameSnakeTranslations[locale].gameSnake.speedLabel }}<br><b id="speed">1x</b></div>
          <div class="stat">{{ gameSnakeTranslations[locale].gameSnake.fieldSizeLabel }}<br><b>{{ gameSnakeTranslations[locale].gameSnake.fieldSizeValue }}</b></div>
        </div>

        <div style="display:flex; gap:8px; justify-content:center; margin-top:8px;">
          <button class="btn primary" id="btnStart">{{ gameSnakeTranslations[locale].gameSnake.btnStart }}</button>
          <button class="btn" id="btnPause">{{ gameSnakeTranslations[locale].gameSnake.btnPause }}</button>
          <button class="btn" id="btnReset">{{ gameSnakeTranslations[locale].gameSnake.btnReset }}</button>
        </div>

        <div class="controls" aria-label="{{ gameSnakeTranslations[locale].gameSnake.mobileControlsAria }}">
          <div></div>
          <button class="btn" data-dir="up">▲</button>
          <div></div>
          <button class="btn" data-dir="left">◀</button>
          <button class="btn" data-dir="down">▼</button>
          <button class="btn" data-dir="right">▶</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    window.i18n = {
      gameOver: {{ gameSnakeTranslations[locale].gameSnake.gameOver | dump | safe }},
      pressRToRestart: {{ gameSnakeTranslations[locale].gameSnake.pressRToRestart | dump | safe }},
      instructionsDesktop: {{ gameSnakeTranslations[locale].gameSnake.instructionsDesktop | dump | safe }},
      instructionsMobile: {{ gameSnakeTranslations[locale].gameSnake.instructionsMobile | dump | safe }}
    };
  </script>
  <script src="/frontend/games/snake/snake.js?v=2" defer></script>
  <script src="/frontend/scripts/mobile-enhancements.js" defer></script>
</body>
</html>
