# Env used by open-webui container (recreate with docker run --network host)
WEBUI_NAME=Serpmonn AI
WEBUI_URL=https://ai.serpmonn.ru
ENABLE_SIGNUP=true
ENABLE_LOGIN_FORM=false
ENABLE_VERSION_UPDATE_CHECK=false
ENABLE_API_KEYS=false
WEBUI_AUTH_TRUSTED_EMAIL_HEADER=X-Serpmonn-User-Email
WEBUI_AUTH_TRUSTED_NAME_HEADER=X-Serpmonn-User-Name
WEBUI_AUTH_SIGNOUT_REDIRECT_URL=https://serpmonn.ru/
OLLAMA_BASE_URL=http://127.0.0.1:11434
HOST=127.0.0.1
PORT=8080
DEFAULT_USER_ROLE=user
DEFAULT_MODELS=serpmonn-ai-search:latest,serpmonn-ai-fast:latest
USER_PERMISSIONS_WORKSPACE_MODELS_ACCESS=false
USER_PERMISSIONS_WORKSPACE_KNOWLEDGE_ACCESS=false
USER_PERMISSIONS_WORKSPACE_PROMPTS_ACCESS=false
USER_PERMISSIONS_WORKSPACE_TOOLS_ACCESS=false
