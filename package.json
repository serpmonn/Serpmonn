{
  "name": "serpmonn",
  "version": "1.0.0",
  "description": "Проект Serpmonn",
  "type": "module",
  "main": "backend/server.mjs",
  "scripts": {
    "start": "pm2 start ecosystem.config.cjs",
    "restart": "pm2 restart all",
    "stop": "pm2 stop all",
    "delete": "pm2 delete all",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "start-analytics": "pm2 start ecosystem.config.cjs --only goaccess-analytics",
    "start-auth": "pm2 start ecosystem.config.cjs --only auth-server",
    "start-check-pro": "pm2 start ecosystem.config.cjs --only check-pro",
    "start-news": "pm2 start ecosystem.config.cjs --only news-server",
    "start-leaderboard": "pm2 start ecosystem.config.cjs --only leaderboard-server",
    "start-onnmail": "pm2 start ecosystem.config.cjs --only onnmail-server",
    "start-password-reset": "pm2 start ecosystem.config.cjs --only password-reset-server",
    "start-ai": "pm2 start ecosystem.config.cjs --only ai-search",
    "start-autoReplyBot": "pm2 start ecosystem.config.cjs --only autoReplyBot",
    "start-communityBotBlog": "pm2 start ecosystem.config.cjs --only communityBotBlog",
    "start-communityBotSite": "pm2 start ecosystem.config.cjs --only communityBotSite",
    "start-serpmonnKeeperBot": "pm2 start ecosystem.config.cjs --only serpmonnKeeperBot",
    "site:build": "eleventy",
    "site:clean": "rm -rf dist",
    "lint": "eslint .",
    "validate:locales": "node scripts/validate-locales.mjs",
    "validate:i18n": "node scripts/validate-locales.mjs && node scripts/validate-locale-placeholders.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": {
    "name": "Sergei Popov",
    "email": "sergei@serpmonn.ru",
    "url": "https://serpmonn.ru"
  },
  "repositories": [
    {
      "type": "git",
      "name": "gitverse",
      "url": "ssh://git@gitverse.ru:2222/Serpmonn/Serpmonn_project.git",
      "description": "Основной рабочий репозиторий (GitVerse)"
    },
    {
      "type": "git",
      "name": "github",
      "url": "https://github.com/Serpmonn/serpmonn.git",
      "description": "GitHub зеркало"
    }
  ],
  "keywords": [
    "Serpmonn",
    "поиск",
    "новости",
    "игры",
    "инструменты",
    "автоматизация",
    "промокоды",
    "ии",
    "искусственный интеллект",
    "агентный поиск",
    "ai-search",
    "pwa",
    "twa",
    "russian",
    "российский"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsdom": "^26.0.0",
    "limiter": "^3.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^9.0.3",
    "paseto": "^3.1.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.35.3",
    "uuid": "^11.1.1",
    "yookassa": "^0.1.1"
  },
  "license": "Proprietary",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "nodemon": "^3.0.0",
    "nunjucks": "^3.2.4",
    "pm2": "^6.0.8",
    "supertest": "^7.0.0",
    "vite": "^7.1.7",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "tough-cookie": "^5.1.2",
    "on-headers": "^1.0.2",
    "request": "^2.88.2",
    "cookie": "^0.7.2",
    "qs": "^6.15.3",
    "js-yaml": "^4.1.1",
    "express": {
      "cookie": "^0.7.2"
    },
    "csurf": {
      "cookie": "^0.7.2"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
