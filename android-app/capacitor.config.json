{
  "appId": "ru.serpmonn",
  "appName": "Serpmonn",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#ffffff",
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "backgroundColor": "#ffffff",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#ffffff"
    }
  },
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "serpmonn.ru",
      "*.serpmonn.ru",
      "dev.serpmonn.ru"
    ]
  }
}
